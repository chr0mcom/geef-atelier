{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Llm": {
    "DefaultProvider": "openrouter",
    "DefaultMaxTokens": 4096,
    "Providers": {
      "openrouter": {
        "Endpoint": "https://openrouter.ai/api/v1",
        "ApiKey": ""
      },
      "claude-cli": {
        "Endpoint": "http://cli-proxy:8090/v1/claude",
        "ApiKey": ""
      },
      "codex-cli": {
        "Endpoint": "http://cli-proxy:8090/v1/codex",
        "ApiKey": ""
      }
    },
    "Actors": {
      "Executor": {
        "Provider": "openrouter",
        "Model": "anthropic/claude-opus-4.7",
        "MaxTokens": 8192
      },
      "BriefingTreueReviewer": {
        "Provider": "openrouter",
        "Model": "anthropic/claude-opus-4.7",
        "MaxTokens": 2048
      },
      "KlarheitReviewer": {
        "Provider": "openrouter",
        "Model": "anthropic/claude-opus-4.7",
        "MaxTokens": 2048
      }
    }
  },
  "Orchestrator": {
    "PollingInterval": "00:00:02",
    "MaxConcurrentRuns": 5,
    "CancellationPollingInterval": "00:00:01"
  },
  "Convergence": {
    "MaxIterations": 3,
    "AbortOnCritical": false,
    "DetectRegression": true,
    "StagnationThreshold": 3
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AtelierUser": {
    "Username": "",
    "PasswordHash": ""
  },
  "AtelierMcp": {
    "Token": ""
  },
  "Tavily": {
    "Endpoint": "https://api.tavily.com",
    "BasicSearchCostUsd": 0.001,
    "AdvancedSearchCostUsd": 0.002,
    "UsdToEurRate": 0.92,
    "RequestTimeoutSeconds": 30
  }
}
