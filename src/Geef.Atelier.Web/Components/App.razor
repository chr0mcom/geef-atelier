@inject IHttpContextAccessor Http

<!DOCTYPE html>
<html lang="en" class="@HtmlRootClass">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["atelier.css"]" />
    <link rel="stylesheet" href="@Assets["atelier-dashboard.css"]" />
    <link rel="stylesheet" href="@Assets["Geef.Atelier.Web.styles.css"]" />
    @if (UsesLandingChrome)
    {
        <link rel="stylesheet" href="@Assets["atelier-landing.css"]" />
    }
    <ImportMap />
    <!-- Modern PNG favicons -->
    <link rel="icon" type="image/png" sizes="16x16" href="favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="favicon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="favicon-512.png" />
    <!-- Dark mode hint -->
    <link rel="icon" type="image/png" sizes="16x16" href="favicon-noir-16.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="32x32" href="favicon-noir-32.png" media="(prefers-color-scheme: dark)" />
    <!-- Apple Touch -->
    <link rel="apple-touch-icon" sizes="192x192" href="apple-touch-icon.png" />
    <!-- Web Manifest for PWA / Android home screen -->
    <link rel="manifest" href="site.webmanifest" />
    <HeadOutlet />
    <script defer src="@Assets["js/theme.js"]"></script>
    <script defer src="@Assets["js/email-deobfuscate.js"]"></script>
    @if (IsLanding)
    {
        <script defer src="@Assets["js/landing.js"]"></script>
    }
</head>

<body class="@BodyClass">
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    static readonly HashSet<string> AllowedThemes = ["vellum", "noir", "petrol"];

    /// <summary>Public, pre-login pages that share the landing design language.</summary>
    static readonly HashSet<string> PublicLandingPaths =
    [
        "/", "/pricing", "/docs", "/self-host", "/status",
        "/changelog", "/contact", "/imprint", "/privacy", "/terms",
    ];

    bool IsLanding => Http.HttpContext?.Request.Path.Value == "/";

    /// <summary>True for any public landing-styled page — drives shared CSS + chrome.</summary>
    bool UsesLandingChrome =>
        PublicLandingPaths.Contains(Http.HttpContext?.Request.Path.Value ?? "");

    string Theme
    {
        get
        {
            var v = Http.HttpContext?.Request.Cookies["Atelier.Theme"];
            return v is not null && AllowedThemes.Contains(v) ? v : "vellum";
        }
    }

    string HtmlRootClass => $"palette-{Theme}{(UsesLandingChrome ? " landing-root" : "")}";
    string BodyClass => UsesLandingChrome ? "landing-body" : "";

    /// <summary>Dashboard scope read from cookie; defaults to "my".</summary>
    internal string DashboardScope
    {
        get
        {
            var v = Http.HttpContext?.Request.Cookies["Atelier.DashboardScope"];
            return v == "all" ? "all" : "my";
        }
    }
}
