@inject IHttpContextAccessor Http

<!DOCTYPE html>
<html lang="en" class="palette-@Theme">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["atelier.css"]" />
    <link rel="stylesheet" href="@Assets["Geef.Atelier.Web.styles.css"]" />
    <ImportMap />
    <!-- Modern PNG favicons -->
    <link rel="icon" type="image/png" sizes="16x16" href="favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="favicon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="favicon-512.png" />
    <!-- Dark mode hint -->
    <link rel="icon" type="image/png" sizes="16x16" href="favicon-noir-16.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="32x32" href="favicon-noir-32.png" media="(prefers-color-scheme: dark)" />
    <!-- Apple Touch -->
    <link rel="apple-touch-icon" sizes="192x192" href="apple-touch-icon.png" />
    <!-- Web Manifest for PWA / Android home screen -->
    <link rel="manifest" href="site.webmanifest" />
    <HeadOutlet />
    <script defer src="@Assets["js/theme.js"]"></script>
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    static readonly HashSet<string> AllowedThemes = ["vellum", "noir", "petrol"];

    string Theme
    {
        get
        {
            var v = Http.HttpContext?.Request.Cookies["Atelier.Theme"];
            return v is not null && AllowedThemes.Contains(v) ? v : "vellum";
        }
    }
}
