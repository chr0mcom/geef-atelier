@using System.ComponentModel.DataAnnotations
@using Geef.Atelier.Application.Crew
@using Geef.Atelier.Application.Providers
@using Geef.Atelier.Core.Domain.Crew.Advisors
@using Geef.Atelier.Core.Domain.Providers
@inject IProviderService ProviderService

<div data-testid="profile-editor">
    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="error-banner">@Error</div>
    }

    <EditForm Model="_form" OnValidSubmit="HandleSave">
        <DataAnnotationsValidator />
        <ValidationSummary />

        @* ── §0 Grunddaten ── *@
        <div class="template-meta-section">
            <h3>Grunddaten</h3>

            <div class="field">
                <label>Name</label>
                <InputText @bind-Value="_form.Name" disabled="@IsSystem" placeholder="mein-profil" />
                @if (!IsSystem && !string.IsNullOrEmpty(_form.Name))
                {
                    <small class="form-hint">Wird gespeichert als: custom-@_form.Name.TrimStart("custom-".ToCharArray())</small>
                }
                <ValidationMessage For="() => _form.Name" />
            </div>

            <div class="field">
                <label>Anzeigename</label>
                <InputText @bind-Value="_form.DisplayName" disabled="@IsSystem" />
                <ValidationMessage For="() => _form.DisplayName" />
            </div>

            <div class="field">
                <label>Beschreibung</label>
                <InputTextArea @bind-Value="_form.Description" rows="2" disabled="@IsSystem" />
                <ValidationMessage For="() => _form.Description" />
            </div>
        </div>

        @* ── §1 Modell-Konfiguration ── *@
        <div class="pipeline-stage-section">
            <div class="pipeline-stage-header">
                <div class="pipeline-stage-header-text">
                    <h3>Modell-Konfiguration</h3>
                    <p class="pipeline-stage-desc">LLM-Anbieter, Modell und maximale Ausgabelänge für dieses Profil.</p>
                </div>
            </div>

            <div class="field-grid">
                <div class="field">
                    <label>Anbieter</label>
                    <InputSelect @bind-Value="_form.Provider" disabled="@IsSystem">
                        <optgroup label="HTTP">
                            @foreach (var p in _providers.Where(p => p.Type == ProviderType.Http && p.IsActive))
                            {
                                <option value="@p.Name">@p.DisplayName</option>
                            }
                        </optgroup>
                        <optgroup label="CLI">
                            @foreach (var p in _providers.Where(p => p.Type == ProviderType.Cli && p.IsActive))
                            {
                                <option value="@p.Name">@p.DisplayName</option>
                            }
                        </optgroup>
                    </InputSelect>
                    <small class="form-hint">OpenRouter wird pro Token abgerechnet. CLI-Anbieter nutzen ein lokales Abonnement.</small>
                    <ValidationMessage For="() => _form.Provider" />
                </div>

                <div class="field">
                    <label>Modell</label>
                    <ModelSelector @ref="_modelSelector"
                                   Provider="@_form.Provider"
                                   @bind-Value="_form.Model"
                                   Disabled="@IsSystem"
                                   DataTestId="model-selector" />
                    <ValidationMessage For="() => _form.Model" />
                </div>

                <div class="field">
                    <label>Max. Token (optional)</label>
                    <InputNumber @bind-Value="_form.MaxTokens" disabled="@IsSystem" />
                </div>
            </div>
        </div>

        @* ── §2 System-Prompt ── *@
        <div class="pipeline-stage-section">
            <div class="pipeline-stage-header">
                <div class="pipeline-stage-header-text">
                    <h3>System-Prompt</h3>
                    <p class="pipeline-stage-desc">Rolle und Verhalten des Profils. @(_form.SystemPrompt?.Length ?? 0)/8000 Zeichen.</p>
                </div>
            </div>

            <div class="field">
                <InputTextArea @bind-Value="_form.SystemPrompt" rows="15"
                               style="font-family: var(--font-mono, monospace); font-size: 0.82rem;"
                               disabled="@IsSystem" data-testid="profile-systemprompt" />
                <ValidationMessage For="() => _form.SystemPrompt" />
            </div>
        </div>

        @* ── §3 Advisor-Einstellungen (optional) ── *@
        @if (ShowAdvisorFields)
        {
            <div class="pipeline-stage-section">
                <div class="pipeline-stage-header">
                    <div class="pipeline-stage-header-text">
                        <h3>Advisor-Einstellungen</h3>
                        <p class="pipeline-stage-desc">Wie und wann der Advisor in den Pipeline-Ablauf eingreift.</p>
                    </div>
                </div>

                <div class="field">
                    <label>Modus</label>
                    <div class="radio-group" data-testid="advisor-mode-group">
                        @foreach (var mode in Enum.GetValues<AdvisorMode>())
                        {
                            <label class="radio-option">
                                <input type="radio"
                                       name="advisor-mode"
                                       value="@mode"
                                       checked="@(SelectedMode == mode)"
                                       disabled="@IsSystem"
                                       @onchange="() => SelectedModeChanged.InvokeAsync(mode)" />
                                <span>
                                    <strong>@GetAdvisorModeLabel(mode)</strong>
                                    <span class="radio-description">@GetAdvisorModeDescription(mode)</span>
                                </span>
                            </label>
                        }
                    </div>
                </div>

                <div class="field">
                    <label>Auslöser</label>
                    <div class="radio-group" data-testid="advisor-trigger-group">
                        @foreach (var trigger in Enum.GetValues<AdvisorTrigger>())
                        {
                            <label class="radio-option">
                                <input type="radio"
                                       name="advisor-trigger"
                                       value="@trigger"
                                       checked="@(SelectedTrigger == trigger)"
                                       disabled="@IsSystem"
                                       @onchange="() => SelectedTriggerChanged.InvokeAsync(trigger)" />
                                <span>
                                    <strong>@GetAdvisorTriggerLabel(trigger)</strong>
                                    <span class="radio-description">@GetAdvisorTriggerDescription(trigger)</span>
                                </span>
                            </label>
                        }
                    </div>
                </div>
            </div>
        }

        @* ── Aktionsleiste ── *@
        <div class="editor-actions">
            @if (!IsSystem)
            {
                <button type="submit" class="btn primary" data-testid="save-profile" disabled="@IsSaving">
                    @(IsSaving ? "Speichern…" : IsNew ? "Erstellen" : "Speichern")
                </button>
            }
            else
            {
                <button type="button" class="btn primary" @onclick="() => OnDuplicate.InvokeAsync()">
                    Als Kopie anlegen
                </button>
            }
            <button type="button" class="btn ghost" @onclick="() => OnCancel.InvokeAsync()">Abbrechen</button>
            @if (!IsNew && !IsSystem && OnDeleteRequested.HasDelegate)
            {
                <button type="button" class="btn danger" @onclick="() => OnDeleteRequested.InvokeAsync()">Löschen</button>
            }
        </div>
    </EditForm>
</div>

<Modal Show="_showCustomModelWarning" OnClose="CancelCustomModelSave" DataTestId="custom-model-warning-modal">
    <Title>Unbekanntes Modell</Title>
    <ChildContent>
        <p>Modell <strong>@_form.Model</strong> ist nicht im Katalog für diesen Anbieter.</p>
        <p>Profil trotzdem mit diesem Modellnamen speichern?</p>
    </ChildContent>
    <Actions>
        <button type="button" class="btn primary" @onclick="ConfirmCustomModelSave" data-testid="custom-model-confirm">Trotzdem speichern</button>
        <button type="button" class="btn ghost"   @onclick="CancelCustomModelSave">Abbrechen</button>
    </Actions>
</Modal>

@code {
    [Parameter] public string? ProfileName { get; set; }
    [Parameter] public string DisplayName { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public string SystemPrompt { get; set; } = "";
    [Parameter] public string Provider { get; set; } = "";
    [Parameter] public string Model { get; set; } = "";
    [Parameter] public int? MaxTokens { get; set; }
    [Parameter] public bool IsSystem { get; set; }
    [Parameter] public bool IsSaving { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public bool ShowAdvisorFields { get; set; }
    [Parameter] public AdvisorMode? SelectedMode { get; set; }
    [Parameter] public EventCallback<AdvisorMode?> SelectedModeChanged { get; set; }
    [Parameter] public AdvisorTrigger? SelectedTrigger { get; set; }
    [Parameter] public EventCallback<AdvisorTrigger?> SelectedTriggerChanged { get; set; }
    [Parameter] public EventCallback<ProfileFormValues> OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnDuplicate { get; set; }
    [Parameter] public EventCallback OnDeleteRequested { get; set; }

    private bool IsNew => ProfileName == null;
    private IReadOnlyList<Provider> _providers = [];
    private ProfileFormModel _form = new();
    private ModelSelector? _modelSelector;
    private bool _showCustomModelWarning = false;

    protected override async Task OnInitializedAsync()
    {
        _providers = await ProviderService.ListAsync(includeInactive: false);
        var effectiveProvider = !string.IsNullOrEmpty(Provider) ? Provider
            : _providers.Count > 0 ? _providers[0].Name : "";
        _form = new ProfileFormModel
        {
            Name = ProfileName ?? "",
            DisplayName = DisplayName,
            Description = Description,
            SystemPrompt = SystemPrompt,
            Provider = effectiveProvider,
            Model = Model,
            MaxTokens = MaxTokens,
        };
    }

    private async Task HandleSave()
    {
        if (_modelSelector?.IsCustomModel() == true)
        {
            _showCustomModelWarning = true;
            return;
        }
        await CommitSaveAsync();
    }

    private async Task ConfirmCustomModelSave()
    {
        _showCustomModelWarning = false;
        await CommitSaveAsync();
    }

    private void CancelCustomModelSave() => _showCustomModelWarning = false;

    private async Task CommitSaveAsync()
    {
        await OnSave.InvokeAsync(new ProfileFormValues(
            _form.Name,
            _form.DisplayName,
            _form.Description,
            _form.SystemPrompt ?? "",
            _form.Provider,
            _form.Model ?? "",
            _form.MaxTokens,
            SelectedMode,
            SelectedTrigger));
    }

    private static string GetAdvisorModeLabel(AdvisorMode m) => m switch
    {
        AdvisorMode.Strategic      => "Strategisch",
        AdvisorMode.Critical       => "Kritisch",
        AdvisorMode.DevilsAdvocate => "Advocatus Diaboli",
        AdvisorMode.DomainExpert   => "Domänen-Experte",
        _                          => m.ToString()
    };

    private static string GetAdvisorModeDescription(AdvisorMode m) => m switch
    {
        AdvisorMode.Strategic      => "Liefert strategische Beratung vor dem ersten Executor-Durchlauf",
        AdvisorMode.Critical       => "Kritische Analyse der Annahmen und Schwachstellen im Artefakt",
        AdvisorMode.DevilsAdvocate => "Hinterfragt die stärksten Thesen, um verborgene Schwächen aufzudecken",
        AdvisorMode.DomainExpert   => "Bringt domänenspezifisches Fachwissen in die Beratung ein",
        _                          => m.ToString()
    };

    private static string GetAdvisorTriggerLabel(AdvisorTrigger t) => t switch
    {
        AdvisorTrigger.BeforeFirstExecution => "Vor dem ersten Durchlauf",
        AdvisorTrigger.BeforeEveryExecution => "Vor jedem Durchlauf",
        AdvisorTrigger.OnConvergenceFailure => "Bei Konvergenz-Fehlschlag",
        _                                   => t.ToString()
    };

    private static string GetAdvisorTriggerDescription(AdvisorTrigger t) => t switch
    {
        AdvisorTrigger.BeforeFirstExecution => "Wird nur vor der ersten Iteration konsultiert",
        AdvisorTrigger.BeforeEveryExecution => "Wird vor jeder Iteration konsultiert",
        AdvisorTrigger.OnConvergenceFailure => "Wird konsultiert, wenn die Konvergenz scheitert (Retry-Modus)",
        _                                   => t.ToString()
    };

    private sealed class ProfileFormModel
    {
        [Required, RegularExpression(@"^[a-z0-9\-]+$", ErrorMessage = "Nur Kleinbuchstaben, Ziffern und Bindestriche")]
        [MaxLength(64)]
        public string Name { get; set; } = "";

        [Required, MaxLength(200)]
        public string DisplayName { get; set; } = "";

        [MaxLength(1000)]
        public string Description { get; set; } = "";

        [Required, MaxLength(8000)]
        public string? SystemPrompt { get; set; } = "";

        [Required]
        public string Provider { get; set; } = "";

        [Required]
        public string? Model { get; set; } = "";

        public int? MaxTokens { get; set; }
    }

    public sealed record ProfileFormValues(
        string Name,
        string DisplayName,
        string Description,
        string SystemPrompt,
        string Provider,
        string Model,
        int? MaxTokens,
        AdvisorMode? Mode = null,
        AdvisorTrigger? Trigger = null);
}
