@using System.ComponentModel.DataAnnotations
@using Geef.Atelier.Application.Crew
@using Geef.Atelier.Application.Providers
@using Geef.Atelier.Core.Domain.Crew.Advisors
@using Geef.Atelier.Core.Domain.Providers
@using Geef.Atelier.Core.Domain.Tools
@using Geef.Atelier.Web.Services
@inject IProviderService ProviderService
@inject IToolDefinitionService ToolService

<div data-testid="profile-editor">
    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="error-banner">@Error</div>
    }

    <EditForm Model="_form" OnValidSubmit="HandleSave">
        <DataAnnotationsValidator />
        <ValidationSummary />

        @* ── §0 Basics ── *@
        <div class="template-meta-section">
            <h3>Basics</h3>

            <div class="field">
                <label>Name</label>
                <InputText @bind-Value="_form.Name" disabled="@IsSystem" placeholder="my-profile" />
                @if (!IsSystem && !string.IsNullOrEmpty(_form.Name))
                {
                    <small class="form-hint">Saved as: custom-@_form.Name.TrimStart("custom-".ToCharArray())</small>
                }
                <ValidationMessage For="() => _form.Name" />
            </div>

            <div class="field">
                <label>Display name</label>
                <InputText @bind-Value="_form.DisplayName" disabled="@IsSystem" />
                <ValidationMessage For="() => _form.DisplayName" />
            </div>

            <div class="field">
                <label>Description</label>
                <InputTextArea @bind-Value="_form.Description" rows="2" disabled="@IsSystem" />
                <ValidationMessage For="() => _form.Description" />
            </div>
        </div>

        @* ── §1 Model configuration ── *@
        <div class="pipeline-stage-section">
            <div class="pipeline-stage-header">
                <div class="pipeline-stage-header-text">
                    <h3>Model configuration</h3>
                    <p class="pipeline-stage-desc">LLM provider, model and maximum output length for this profile.</p>
                </div>
            </div>

            <div class="field-grid">
                <div class="field">
                    <label>Provider</label>
                    <InputSelect @bind-Value="_form.Provider" disabled="@IsSystem">
                        <optgroup label="HTTP">
                            @foreach (var p in _providers.Where(p => p.Type == ProviderType.Http && p.IsActive))
                            {
                                <option value="@p.Name">@p.DisplayName</option>
                            }
                        </optgroup>
                        <optgroup label="CLI">
                            @foreach (var p in _providers.Where(p => p.Type == ProviderType.Cli && p.IsActive))
                            {
                                <option value="@p.Name">@p.DisplayName</option>
                            }
                        </optgroup>
                    </InputSelect>
                    <small class="form-hint">OpenRouter is billed per token. CLI providers use a local subscription.</small>
                    <ValidationMessage For="() => _form.Provider" />
                </div>

                <div class="field">
                    <label>Model</label>
                    <ModelSelector @ref="_modelSelector"
                                   Provider="@_form.Provider"
                                   @bind-Value="_form.Model"
                                   Disabled="@IsSystem"
                                   DataTestId="model-selector" />
                    <ValidationMessage For="() => _form.Model" />
                </div>

                <div class="field">
                    <label>Max tokens (optional)</label>
                    <InputNumber @bind-Value="_form.MaxTokens" disabled="@IsSystem" />
                </div>
            </div>
        </div>

        @* ── §2 System prompt ── *@
        <div class="pipeline-stage-section">
            <div class="pipeline-stage-header">
                <div class="pipeline-stage-header-text">
                    <h3>System prompt</h3>
                    <p class="pipeline-stage-desc">The profile's role and behaviour. @(_form.SystemPrompt?.Length ?? 0)/8000 characters.</p>
                </div>
            </div>

            <div class="field">
                <InputTextArea @bind-Value="_form.SystemPrompt" rows="15"
                               style="font-family: var(--font-mono, monospace); font-size: 0.82rem;"
                               disabled="@IsSystem" data-testid="profile-systemprompt" />
                <ValidationMessage For="() => _form.SystemPrompt" />
            </div>
        </div>

        @* ── §3 Tools (optional) ── *@
        @if (ShowToolPicker)
        {
            <div class="pipeline-stage-section">
                <div class="pipeline-stage-header">
                    <div class="pipeline-stage-header-text">
                        <h3>Tools</h3>
                        <p class="pipeline-stage-desc">
                            Tools from the catalogue this profile may call in the agentic tool-use loop.
                            Empty = standard single-shot completion.
                        </p>
                    </div>
                </div>

                <ToolPicker SelectedToolNames="_selectedToolNames"
                            SelectedToolNamesChanged="OnToolNamesChanged"
                            AllTools="_allTools"
                            CanSelectProvider="@_providerSupportsAgenticTools" />
            </div>
        }

        @* ── §4 Advisor settings (optional) ── *@
        @if (ShowAdvisorFields)
        {
            <div class="pipeline-stage-section">
                <div class="pipeline-stage-header">
                    <div class="pipeline-stage-header-text">
                        <h3>Advisor settings</h3>
                        <p class="pipeline-stage-desc">How and when the advisor intervenes in the pipeline.</p>
                    </div>
                </div>

                <div class="field">
                    <label>Mode</label>
                    <div class="radio-group" data-testid="advisor-mode-group">
                        @foreach (var mode in Enum.GetValues<AdvisorMode>())
                        {
                            <label class="radio-option">
                                <input type="radio"
                                       name="advisor-mode"
                                       value="@mode"
                                       checked="@(SelectedMode == mode)"
                                       disabled="@IsSystem"
                                       @onchange="() => SelectedModeChanged.InvokeAsync(mode)" />
                                <span>
                                    <strong>@GetAdvisorModeLabel(mode)</strong>
                                    <span class="radio-description">@GetAdvisorModeDescription(mode)</span>
                                </span>
                            </label>
                        }
                    </div>
                </div>

                <div class="field">
                    <label>Trigger</label>
                    <div class="radio-group" data-testid="advisor-trigger-group">
                        @foreach (var trigger in Enum.GetValues<AdvisorTrigger>())
                        {
                            <label class="radio-option">
                                <input type="radio"
                                       name="advisor-trigger"
                                       value="@trigger"
                                       checked="@(SelectedTrigger == trigger)"
                                       disabled="@IsSystem"
                                       @onchange="() => SelectedTriggerChanged.InvokeAsync(trigger)" />
                                <span>
                                    <strong>@GetAdvisorTriggerLabel(trigger)</strong>
                                    <span class="radio-description">@GetAdvisorTriggerDescription(trigger)</span>
                                </span>
                            </label>
                        }
                    </div>
                </div>
            </div>
        }

        @* ── Action bar ── *@
        <div class="editor-actions">
            @if (!IsSystem)
            {
                <button type="submit" class="btn primary" data-testid="save-profile" disabled="@IsSaving">
                    @(IsSaving ? "Saving…" : IsNew ? "Create" : "Save")
                </button>
            }
            else
            {
                <button type="button" class="btn primary" @onclick="() => OnDuplicate.InvokeAsync()">
                    Duplicate as custom
                </button>
            }
            <button type="button" class="btn ghost" @onclick="() => OnCancel.InvokeAsync()">Cancel</button>
            @if (!IsNew && !IsSystem && OnDeleteRequested.HasDelegate)
            {
                <button type="button" class="btn danger" @onclick="() => OnDeleteRequested.InvokeAsync()">Delete</button>
            }
        </div>
    </EditForm>
</div>

<Modal Show="_showCustomModelWarning" OnClose="CancelCustomModelSave" DataTestId="custom-model-warning-modal">
    <Title>Unknown model</Title>
    <ChildContent>
        <p>Model <strong>@_form.Model</strong> is not in the catalogue for this provider.</p>
        <p>Save the profile with this model name anyway?</p>
    </ChildContent>
    <Actions>
        <button type="button" class="btn primary" @onclick="ConfirmCustomModelSave" data-testid="custom-model-confirm">Save anyway</button>
        <button type="button" class="btn ghost"   @onclick="CancelCustomModelSave">Cancel</button>
    </Actions>
</Modal>

@code {
    [Parameter] public string? ProfileName { get; set; }
    [Parameter] public string DisplayName { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public string SystemPrompt { get; set; } = "";
    [Parameter] public string Provider { get; set; } = "";
    [Parameter] public string Model { get; set; } = "";
    [Parameter] public int? MaxTokens { get; set; }
    [Parameter] public bool IsSystem { get; set; }
    [Parameter] public bool IsSaving { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public bool ShowToolPicker { get; set; }
    [Parameter] public IReadOnlyList<string>? InitialToolNames { get; set; }
    [Parameter] public bool ShowAdvisorFields { get; set; }
    [Parameter] public AdvisorMode? SelectedMode { get; set; }
    [Parameter] public EventCallback<AdvisorMode?> SelectedModeChanged { get; set; }
    [Parameter] public AdvisorTrigger? SelectedTrigger { get; set; }
    [Parameter] public EventCallback<AdvisorTrigger?> SelectedTriggerChanged { get; set; }
    [Parameter] public EventCallback<ProfileFormValues> OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnDuplicate { get; set; }
    [Parameter] public EventCallback OnDeleteRequested { get; set; }

    private bool IsNew => ProfileName == null;
    private IReadOnlyList<Provider> _providers = [];
    private IReadOnlyList<ToolDefinition> _allTools = [];
    private ProfileFormModel _form = new();
    private ModelSelector? _modelSelector;
    private bool _showCustomModelWarning = false;
    private List<string> _selectedToolNames = [];
    private bool _providerSupportsAgenticTools = true;

    protected override async Task OnInitializedAsync()
    {
        _providers = await ProviderService.ListAsync(includeInactive: false);
        // Load the tool catalogue here (sequentially) and pass it to the child ToolPicker, so the picker
        // does not query concurrently with this component on the shared circuit-scoped DbContext.
        if (ShowToolPicker)
            _allTools = await ToolService.GetAllAsync();
        var effectiveProvider = !string.IsNullOrEmpty(Provider) ? Provider
            : _providers.Count > 0 ? _providers[0].Name : "";
        _form = new ProfileFormModel
        {
            Name = ProfileName ?? "",
            DisplayName = DisplayName,
            Description = Description,
            SystemPrompt = SystemPrompt,
            Provider = effectiveProvider,
            Model = Model,
            MaxTokens = MaxTokens,
        };

        _selectedToolNames = InitialToolNames?.ToList() ?? [];
        await UpdateAgenticToolsSupportAsync(effectiveProvider);
    }

    private async Task UpdateAgenticToolsSupportAsync(string providerName)
    {
        if (!ShowToolPicker || string.IsNullOrEmpty(providerName))
        {
            _providerSupportsAgenticTools = true;
            return;
        }
        var provider = await ProviderService.GetByNameAsync(providerName);
        _providerSupportsAgenticTools = provider?.SupportsAgenticTools() ?? true;
    }

    private void OnToolNamesChanged(List<string> names)
    {
        _selectedToolNames = names;
    }

    private async Task HandleSave()
    {
        if (_modelSelector?.IsCustomModel() == true)
        {
            _showCustomModelWarning = true;
            return;
        }
        await CommitSaveAsync();
    }

    private async Task ConfirmCustomModelSave()
    {
        _showCustomModelWarning = false;
        await CommitSaveAsync();
    }

    private void CancelCustomModelSave() => _showCustomModelWarning = false;

    private async Task CommitSaveAsync()
    {
        await OnSave.InvokeAsync(new ProfileFormValues(
            _form.Name,
            _form.DisplayName,
            _form.Description,
            _form.SystemPrompt ?? "",
            _form.Provider,
            _form.Model ?? "",
            _form.MaxTokens,
            SelectedMode,
            SelectedTrigger,
            _selectedToolNames.Count > 0 ? _selectedToolNames : null));
    }

    private static string GetAdvisorModeLabel(AdvisorMode m) => m switch
    {
        AdvisorMode.Strategic      => "Strategic",
        AdvisorMode.Critical       => "Critical",
        AdvisorMode.DevilsAdvocate => "Devil's advocate",
        AdvisorMode.DomainExpert   => "Domain expert",
        _                          => m.ToString()
    };

    private static string GetAdvisorModeDescription(AdvisorMode m) => m switch
    {
        AdvisorMode.Strategic      => "Provides strategic advice before the first executor run",
        AdvisorMode.Critical       => "Critical analysis of the assumptions and weaknesses in the artifact",
        AdvisorMode.DevilsAdvocate => "Challenges the strongest claims to surface hidden weaknesses",
        AdvisorMode.DomainExpert   => "Brings domain-specific expertise into the advice",
        _                          => m.ToString()
    };

    private static string GetAdvisorTriggerLabel(AdvisorTrigger t) => t switch
    {
        AdvisorTrigger.BeforeFirstExecution => "Before the first run",
        AdvisorTrigger.BeforeEveryExecution => "Before every run",
        AdvisorTrigger.OnConvergenceFailure => "On convergence failure",
        _                                   => t.ToString()
    };

    private static string GetAdvisorTriggerDescription(AdvisorTrigger t) => t switch
    {
        AdvisorTrigger.BeforeFirstExecution => "Consulted only before the first iteration",
        AdvisorTrigger.BeforeEveryExecution => "Consulted before every iteration",
        AdvisorTrigger.OnConvergenceFailure => "Consulted when convergence fails (retry mode)",
        _                                   => t.ToString()
    };

    private sealed class ProfileFormModel
    {
        [Required, RegularExpression(@"^[a-z0-9\-]+$", ErrorMessage = "Lowercase letters, digits and hyphens only")]
        [MaxLength(64)]
        public string Name { get; set; } = "";

        [Required, MaxLength(200)]
        public string DisplayName { get; set; } = "";

        [MaxLength(1000)]
        public string Description { get; set; } = "";

        [Required, MaxLength(8000)]
        public string? SystemPrompt { get; set; } = "";

        [Required]
        public string Provider { get; set; } = "";

        [Required]
        public string? Model { get; set; } = "";

        public int? MaxTokens { get; set; }
    }

    public sealed record ProfileFormValues(
        string Name,
        string DisplayName,
        string Description,
        string SystemPrompt,
        string Provider,
        string Model,
        int? MaxTokens,
        AdvisorMode? Mode = null,
        AdvisorTrigger? Trigger = null,
        IReadOnlyList<string>? ToolNames = null);
}
