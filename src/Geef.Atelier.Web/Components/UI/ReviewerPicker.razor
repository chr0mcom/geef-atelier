@using Geef.Atelier.Core.Domain.Crew.Profiles

<div class="reviewer-picker" data-testid="reviewer-picker">
    <div class="reviewer-picker-columns">
        <div class="reviewer-picker-available">
            <h4>Available</h4>
            @foreach (var profile in AvailableNotSelected)
            {
                <button type="button" class="reviewer-picker-item"
                        data-testid="reviewer-picker-available-@profile.Name"
                        @onclick="() => Add(profile.Name)">
                    @profile.DisplayName
                    @if (profile.IsSystem) { <span class="crew-badge">System</span> }
                </button>
            }
        </div>
        <div class="reviewer-picker-selected">
            <h4>Selected</h4>
            @for (int i = 0; i < Selected.Count; i++)
            {
                var idx = i;
                var name = Selected[idx];
                var profile = FindProfile(name);
                <div class="reviewer-picker-selected-item" data-testid="reviewer-picker-selected-@name">
                    <span>@(profile?.DisplayName ?? name)</span>
                    <div class="reviewer-picker-actions">
                        <button type="button" class="btn small ghost" disabled="@(idx == 0)"
                                data-testid="reviewer-picker-up-@name"
                                @onclick="() => MoveUp(idx)">↑</button>
                        <button type="button" class="btn small ghost" disabled="@(idx == Selected.Count - 1)"
                                data-testid="reviewer-picker-down-@name"
                                @onclick="() => MoveDown(idx)">↓</button>
                        <button type="button" class="btn small danger"
                                @onclick="() => Remove(idx)">×</button>
                    </div>
                </div>
            }
            @if (Selected.Count == 0)
            {
                <p class="text-muted">No reviewers selected.</p>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ReviewerProfile> AllProfiles { get; set; } = [];
    [Parameter, EditorRequired] public List<string> Selected { get; set; } = [];
    [Parameter] public EventCallback<List<string>> SelectedChanged { get; set; }

    private IEnumerable<ReviewerProfile> AvailableNotSelected =>
        AllProfiles.Where(p => !Selected.Contains(p.Name));

    private ReviewerProfile? FindProfile(string name) =>
        AllProfiles.FirstOrDefault(p => p.Name == name);

    private async Task Add(string name)
    {
        if (!Selected.Contains(name))
        {
            Selected = [.. Selected, name];
            await SelectedChanged.InvokeAsync(Selected);
        }
    }

    private async Task Remove(int idx)
    {
        var newList = Selected.ToList();
        newList.RemoveAt(idx);
        Selected = newList;
        await SelectedChanged.InvokeAsync(Selected);
    }

    private async Task MoveUp(int idx)
    {
        if (idx <= 0) return;
        var newList = Selected.ToList();
        (newList[idx - 1], newList[idx]) = (newList[idx], newList[idx - 1]);
        Selected = newList;
        await SelectedChanged.InvokeAsync(Selected);
    }

    private async Task MoveDown(int idx)
    {
        if (idx >= Selected.Count - 1) return;
        var newList = Selected.ToList();
        (newList[idx + 1], newList[idx]) = (newList[idx], newList[idx + 1]);
        Selected = newList;
        await SelectedChanged.InvokeAsync(Selected);
    }
}
