@inject IJSRuntime JS

<span @ref="_ref" class="obf-email" data-u="@_user" data-d="@_domain"
      aria-label="Email address (revealed via JavaScript)"></span>

@code {
    [Parameter, EditorRequired] public string Email { get; set; } = "";

    private ElementReference _ref;
    private string _user = "";
    private string _domain = "";

    protected override void OnParametersSet()
    {
        var parts = Email.Split('@');
        _user   = parts.Length == 2 ? parts[0] : "";
        _domain = parts.Length == 2 ? parts[1] : "";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_user.Length > 0 && _domain.Length > 0)
            await JS.InvokeVoidAsync("deobfuscateEmail", _ref);
    }
}
