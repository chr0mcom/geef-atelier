<section class="lp-section lp-film lp-reveal" id="film">
    <div class="lp-container">
        <div class="lp-film-head">
            <p class="lp-eyebrow centered">The film · 60 seconds</p>
            <h2 class="lp-h2">See the whole <em>manufactory</em> in motion.</h2>
            <p class="lp-lede">
                From a blank briefing to a sealed manuscript — the grounding,
                the drafting, the crew's critique, and the final press, in one minute.
            </p>
        </div>

        <div class="lp-film-frame">
            <div class="lp-film-colophon">
                <span>Folio II</span>
                <span><b>The film</b></span>
            </div>
            <div class="lp-film-colophon-r">Reel · 00:60</div>

            <div class="lp-film-stage" data-testid="film-stage">
                <video class="lp-film-video" playsinline preload="none"
                       poster="media/geef-film-poster.jpg" data-testid="film-video">
                    <source src="media/geef-film.mp4" type="video/mp4" />
                    Your browser does not support embedded video.
                </video>
                <button type="button" class="lp-film-play" data-testid="film-play"
                        aria-label="Play the film">
                    <span class="lp-film-play-disc" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
                            <path d="M8 5v14l11-7z" fill="currentColor" />
                        </svg>
                    </span>
                    <span class="lp-film-play-label">Watch the film · 60s</span>
                </button>
            </div>
        </div>
    </div>
</section>
