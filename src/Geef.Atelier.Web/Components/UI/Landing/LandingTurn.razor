<section class="lp-section lp-turn lp-reveal">
    <div class="lp-container">
        <p class="lp-eyebrow centered">The Turn</p>
        <h2 class="quote">
            Most AI tools answer in <em>one breath</em>.
            A good text is never written that way — it's drafted,
            challenged, and <em>rewritten</em>.
        </h2>

        <div class="drafts">
            <div class="draft-card bad">
                <div class="tag"><span>Draft 01</span><span>One pass</span></div>
                <div class="lines">
                    <i style="width: 92%"></i>
                    <i style="width: 78%"></i>
                    <i style="width: 85%"></i>
                    <i style="width: 62%"></i>
                    <i style="width: 88%"></i>
                    <i style="width: 70%"></i>
                    <i style="width: 54%"></i>
                </div>
                <div class="seal">— rejected</div>
            </div>

            <div class="draft-arrow">
                <div>
                    <div style="font-size: 28px; line-height: 1; color: var(--hero)">→</div>
                    <div style="margin-top: 6px">refined</div>
                </div>
            </div>

            <div class="draft-card good">
                <div class="tag"><span>Iteration 04</span><span style="color: var(--hero)">converged</span></div>
                <div class="lines">
                    <i style="width: 84%"></i>
                    <i style="width: 94%"></i>
                    <i style="width: 76%"></i>
                    <i style="width: 88%"></i>
                    <i style="width: 92%"></i>
                    <i style="width: 70%"></i>
                    <i style="width: 80%"></i>
                </div>
                <div class="seal">— sealed</div>
            </div>
        </div>
    </div>
</section>
