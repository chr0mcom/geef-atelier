@using Geef.Atelier.Core.Domain
@using Geef.Atelier.Web.Display
@inject IJSRuntime JS

<div class="iter @(_open ? "open" : "") @(IsLast ? "active" : "")">
    <div class="iter-head" @onclick="Toggle" role="button" tabindex="0" aria-expanded="@_open">
        <div class="num">i.<span class="label">Iteration</span> @Iteration.IterationNumber</div>
        <div class="summary">@Iteration.ArtifactText[..Math.Min(120, Iteration.ArtifactText.Length)]…</div>
        <div class="findings-count">
            @if (_critCount > 0) { <span class="pill crit">@_critCount crit</span> }
            @if (_majCount > 0)  { <span class="pill maj">@_majCount maj</span> }
            @if (_minCount > 0)  { <span class="pill min">@_minCount min</span> }
            @if (_infCount > 0)  { <span class="pill inf">@_infCount info</span> }
        </div>
        <span class="caret"><IconChevron Size="14" /></span>
    </div>
    <div class="iter-body">
        <div class="artifact">
            <div class="artifact-head">
                <span class="t-eyebrow eyebrow">Working draft</span>
                <button type="button" class="btn small ghost" @onclick="CopyArtifact" @onclick:stopPropagation="true">
                    <IconCopy Size="13" />
                    @(_copied ? "Copied" : "Copy Markdown")
                </button>
            </div>
            <MarkdownView Markdown="@Iteration.ArtifactText" Class="prose" />
        </div>
        <div class="findings">
            @foreach (var finding in Findings)
            {
                <FindingItem Finding="finding" Resolved="@(ResolvedMap?.GetValueOrDefault(finding.Id) ?? false)" />
            }
        </div>
    </div>
    @if (!IsLast)
    {
        var nonInfo = Findings.Count(f => f.Severity != FindingSeverity.Info);
        <div class="evolution">
            ↓ <strong>Carried into iteration @(Iteration.IterationNumber + 1):</strong>
            @nonInfo finding@(nonInfo != 1 ? "s" : "") requiring revision.
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public IterationEntity Iteration { get; set; } = null!;
    [Parameter, EditorRequired] public IReadOnlyList<FindingEntity> Findings { get; set; } = [];
    [Parameter] public bool IsLast { get; set; }
    [Parameter] public IReadOnlyDictionary<Guid, bool>? ResolvedMap { get; set; }

    bool _open;
    bool _copied;

    async Task CopyArtifact()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", Iteration.ArtifactText);
        _copied = true;
        await Task.Delay(1400);
        _copied = false;
        StateHasChanged();
    }

    int _critCount => Findings.Count(f => f.Severity == FindingSeverity.Critical);
    int _majCount  => Findings.Count(f => f.Severity == FindingSeverity.Major);
    int _minCount  => Findings.Count(f => f.Severity == FindingSeverity.Minor);
    int _infCount  => Findings.Count(f => f.Severity == FindingSeverity.Info);

    void Toggle() => _open = !_open;
}
