@* Collapsible block: shows the effective composed prompt per actor (role + packs + result). *@
@using Geef.Atelier.Core.Domain.Crew.Specialization

@if (Compositions is { Count: > 0 })
{
    <div class="actor-prompt-compositions" data-testid="prompt-compositions">
        <button class="collapsible-header" @onclick="Toggle" type="button" aria-expanded="@_expanded">
            <span>Effective prompts (@Compositions.Count actor@(Compositions.Count != 1 ? "s" : "") with packs)</span>
            <span class="chevron @(_expanded ? "up" : "down")">▾</span>
        </button>

        @if (_expanded)
        {
            <div class="collapsible-body">
                @foreach (var c in Compositions)
                {
                    <div class="prompt-composition" data-testid="prompt-composition-@c.ActorName">
                        <div class="prompt-composition-header">
                            <strong>@GetActorTypeLabel(c.ActorType): @c.ActorName</strong>
                            <span class="prompt-composition-packs">
                                @foreach (var p in c.Packs)
                                {
                                    <span class="crew-badge">@(p.Order + 1). @p.DisplayName (@GetScopeLabel(p.Scope))</span>
                                }
                            </span>
                        </div>
                        <details class="prompt-composition-details">
                            <summary>Show composed prompt</summary>
                            <pre class="prompt-composition-text">@c.ComposedPrompt</pre>
                        </details>
                        <details class="prompt-composition-details">
                            <summary>Role prompt (before composition)</summary>
                            <pre class="prompt-composition-text">@c.RolePrompt</pre>
                        </details>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public IReadOnlyList<ActorPromptComposition>? Compositions { get; set; }

    private bool _expanded;
    private void Toggle() => _expanded = !_expanded;

    private static string GetActorTypeLabel(string actorType) => actorType switch
    {
        "executor" => "Executor",
        "reviewer" => "Reviewer",
        "advisor"  => "Advisor",
        _          => actorType
    };

    private static string GetScopeLabel(PackScope s) => s switch
    {
        PackScope.General      => "General",
        PackScope.DomainScoped => "Domain",
        PackScope.TaskBound    => "Crew-bound",
        _                      => s.ToString()
    };
}
