@using Geef.Atelier.Application.Crew
@using Geef.Atelier.Core.Domain.Crew.Advisors
@using Geef.Atelier.Core.Domain.Crew.Finalizers
@using Geef.Atelier.Core.Domain.Crew.Profiles
@using Geef.Atelier.Core.Domain.Crew.TemplateStudio
@using Geef.Atelier.Web.Resources
@inject ICrewService CrewService
@inject IProviderCatalog ProviderCatalog

<div class="studio-slot @(ShowValidation && !IsValid ? "studio-slot--invalid" : "") @(_expanded ? "is-open" : "")"
     data-testid="@SlotTestId">

    <button type="button" class="studio-slot-header" @onclick="ToggleExpanded"
            aria-expanded="@_expanded" data-testid="@($"slot-header-{SlotTestSuffix}")">
        <span class="slot-chevron">@(_expanded ? "▾" : "▸")</span>
        <span class="studio-slot-label">@SlotLabel</span>
        <span class="slot-summary">@SummaryText</span>
        <span class="slot-mode-pill @(Mode == StudioSlotMode.UseExisting ? "is-existing" : "is-new")">
            @(Mode == StudioSlotMode.UseExisting ? "Existing" : "New")
        </span>
        @if (ShowValidation && !IsValid)
        {
            <span class="slot-invalid-dot" title="Incomplete" data-testid="@($"slot-invalid-{SlotTestSuffix}")">!</span>
        }
    </button>

    @if (_expanded)
    {
    <div class="studio-slot-body">
        @if (CanSwitchMode)
        {
            <div class="studio-slot-toggle" role="group" aria-label="Choose mode">
                <button type="button"
                        class="toggle-btn @(Mode == StudioSlotMode.UseExisting ? "active" : "")"
                        @onclick="() => SetMode(StudioSlotMode.UseExisting)"
                        data-testid="@($"slot-toggle-use-existing-{SlotTestSuffix}")">
                    Use existing
                </button>
                <button type="button"
                        class="toggle-btn @(Mode == StudioSlotMode.CreateNew ? "active" : "")"
                        @onclick="() => SetMode(StudioSlotMode.CreateNew)"
                        data-testid="@($"slot-toggle-create-new-{SlotTestSuffix}")">
                    Create new
                </button>
            </div>
        }

    @if (Mode == StudioSlotMode.UseExisting)
    {
        <div class="field">
            <label>Select profile</label>
            <select value="@ExistingProfileName"
                    @onchange="OnExistingProfileChange"
                    data-testid="@($"slot-existing-select-{SlotTestSuffix}")">
                <option value="">— please select —</option>
                @foreach (var p in _availableProfiles)
                {
                    <option value="@p.Name">@p.DisplayName @(p.IsSystem ? "(System)" : string.Empty)</option>
                }
            </select>
            @if (ShowValidation && string.IsNullOrEmpty(ExistingProfileName))
            {
                <span class="validation-error" data-testid="slot-validation-error">Please select a profile.</span>
            }
        </div>
    }
    else // CreateNew
    {
        @if (Draft is not null)
        {
            <div class="slot-fields">
            <div class="field">
                <label>Name (internal, kebab-case)</label>
                <input type="text"
                       value="@Draft.Name"
                       @oninput="OnNameInput"
                       data-testid="@($"slot-name-{SlotTestSuffix}")" />
                <FieldHelp Text="@StudioFieldHelps.ProfileName" DataTestId="field-help-profilename" />
                @if (ShowValidation && string.IsNullOrWhiteSpace(Draft.Name))
                {
                    <span class="validation-error">Name is required.</span>
                }
            </div>

            <div class="field">
                <label>Display name</label>
                <input type="text"
                       value="@Draft.DisplayName"
                       @oninput="OnDisplayNameInput"
                       data-testid="@($"slot-displayname-{SlotTestSuffix}")" />
                <FieldHelp Text="@StudioFieldHelps.ProfileDisplayName" DataTestId="field-help-profiledisplayname" />
                @if (ShowValidation && string.IsNullOrWhiteSpace(Draft.DisplayName))
                {
                    <span class="validation-error">Display name is required.</span>
                }
            </div>

            <div class="field field--full">
                <label>Description</label>
                <input type="text"
                       value="@Draft.Description"
                       @oninput="OnDescriptionInput"
                       data-testid="@($"slot-description-{SlotTestSuffix}")" />
                <FieldHelp Text="@StudioFieldHelps.ProfileDescription" DataTestId="field-help-profiledescription" />
            </div>

            @if (Draft.ProfileType != ProposedProfileType.Finalizer || Draft.FinalizerType == "Transform")
            {
                <div class="field">
                    <label>Provider</label>
                    <select value="@Draft.Provider"
                            @onchange="OnProviderChange"
                            data-testid="@($"slot-provider-{SlotTestSuffix}")">
                        <option value="">— please select —</option>
                        @foreach (var p in _providers)
                        {
                            <option value="@p.Name">@p.DisplayName</option>
                        }
                    </select>
                    <FieldHelp Text="@StudioFieldHelps.Provider" DataTestId="field-help-provider" />
                    @if (ShowValidation && string.IsNullOrEmpty(Draft.Provider))
                    {
                        <span class="validation-error">Provider is required.</span>
                    }
                </div>

                <div class="field">
                    <label>Model</label>
                    <ModelSelector Provider="@Draft.Provider"
                                   Value="@Draft.Model"
                                   ValueChanged="@(v => UpdateDraft(d => d with { Model = v }))"
                                   DataTestId="@($"slot-model-{SlotTestSuffix}")" />
                    <FieldHelp Text="@StudioFieldHelps.Model" DataTestId="field-help-model" />
                    @if (!string.IsNullOrEmpty(Draft.ModelReasoning))
                    {
                        <div class="field-reasoning" data-testid="slot-model-reasoning">💡 @Draft.ModelReasoning</div>
                    }
                </div>

                <div class="field">
                    <label>Max tokens</label>
                    <input type="number" min="256" max="32768"
                           value="@(Draft.MaxTokens?.ToString() ?? string.Empty)"
                           @oninput="OnMaxTokensInput"
                           data-testid="@($"slot-maxtokens-{SlotTestSuffix}")" />
                    <FieldHelp Text="@StudioFieldHelps.MaxTokens" DataTestId="field-help-maxtokens" />
                </div>

                <div class="field field--full">
                    <label>System prompt</label>
                    <textarea rows="5"
                              value="@Draft.SystemPrompt"
                              @oninput="OnSystemPromptInput"
                              data-testid="@($"slot-systemprompt-{SlotTestSuffix}")"
                              style="font-family: var(--font-mono, monospace)"></textarea>
                    <FieldHelp Text="@(Draft.ProfileType == ProposedProfileType.Finalizer ? StudioFieldHelps.FinalizerTransformSystemPrompt : StudioFieldHelps.SystemPrompt)"
                               DataTestId="field-help-systemprompt" />
                    @if (!string.IsNullOrEmpty(Draft.SystemPromptReasoning))
                    {
                        <div class="field-reasoning" data-testid="slot-systemprompt-reasoning">💡 @Draft.SystemPromptReasoning</div>
                    }
                    @if (ShowValidation && string.IsNullOrWhiteSpace(Draft.SystemPrompt))
                    {
                        <span class="validation-error">System prompt is required.</span>
                    }
                </div>
            }

            @if (Draft.ProfileType == ProposedProfileType.Reviewer)
            {
                <div class="field">
                    <label>Reviewer focus (optional)</label>
                    <input type="text"
                           value="@(Draft.ReviewerFocus ?? string.Empty)"
                           @oninput="OnReviewerFocusInput"
                           data-testid="slot-reviewerfocus" />
                    <FieldHelp Text="@StudioFieldHelps.ReviewerFocus" DataTestId="field-help-reviewerfocus" />
                </div>
            }

            @if (Draft.ProfileType == ProposedProfileType.Advisor)
            {
                <div class="field">
                    <label>Advisor mode</label>
                    <select value="@(Draft.AdvisorMode ?? "Strategic")"
                            @onchange="OnAdvisorModeChange"
                            data-testid="slot-advisormode">
                        @foreach (var mode in Enum.GetNames<AdvisorMode>())
                        {
                            <option value="@mode">@mode</option>
                        }
                    </select>
                    <FieldHelp Text="@StudioFieldHelps.AdvisorMode" DataTestId="field-help-advisormode" />
                    @if (!string.IsNullOrEmpty(Draft.ModeReasoning))
                    {
                        <div class="field-reasoning" data-testid="slot-mode-reasoning">💡 @Draft.ModeReasoning</div>
                    }
                </div>

                <div class="field">
                    <label>Advisor trigger</label>
                    <select value="@(Draft.AdvisorTrigger ?? "BeforeFirstExecution")"
                            @onchange="OnAdvisorTriggerChange"
                            data-testid="slot-advisortrigger">
                        @foreach (var trigger in Enum.GetNames<AdvisorTrigger>())
                        {
                            <option value="@trigger">@trigger</option>
                        }
                    </select>
                    <FieldHelp Text="@StudioFieldHelps.AdvisorTrigger" DataTestId="field-help-advisortrigger" />
                    @if (!string.IsNullOrEmpty(Draft.TriggerReasoning))
                    {
                        <div class="field-reasoning" data-testid="slot-trigger-reasoning">💡 @Draft.TriggerReasoning</div>
                    }
                </div>
            }

            @if (Draft.ProfileType == ProposedProfileType.GroundingProvider)
            {
                <div class="field">
                    <label>Grounding type</label>
                    <select value="@(Draft.GroundingProviderType ?? "tavily")"
                            @onchange="OnGroundingTypeChange"
                            data-testid="slot-groundingtype">
                        <option value="tavily">Tavily (web search)</option>
                        <option value="vector_store">VectorStore (your documents)</option>
                    </select>
                    <FieldHelp Text="@StudioFieldHelps.GroundingProviderType" DataTestId="field-help-groundingtype" />
                </div>

                <div class="field">
                    <label>Settings</label>
                    @if (Draft.GroundingProviderType == "vector_store")
                    {
                        <input type="text"
                               value="@GetCollectionName()"
                               @oninput="OnCollectionNameInput"
                               placeholder="Collection name"
                               data-testid="slot-grounding-collectionname" />
                    }
                    else
                    {
                        <input type="text"
                               value="@GetApiKey()"
                               @oninput="OnApiKeyInput"
                               placeholder="API key"
                               data-testid="slot-grounding-apikey" />
                    }
                    <FieldHelp Text="@StudioFieldHelps.GroundingProviderSettings" DataTestId="field-help-groundingsettings" />
                </div>
            }

            @if (Draft.ProfileType == ProposedProfileType.Finalizer)
            {
                <div class="field">
                    <label>Finalizer type</label>
                    <select value="@(Draft.FinalizerType ?? "FileExport")"
                            @onchange="OnFinalizerTypeChange"
                            data-testid="slot-finalizertype">
                        <option value="FileExport">FileExport – export a file</option>
                        <option value="MetadataEnrich">MetadataEnrich – enrich metadata</option>
                        <option value="ExternalSink">ExternalSink – webhook or email</option>
                        <option value="Transform">Transform – AI transformation</option>
                    </select>
                    <FieldHelp Text="@StudioFieldHelps.FinalizerType" DataTestId="field-help-finalizertype" />
                    @if (!string.IsNullOrEmpty(Draft.FinalizerReasoning))
                    {
                        <div class="field-reasoning" data-testid="slot-finalizer-reasoning">💡 @Draft.FinalizerReasoning</div>
                    }
                </div>

                @if (Draft.FinalizerType == "FileExport" || string.IsNullOrEmpty(Draft.FinalizerType))
                {
                    <div class="field">
                        <label>File format</label>
                        <select value="@GetFinalizerSetting("format", "markdown")"
                                @onchange="OnFinalizerFormatChange"
                                data-testid="slot-finalizer-format">
                            <option value="markdown">Markdown (.md)</option>
                            <option value="html">HTML (.html)</option>
                            <option value="pdf">PDF (.pdf)</option>
                            <option value="docx">Word document (.docx)</option>
                            <option value="txt">Plaintext (.txt)</option>
                        </select>
                        <FieldHelp Text="@StudioFieldHelps.FinalizerFileFormat" DataTestId="field-help-finalizerformat" />
                    </div>
                }

                @if (Draft.FinalizerType == "MetadataEnrich")
                {
                    <div class="field">
                        <label>Enrichment type</label>
                        <select value="@GetFinalizerSetting("enricher", "front-matter")"
                                @onchange="OnFinalizerEnricherChange"
                                data-testid="slot-finalizer-enricher">
                            <option value="front-matter">Front matter (YAML header)</option>
                            <option value="word-count-footer">Word-count footer</option>
                            <option value="reading-level">Reading level (Flesch-Kincaid)</option>
                        </select>
                        <FieldHelp Text="@StudioFieldHelps.FinalizerEnricherType" DataTestId="field-help-finalizerenricher" />
                    </div>
                }

                @if (Draft.FinalizerType == "ExternalSink")
                {
                    <div class="field">
                        <label>Channel</label>
                        <select value="@GetFinalizerSetting("sink", "webhook")"
                                @onchange="OnFinalizerSinkChange"
                                data-testid="slot-finalizer-sink">
                            <option value="webhook">Webhook (HTTP POST)</option>
                            <option value="email">Email (SMTP)</option>
                        </select>
                        <FieldHelp Text="@StudioFieldHelps.FinalizerSinkType" DataTestId="field-help-finalizersink" />
                    </div>
                    @if (GetFinalizerSetting("sink", "webhook") == "webhook")
                    {
                        <div class="field">
                            <label>Webhook-URL</label>
                            <input type="text"
                                   value="@GetFinalizerSetting("url", string.Empty)"
                                   @oninput="OnFinalizerUrlInput"
                                   placeholder="https://..."
                                   data-testid="slot-finalizer-webhookurl" />
                            <FieldHelp Text="@StudioFieldHelps.FinalizerWebhookUrl" DataTestId="field-help-finalizerwebhookurl" />
                        </div>
                        <div class="field">
                            <label>Auth header (optional)</label>
                            <input type="password"
                                   value="@GetFinalizerSetting("auth_header", string.Empty)"
                                   @oninput="OnFinalizerAuthHeaderInput"
                                   placeholder="Bearer …"
                                   data-testid="slot-finalizer-authheader" />
                            <FieldHelp Text="@StudioFieldHelps.FinalizerWebhookAuthHeader" DataTestId="field-help-finalizerauth" />
                        </div>
                    }
                    else
                    {
                        <div class="field">
                            <label>Recipient</label>
                            <input type="email"
                                   value="@GetFinalizerSetting("to", string.Empty)"
                                   @oninput="OnFinalizerEmailToInput"
                                   placeholder="recipient@example.com"
                                   data-testid="slot-finalizer-emailto" />
                            <FieldHelp Text="@StudioFieldHelps.FinalizerEmailTo" DataTestId="field-help-finalizeremailtto" />
                        </div>
                        <div class="field">
                            <label>Subject</label>
                            <input type="text"
                                   value="@GetFinalizerSetting("subject", string.Empty)"
                                   @oninput="OnFinalizerSubjectInput"
                                   placeholder="Result of {template}"
                                   data-testid="slot-finalizer-emailsubject" />
                            <FieldHelp Text="@StudioFieldHelps.FinalizerEmailSubject" DataTestId="field-help-finalizersubject" />
                        </div>
                    }
                }
            }

            @if (!string.IsNullOrEmpty(Draft.OverallReasoning))
            {
                <div class="field-reasoning overall-reasoning field--full" data-testid="slot-overall-reasoning">
                    <strong>AI rationale:</strong> @Draft.OverallReasoning
                </div>
            }
            </div>
        }
    }
    </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public ProposedProfileType ProfileType { get; set; }
    [Parameter, EditorRequired] public string SlotLabel { get; set; } = "";
    [Parameter] public bool CanSwitchMode { get; set; } = true;
    /// <summary>Pre-loaded profile options from the parent. When set, skips the per-slot DB query.</summary>
    [Parameter] public IReadOnlyList<StudioProfileOption>? PreloadedProfiles { get; set; }
    [Parameter] public StudioSlotMode Mode { get; set; } = StudioSlotMode.CreateNew;
    [Parameter] public EventCallback<StudioSlotMode> ModeChanged { get; set; }
    [Parameter] public string? ExistingProfileName { get; set; }
    [Parameter] public EventCallback<string?> ExistingProfileNameChanged { get; set; }
    [Parameter] public ProposedProfile? Draft { get; set; }
    [Parameter] public EventCallback<ProposedProfile?> DraftChanged { get; set; }
    [Parameter] public bool ShowValidation { get; set; }

    private sealed record ProfileSummary(string Name, string DisplayName, bool IsSystem);

    private IReadOnlyList<ProviderInfo> _providers = [];
    private IReadOnlyList<ProfileSummary> _availableProfiles = [];
    private bool _expanded;
    private bool _expandInitialized;

    private string SlotTestSuffix => SlotLabel.ToLowerInvariant().Replace(' ', '-');
    private string SlotTestId => $"studio-slot-{SlotTestSuffix}";

    /// <summary>Compact one-line summary shown in the collapsed header.</summary>
    private string SummaryText
    {
        get
        {
            if (Mode == StudioSlotMode.UseExisting)
            {
                if (string.IsNullOrEmpty(ExistingProfileName)) return "— no profile selected —";
                var match = _availableProfiles.FirstOrDefault(p => p.Name == ExistingProfileName);
                return match?.DisplayName ?? ExistingProfileName;
            }
            if (Draft is null) return "New profile";
            if (!string.IsNullOrWhiteSpace(Draft.DisplayName)) return Draft.DisplayName;
            if (!string.IsNullOrWhiteSpace(Draft.Name)) return Draft.Name;
            return "New profile (unnamed)";
        }
    }

    private void ToggleExpanded() => _expanded = !_expanded;

    public bool IsValid
    {
        get
        {
            if (Mode == StudioSlotMode.UseExisting)
                return !string.IsNullOrEmpty(ExistingProfileName);
            if (Draft is null) return false;
            if (string.IsNullOrWhiteSpace(Draft.Name) || string.IsNullOrWhiteSpace(Draft.DisplayName))
                return false;
            if (Draft.ProfileType == ProposedProfileType.Finalizer)
            {
                return Draft.FinalizerType != "Transform" ||
                       (!string.IsNullOrEmpty(Draft.Provider) && !string.IsNullOrWhiteSpace(Draft.SystemPrompt));
            }
            return !string.IsNullOrEmpty(Draft.Provider) && !string.IsNullOrWhiteSpace(Draft.SystemPrompt);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _providers = ProviderCatalog.ListProviders();
        if (PreloadedProfiles is not null)
            _availableProfiles = PreloadedProfiles.Select(p => new ProfileSummary(p.Name, p.DisplayName, p.IsSystem)).ToList();
        else
            await LoadAvailableProfilesAsync();

        // Start expanded only for freshly-added (empty) drafts that need input; otherwise collapsed
        // so the parent renders a clean, scannable overview of all slots.
        _expanded = Mode == StudioSlotMode.CreateNew && string.IsNullOrWhiteSpace(Draft?.Name);
        _expandInitialized = true;
    }

    protected override void OnParametersSet()
    {
        // Auto-expand invalid slots when the user attempts to save, so the error is visible.
        if (_expandInitialized && ShowValidation && !IsValid)
            _expanded = true;
    }

    private async Task LoadAvailableProfilesAsync()
    {
        _availableProfiles = ProfileType switch
        {
            ProposedProfileType.Reviewer =>
                (await CrewService.ListReviewerProfilesAsync(includeSystem: true))
                    .Select(p => new ProfileSummary(p.Name, p.DisplayName, p.IsSystem)).ToList(),
            ProposedProfileType.Advisor =>
                (await CrewService.ListAdvisorProfilesAsync(includeSystem: true))
                    .Select(p => new ProfileSummary(p.Name, p.DisplayName, p.IsSystem)).ToList(),
            ProposedProfileType.GroundingProvider =>
                (await CrewService.ListGroundingProviderProfilesAsync(includeSystem: true))
                    .Select(p => new ProfileSummary(p.Name, p.DisplayName, p.IsSystem)).ToList(),
            ProposedProfileType.Executor =>
                (await CrewService.ListExecutorProfilesAsync(includeSystem: true))
                    .Select(p => new ProfileSummary(p.Name, p.DisplayName, p.IsSystem)).ToList(),
            ProposedProfileType.Finalizer =>
                (await CrewService.ListFinalizerProfilesAsync(includeSystem: true))
                    .Select(p => new ProfileSummary(p.Name, p.DisplayName, p.IsSystem)).ToList(),
            _ => []
        };
    }

    private async Task SetMode(StudioSlotMode mode)
    {
        Mode = mode;
        await ModeChanged.InvokeAsync(mode);
    }

    private async Task OnExistingProfileChange(ChangeEventArgs e)
    {
        var name = e.Value?.ToString();
        await ExistingProfileNameChanged.InvokeAsync(string.IsNullOrEmpty(name) ? null : name);
    }

    private async Task UpdateDraft(Func<ProposedProfile, ProposedProfile> update)
    {
        if (Draft is not null)
            await DraftChanged.InvokeAsync(update(Draft));
    }

    private Task OnNameInput(ChangeEventArgs e)
        => UpdateDraft(d => d with { Name = e.Value?.ToString() ?? string.Empty });

    private Task OnDisplayNameInput(ChangeEventArgs e)
        => UpdateDraft(d => d with { DisplayName = e.Value?.ToString() ?? string.Empty });

    private Task OnDescriptionInput(ChangeEventArgs e)
        => UpdateDraft(d => d with { Description = e.Value?.ToString() ?? string.Empty });

    private Task OnSystemPromptInput(ChangeEventArgs e)
        => UpdateDraft(d => d with { SystemPrompt = e.Value?.ToString() ?? string.Empty });

    private Task OnReviewerFocusInput(ChangeEventArgs e)
        => UpdateDraft(d => d with { ReviewerFocus = e.Value?.ToString() });

    private async Task OnProviderChange(ChangeEventArgs e)
    {
        var provider = e.Value?.ToString() ?? string.Empty;
        await UpdateDraft(d => d with { Provider = provider, Model = string.Empty });
    }

    private Task OnAdvisorModeChange(ChangeEventArgs e)
        => UpdateDraft(d => d with { AdvisorMode = e.Value?.ToString() });

    private Task OnAdvisorTriggerChange(ChangeEventArgs e)
        => UpdateDraft(d => d with { AdvisorTrigger = e.Value?.ToString() });

    private Task OnGroundingTypeChange(ChangeEventArgs e)
        => UpdateDraft(d => d with { GroundingProviderType = e.Value?.ToString() });

    private Task OnFinalizerTypeChange(ChangeEventArgs e)
        => UpdateDraft(d => d with { FinalizerType = e.Value?.ToString() });

    private Task OnFinalizerFormatChange(ChangeEventArgs e)
        => SetFinalizerSetting("format", e.Value?.ToString() ?? "markdown");

    private Task OnFinalizerEnricherChange(ChangeEventArgs e)
        => SetFinalizerSetting("enricher", e.Value?.ToString() ?? "front-matter");

    private Task OnFinalizerSinkChange(ChangeEventArgs e)
        => SetFinalizerSetting("sink", e.Value?.ToString() ?? "webhook");

    private Task OnFinalizerUrlInput(ChangeEventArgs e)
        => SetFinalizerSetting("url", e.Value?.ToString() ?? string.Empty);

    private Task OnFinalizerAuthHeaderInput(ChangeEventArgs e)
        => SetFinalizerSetting("auth_header", e.Value?.ToString() ?? string.Empty);

    private Task OnFinalizerEmailToInput(ChangeEventArgs e)
        => SetFinalizerSetting("to", e.Value?.ToString() ?? string.Empty);

    private Task OnFinalizerSubjectInput(ChangeEventArgs e)
        => SetFinalizerSetting("subject", e.Value?.ToString() ?? string.Empty);

    private async Task OnMaxTokensInput(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        var parsed = int.TryParse(raw, out var val) ? (int?)val : null;
        await UpdateDraft(d => d with { MaxTokens = parsed });
    }

    private string GetSetting(string key)
        => Draft?.GroundingProviderSettings?.TryGetValue(key, out var v) == true ? v : string.Empty;

    private string GetCollectionName() => GetSetting("collection_name");
    private string GetApiKey() => GetSetting("api_key");

    private Task OnCollectionNameInput(ChangeEventArgs e)
        => SetSetting("collection_name", e.Value?.ToString() ?? string.Empty);

    private Task OnApiKeyInput(ChangeEventArgs e)
        => SetSetting("api_key", e.Value?.ToString() ?? string.Empty);

    private async Task SetSetting(string key, string value)
    {
        await UpdateDraft(d =>
        {
            var settings = d.GroundingProviderSettings is not null
                ? new Dictionary<string, string>(d.GroundingProviderSettings)
                : new Dictionary<string, string>();
            settings[key] = value;
            return d with { GroundingProviderSettings = settings };
        });
    }

    private string GetFinalizerSetting(string key, string defaultValue)
        => Draft?.FinalizerSettings?.TryGetValue(key, out var v) == true ? v : defaultValue;

    private Task SetFinalizerSetting(string key, string value)
        => UpdateDraft(d =>
        {
            var settings = d.FinalizerSettings is not null
                ? new Dictionary<string, string>(d.FinalizerSettings)
                : new Dictionary<string, string>();
            settings[key] = value;
            return d with { FinalizerSettings = settings };
        });
}
