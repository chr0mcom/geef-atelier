@using Geef.Atelier.Application.Crew
@using Geef.Atelier.Application.Crew.TemplateStudio
@using Geef.Atelier.Core.Domain.Crew.TemplateStudio
@using Geef.Atelier.Web.Resources
@using Microsoft.Extensions.Options
@using Geef.Atelier.Core.Domain.Crew.Finalizers
@inject ICrewService CrewService
@inject IOptions<TemplateStudioOptions> Options

<div class="studio-edit" data-testid="studio-edit-step">
    <h2>Edit configuration</h2>
    <p class="edit-hint">Review the AI recommendation and adjust the fields as needed.</p>

    @if (_template is not null)
    {
        <div class="edit-section">
            <h3>Template</h3>

            <div class="field">
                <label>Display name</label>
                <input type="text"
                       value="@_template.DisplayName"
                       @oninput="OnDisplayNameInput"
                       data-testid="template-display-name" />
                <FieldHelp Text="@StudioFieldHelps.DisplayName" DataTestId="field-help-displayname" />
            </div>

            <div class="field">
                <label>Description</label>
                <textarea rows="2"
                          value="@_template.Description"
                          @oninput="OnDescriptionInput"
                          data-testid="template-description"></textarea>
                <FieldHelp Text="@StudioFieldHelps.Description" DataTestId="field-help-description" />
            </div>

            <div class="field">
                <label>Evaluation strategy</label>
                <select value="@_template.EvaluationStrategy"
                        @onchange="OnStrategyChange"
                        data-testid="template-strategy">
                    <option value="Sequential">Sequential – reviewers one after another</option>
                    <option value="Parallel">Parallel – all at once</option>
                    <option value="FailFast">FailFast – stop at the first finding</option>
                    <option value="Priority">Priority – weighted by priority</option>
                </select>
                <FieldHelp Text="@StudioFieldHelps.EvaluationStrategy" DataTestId="field-help-strategy" />
                @if (!string.IsNullOrEmpty(_template.EvaluationStrategyReasoning))
                {
                    <div class="field-reasoning" data-testid="template-strategy-reasoning">
                        💡 @_template.EvaluationStrategyReasoning
                    </div>
                }
            </div>

            @if (_finalizerSlots.Count > 0)
            {
                <div class="field checkbox-field">
                    <label>
                        <input type="checkbox"
                               checked="@_template.RunFinalizersOnMaxAttempts"
                               @onchange="OnRunFinalizersOnMaxAttemptsChange"
                               data-testid="run-finalizers-on-max-attempts" />
                        Run finalizers even at max iterations
                    </label>
                    <FieldHelp Text="@StudioFieldHelps.RunFinalizersOnMaxAttempts" DataTestId="field-help-run-finalizers-on-max" />
                </div>
            }
        </div>

        <div class="edit-section">
            <h3>Executor</h3>
            @if (_executorSlot is not null)
            {
                <StudioProfileSlot ProfileType="ProposedProfileType.Executor"
                                   SlotLabel="Executor"
                                   CanSwitchMode="true"
                                   Mode="@_executorSlot.Mode"
                                   ModeChanged="@(m => { _executorSlot.Mode = m; StateHasChanged(); })"
                                   ExistingProfileName="@_executorSlot.ExistingProfileName"
                                   ExistingProfileNameChanged="@(n => { _executorSlot.ExistingProfileName = n; StateHasChanged(); })"
                                   Draft="@_executorSlot.Draft"
                                   DraftChanged="@(d => { _executorSlot.Draft = d; StateHasChanged(); })"
                                   ShowValidation="@_showValidation"
                                   PreloadedProfiles="@_executorOptions" />
            }
        </div>

        <div class="edit-section">
            <h3>Reviewer</h3>
            @for (var i = 0; i < _reviewerSlots.Count; i++)
            {
                var slot = _reviewerSlots[i];
                var index = i;
                <div class="slot-row" data-testid="@($"reviewer-slot-row-{index}")">
                    <StudioProfileSlot ProfileType="ProposedProfileType.Reviewer"
                                       SlotLabel="@($"Reviewer {index + 1}")"
                                       CanSwitchMode="true"
                                       Mode="@slot.Mode"
                                       ModeChanged="@(m => { slot.Mode = m; StateHasChanged(); })"
                                       ExistingProfileName="@slot.ExistingProfileName"
                                       ExistingProfileNameChanged="@(n => { slot.ExistingProfileName = n; StateHasChanged(); })"
                                       Draft="@slot.Draft"
                                       DraftChanged="@(d => { slot.Draft = d; StateHasChanged(); })"
                                       ShowValidation="@_showValidation"
                                       PreloadedProfiles="@_reviewerOptions" />
                    <div class="slot-actions">
                        <button type="button" class="btn ghost btn-sm"
                                disabled="@(index == 0)"
                                @onclick="() => MoveReviewer(index, -1)"
                                data-testid="@($"reviewer-up-{index}")">▲</button>
                        <button type="button" class="btn ghost btn-sm"
                                disabled="@(index == _reviewerSlots.Count - 1)"
                                @onclick="() => MoveReviewer(index, 1)"
                                data-testid="@($"reviewer-down-{index}")">▼</button>
                        <button type="button" class="btn ghost btn-sm danger"
                                @onclick="() => RemoveReviewer(index)"
                                data-testid="@($"reviewer-remove-{index}")">Remove</button>
                    </div>
                </div>
            }
            <div class="slot-add-actions">
                <button type="button" class="btn ghost btn-sm"
                        @onclick="AddReviewerSlot"
                        data-testid="add-reviewer-btn">+ Add reviewer</button>
            </div>
            @if (_showValidation && _reviewerSlots.Count == 0)
            {
                <span class="validation-error" data-testid="reviewer-empty-error">At least one reviewer is required.</span>
            }
        </div>

        <div class="edit-section">
            <h3>Advisor <span class="optional-label">(optional)</span></h3>
            @for (var i = 0; i < _advisorSlots.Count; i++)
            {
                var slot = _advisorSlots[i];
                var index = i;
                <div class="slot-row" data-testid="@($"advisor-slot-row-{index}")">
                    <StudioProfileSlot ProfileType="ProposedProfileType.Advisor"
                                       SlotLabel="@($"Advisor {index + 1}")"
                                       CanSwitchMode="true"
                                       Mode="@slot.Mode"
                                       ModeChanged="@(m => { slot.Mode = m; StateHasChanged(); })"
                                       ExistingProfileName="@slot.ExistingProfileName"
                                       ExistingProfileNameChanged="@(n => { slot.ExistingProfileName = n; StateHasChanged(); })"
                                       Draft="@slot.Draft"
                                       DraftChanged="@(d => { slot.Draft = d; StateHasChanged(); })"
                                       ShowValidation="@_showValidation"
                                       PreloadedProfiles="@_advisorOptions" />
                    <div class="slot-actions">
                        <button type="button" class="btn ghost btn-sm danger"
                                @onclick="() => RemoveAdvisor(index)"
                                data-testid="@($"advisor-remove-{index}")">Remove</button>
                    </div>
                </div>
            }
            <div class="slot-add-actions">
                <button type="button" class="btn ghost btn-sm"
                        @onclick="AddAdvisorSlot"
                        data-testid="add-advisor-btn">+ Add advisor</button>
            </div>
        </div>

        <div class="edit-section">
            <h3>Grounding provider <span class="optional-label">(optional)</span></h3>
            @for (var i = 0; i < _groundingSlots.Count; i++)
            {
                var slot = _groundingSlots[i];
                var index = i;
                <div class="slot-row" data-testid="@($"grounding-slot-row-{index}")">
                    <StudioProfileSlot ProfileType="ProposedProfileType.GroundingProvider"
                                       SlotLabel="@($"Grounding {index + 1}")"
                                       CanSwitchMode="true"
                                       Mode="@slot.Mode"
                                       ModeChanged="@(m => { slot.Mode = m; StateHasChanged(); })"
                                       ExistingProfileName="@slot.ExistingProfileName"
                                       ExistingProfileNameChanged="@(n => { slot.ExistingProfileName = n; StateHasChanged(); })"
                                       Draft="@slot.Draft"
                                       DraftChanged="@(d => { slot.Draft = d; StateHasChanged(); })"
                                       ShowValidation="@_showValidation"
                                       PreloadedProfiles="@_groundingOptions" />
                    <div class="slot-actions">
                        <button type="button" class="btn ghost btn-sm danger"
                                @onclick="() => RemoveGrounding(index)"
                                data-testid="@($"grounding-remove-{index}")">Remove</button>
                    </div>
                </div>
            }
            <div class="slot-add-actions">
                <button type="button" class="btn ghost btn-sm"
                        @onclick="AddGroundingSlot"
                        data-testid="add-grounding-btn">+ Add grounding provider</button>
            </div>
        </div>

        <div class="edit-section">
            <h3>Finalizer <span class="optional-label">(optional)</span></h3>
            <FieldHelp Text="@StudioFieldHelps.FinalizerProfiles" DataTestId="field-help-finalizer-profiles" />
            @for (var i = 0; i < _finalizerSlots.Count; i++)
            {
                var slot = _finalizerSlots[i];
                var index = i;
                <div class="slot-row" data-testid="@($"finalizer-slot-row-{index}")">
                    <StudioProfileSlot ProfileType="ProposedProfileType.Finalizer"
                                       SlotLabel="@($"Finalizer {index + 1}")"
                                       CanSwitchMode="true"
                                       Mode="@slot.Mode"
                                       ModeChanged="@(m => { slot.Mode = m; StateHasChanged(); })"
                                       ExistingProfileName="@slot.ExistingProfileName"
                                       ExistingProfileNameChanged="@(n => { slot.ExistingProfileName = n; StateHasChanged(); })"
                                       Draft="@slot.Draft"
                                       DraftChanged="@(d => { slot.Draft = d; StateHasChanged(); })"
                                       ShowValidation="@_showValidation"
                                       PreloadedProfiles="@_finalizerOptions" />
                    <div class="slot-actions">
                        <button type="button" class="btn ghost btn-sm"
                                disabled="@(index == 0)"
                                @onclick="() => MoveFinalizer(index, -1)"
                                data-testid="@($"finalizer-up-{index}")">▲</button>
                        <button type="button" class="btn ghost btn-sm"
                                disabled="@(index == _finalizerSlots.Count - 1)"
                                @onclick="() => MoveFinalizer(index, 1)"
                                data-testid="@($"finalizer-down-{index}")">▼</button>
                        <button type="button" class="btn ghost btn-sm danger"
                                @onclick="() => RemoveFinalizer(index)"
                                data-testid="@($"finalizer-remove-{index}")">Remove</button>
                    </div>
                </div>
            }
            <div class="slot-add-actions">
                <button type="button" class="btn ghost btn-sm"
                        @onclick="AddFinalizerSlot"
                        data-testid="add-finalizer-btn">+ Add finalizer</button>
            </div>
        </div>

        @if (_showValidation && !AreAllSlotsValid())
        {
            <div class="validation-panel" role="alert" data-testid="validation-panel">
                Please fill in all required fields before saving.
            </div>
        }

        <div class="edit-actions">
            <button type="button" class="btn primary"
                    disabled="@(_materializing)"
                    @onclick="OnSaveClick"
                    data-testid="save-button">
                @if (_materializing)
                {
                    <span>Saving…</span>
                }
                else
                {
                    <span>Save and materialize</span>
                }
            </button>
            <button type="button" class="btn ghost"
                    disabled="@_materializing"
                    @onclick="OnBack"
                    data-testid="back-button">
                ← Back
            </button>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public TemplateStudioAnalysis Analysis { get; set; } = null!;
    [Parameter] public EventCallback<MaterializationRequest> OnSave { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    private sealed class SlotState(
        StudioSlotMode mode,
        string? existingProfileName,
        ProposedProfile? draft)
    {
        public StudioSlotMode Mode { get; set; } = mode;
        public string? ExistingProfileName { get; set; } = existingProfileName;
        public ProposedProfile? Draft { get; set; } = draft;
    }

    private ProposedTemplate? _template;
    private SlotState? _executorSlot;
    private List<SlotState> _reviewerSlots = [];
    private List<SlotState> _advisorSlots = [];
    private List<SlotState> _groundingSlots = [];
    private List<SlotState> _finalizerSlots = [];
    private bool _showValidation;
    private bool _materializing;

    private IReadOnlyList<StudioProfileOption> _executorOptions = [];
    private IReadOnlyList<StudioProfileOption> _reviewerOptions = [];
    private IReadOnlyList<StudioProfileOption> _advisorOptions = [];
    private IReadOnlyList<StudioProfileOption> _groundingOptions = [];
    private IReadOnlyList<StudioProfileOption> _finalizerOptions = [];

    protected override async Task OnInitializedAsync()
    {
        // Load all profile lists sequentially to avoid concurrent DbContext operations.
        _reviewerOptions = (await CrewService.ListReviewerProfilesAsync(includeSystem: true))
            .Select(p => new StudioProfileOption(p.Name, p.DisplayName, p.IsSystem)).ToList();
        _advisorOptions = (await CrewService.ListAdvisorProfilesAsync(includeSystem: true))
            .Select(p => new StudioProfileOption(p.Name, p.DisplayName, p.IsSystem)).ToList();
        _executorOptions = (await CrewService.ListExecutorProfilesAsync(includeSystem: true))
            .Select(p => new StudioProfileOption(p.Name, p.DisplayName, p.IsSystem)).ToList();
        _groundingOptions = (await CrewService.ListGroundingProviderProfilesAsync(includeSystem: true))
            .Select(p => new StudioProfileOption(p.Name, p.DisplayName, p.IsSystem)).ToList();
        _finalizerOptions = (await CrewService.ListFinalizerProfilesAsync(includeSystem: true))
            .Select(p => new StudioProfileOption(p.Name, p.DisplayName, p.IsSystem)).ToList();
    }

    protected override void OnParametersSet()
    {
        if (_template is null)
            InitializeFromAnalysis();
    }

    private void InitializeFromAnalysis()
    {
        var proposed = Analysis.ProposedTemplate;
        if (proposed is null) return;

        _template = proposed;
        var newProfiles = Analysis.ProposedNewProfiles;

        _executorSlot = BuildSlot(proposed.ExecutorProfileName, ProposedProfileType.Executor, newProfiles);

        _reviewerSlots = proposed.ReviewerProfileNames
            .Select(name => BuildSlot(name, ProposedProfileType.Reviewer, newProfiles))
            .ToList();

        _advisorSlots = proposed.AdvisorProfileNames
            .Select(name => BuildSlot(name, ProposedProfileType.Advisor, newProfiles))
            .ToList();

        _groundingSlots = proposed.GroundingProviderProfileNames
            .Select(name => BuildSlot(name, ProposedProfileType.GroundingProvider, newProfiles))
            .ToList();

        _finalizerSlots = (proposed.FinalizerProfileNames ?? [])
            .Select(name => BuildSlot(name, ProposedProfileType.Finalizer, newProfiles))
            .ToList();
    }

    private static SlotState BuildSlot(string profileName, ProposedProfileType type, IReadOnlyList<ProposedProfile> newProfiles)
    {
        var draft = newProfiles.FirstOrDefault(p => p.Name == profileName && p.ProfileType == type);
        return draft is not null
            ? new SlotState(StudioSlotMode.CreateNew, null, draft)
            : new SlotState(StudioSlotMode.UseExisting, profileName, null);
    }

    private void AddReviewerSlot()
    {
        var d = Options.Value.Defaults;
        var draft = new ProposedProfile(
            ProfileType: ProposedProfileType.Reviewer,
            Name: string.Empty, DisplayName: string.Empty, Description: string.Empty,
            Model: d.ReviewerModel, Provider: d.ReviewerProvider, SystemPrompt: string.Empty,
            MaxTokens: d.ReviewerMaxTokens,
            ReviewerFocus: null, AdvisorMode: null, AdvisorTrigger: null,
            GroundingProviderType: null, GroundingProviderSettings: null);
        _reviewerSlots.Add(new SlotState(StudioSlotMode.CreateNew, null, draft));
    }

    private void AddAdvisorSlot()
    {
        var d = Options.Value.Defaults;
        var draft = new ProposedProfile(
            ProfileType: ProposedProfileType.Advisor,
            Name: string.Empty, DisplayName: string.Empty, Description: string.Empty,
            Model: d.AdvisorModel, Provider: d.AdvisorProvider, SystemPrompt: string.Empty,
            MaxTokens: d.AdvisorMaxTokens,
            ReviewerFocus: null, AdvisorMode: d.AdvisorMode, AdvisorTrigger: d.AdvisorTrigger,
            GroundingProviderType: null, GroundingProviderSettings: null);
        _advisorSlots.Add(new SlotState(StudioSlotMode.CreateNew, null, draft));
    }

    private void AddGroundingSlot()
    {
        var d = Options.Value.Defaults;
        var draft = new ProposedProfile(
            ProfileType: ProposedProfileType.GroundingProvider,
            Name: string.Empty, DisplayName: string.Empty, Description: string.Empty,
            Model: string.Empty, Provider: d.GroundingProviderProvider, SystemPrompt: string.Empty,
            MaxTokens: null,
            ReviewerFocus: null, AdvisorMode: null, AdvisorTrigger: null,
            GroundingProviderType: d.GroundingProviderType, GroundingProviderSettings: null);
        _groundingSlots.Add(new SlotState(StudioSlotMode.CreateNew, null, draft));
    }

    private void AddFinalizerSlot()
    {
        var draft = new ProposedProfile(
            ProfileType: ProposedProfileType.Finalizer,
            Name: string.Empty, DisplayName: string.Empty, Description: string.Empty,
            Model: string.Empty, Provider: string.Empty, SystemPrompt: string.Empty,
            MaxTokens: null,
            ReviewerFocus: null, AdvisorMode: null, AdvisorTrigger: null,
            GroundingProviderType: null, GroundingProviderSettings: null,
            FinalizerType: "FileExport", FinalizerSettings: new Dictionary<string, string> { ["format"] = "markdown" });
        _finalizerSlots.Add(new SlotState(StudioSlotMode.CreateNew, null, draft));
    }

    private void MoveReviewer(int index, int direction)
    {
        var target = index + direction;
        if (target < 0 || target >= _reviewerSlots.Count) return;
        (_reviewerSlots[index], _reviewerSlots[target]) = (_reviewerSlots[target], _reviewerSlots[index]);
    }

    private void MoveFinalizer(int index, int direction)
    {
        var target = index + direction;
        if (target < 0 || target >= _finalizerSlots.Count) return;
        (_finalizerSlots[index], _finalizerSlots[target]) = (_finalizerSlots[target], _finalizerSlots[index]);
    }

    private void RemoveReviewer(int index) => _reviewerSlots.RemoveAt(index);
    private void RemoveAdvisor(int index) => _advisorSlots.RemoveAt(index);
    private void RemoveGrounding(int index) => _groundingSlots.RemoveAt(index);
    private void RemoveFinalizer(int index) => _finalizerSlots.RemoveAt(index);

    private async Task OnDisplayNameInput(ChangeEventArgs e)
        => _template = _template! with { DisplayName = e.Value?.ToString() ?? string.Empty };

    private async Task OnDescriptionInput(ChangeEventArgs e)
        => _template = _template! with { Description = e.Value?.ToString() ?? string.Empty };

    private async Task OnStrategyChange(ChangeEventArgs e)
        => _template = _template! with { EvaluationStrategy = e.Value?.ToString() ?? "Sequential" };

    private void OnRunFinalizersOnMaxAttemptsChange(ChangeEventArgs e)
        => _template = _template! with { RunFinalizersOnMaxAttempts = e.Value is true };

    private bool AreAllSlotsValid()
    {
        if (_reviewerSlots.Count == 0) return false;
        if (_executorSlot is not null && !IsSlotValid(_executorSlot)) return false;
        if (_reviewerSlots.Any(s => !IsSlotValid(s))) return false;
        if (_advisorSlots.Any(s => !IsSlotValid(s))) return false;
        if (_groundingSlots.Any(s => !IsSlotValid(s))) return false;
        if (_finalizerSlots.Any(s => !IsFinalizerSlotValid(s))) return false;
        return true;
    }

    private static bool IsSlotValid(SlotState slot) => slot.Mode == StudioSlotMode.UseExisting
        ? !string.IsNullOrEmpty(slot.ExistingProfileName)
        : slot.Draft is not null &&
          !string.IsNullOrWhiteSpace(slot.Draft.Name) &&
          !string.IsNullOrWhiteSpace(slot.Draft.DisplayName) &&
          !string.IsNullOrEmpty(slot.Draft.Provider) &&
          !string.IsNullOrWhiteSpace(slot.Draft.SystemPrompt);

    // Finalizer validation: Name + DisplayName required; Transform also needs Provider+SystemPrompt.
    private static bool IsFinalizerSlotValid(SlotState slot)
    {
        if (slot.Mode == StudioSlotMode.UseExisting)
            return !string.IsNullOrEmpty(slot.ExistingProfileName);
        if (slot.Draft is null) return false;
        if (string.IsNullOrWhiteSpace(slot.Draft.Name) || string.IsNullOrWhiteSpace(slot.Draft.DisplayName))
            return false;
        if (slot.Draft.FinalizerType == "Transform")
            return !string.IsNullOrEmpty(slot.Draft.Provider) && !string.IsNullOrWhiteSpace(slot.Draft.SystemPrompt);
        return true;
    }

    private async Task OnSaveClick()
    {
        _showValidation = true;
        if (!AreAllSlotsValid()) return;

        _materializing = true;
        try
        {
            await OnSave.InvokeAsync(BuildRequest());
        }
        finally
        {
            _materializing = false;
        }
    }

    private MaterializationRequest BuildRequest()
    {
        static string ResolveName(SlotState s) =>
            s.Mode == StudioSlotMode.UseExisting ? s.ExistingProfileName! : s.Draft!.Name;

        var executorName = _executorSlot is not null ? ResolveName(_executorSlot) : string.Empty;
        var reviewerNames = _reviewerSlots.Select(ResolveName).ToList();
        var advisorNames = _advisorSlots.Select(ResolveName).ToList();
        var groundingNames = _groundingSlots.Select(ResolveName).ToList();
        var finalizerNames = _finalizerSlots.Select(ResolveName).ToList();

        var finalTemplate = _template! with
        {
            ExecutorProfileName           = executorName,
            ReviewerProfileNames          = reviewerNames,
            AdvisorProfileNames           = advisorNames,
            GroundingProviderProfileNames = groundingNames,
            FinalizerProfileNames         = finalizerNames.Count > 0 ? finalizerNames : null,
        };

        var newProfiles = new List<ProposedProfile>();
        if (_executorSlot?.Mode == StudioSlotMode.CreateNew && _executorSlot.Draft is not null)
            newProfiles.Add(_executorSlot.Draft);
        newProfiles.AddRange(_reviewerSlots
            .Where(s => s.Mode == StudioSlotMode.CreateNew && s.Draft is not null)
            .Select(s => s.Draft!));
        newProfiles.AddRange(_advisorSlots
            .Where(s => s.Mode == StudioSlotMode.CreateNew && s.Draft is not null)
            .Select(s => s.Draft!));
        newProfiles.AddRange(_groundingSlots
            .Where(s => s.Mode == StudioSlotMode.CreateNew && s.Draft is not null)
            .Select(s => s.Draft!));
        newProfiles.AddRange(_finalizerSlots
            .Where(s => s.Mode == StudioSlotMode.CreateNew && s.Draft is not null)
            .Select(s => s.Draft!));

        return new MaterializationRequest(finalTemplate, newProfiles);
    }
}
