@using Geef.Atelier.Core.Domain.Crew.Finalizers

<div class="profile-picker" data-testid="finalizer-picker">
    <div class="profile-picker-grid">
        <div>
            <p class="picker-col-label">Verfügbar</p>
            @foreach (var p in AvailableNotSelected)
            {
                <button type="button" class="picker-pool-item"
                        data-testid="finalizer-picker-available-@p.Name"
                        @onclick="() => Add(p.Name)">
                    <span class="picker-add-icon">＋</span>
                    <span class="picker-item-name">@p.DisplayName</span>
                    <span class="picker-item-meta">@GetTypeLabel(p.FinalizerType)</span>
                    @if (p.IsSystem) { <span class="crew-badge">System</span> }
                </button>
            }
            @if (!AvailableNotSelected.Any())
            {
                <p class="picker-empty-state">Alle ausgewählt</p>
            }
        </div>
        <div>
            <p class="picker-col-label">Ausgewählt (Reihenfolge zählt)</p>
            @for (int i = 0; i < Selected.Count; i++)
            {
                var idx = i;
                var name = Selected[idx];
                var profile = FindProfile(name);
                <div class="picker-active-item" data-testid="finalizer-picker-selected-@name">
                    <span class="picker-item-rank">@(idx + 1).</span>
                    <span class="picker-item-name">
                        @if (profile != null)
                        {
                            @profile.DisplayName
                            <span class="picker-item-meta"> · @GetTypeLabel(profile.FinalizerType)</span>
                        }
                        else
                        {
                            @name
                        }
                    </span>
                    <div class="picker-item-controls">
                        <button type="button" class="btn small ghost" disabled="@(idx == 0)"
                                data-testid="finalizer-picker-up-@name"
                                @onclick="() => MoveUp(idx)">↑</button>
                        <button type="button" class="btn small ghost" disabled="@(idx == Selected.Count - 1)"
                                data-testid="finalizer-picker-down-@name"
                                @onclick="() => MoveDown(idx)">↓</button>
                        <button type="button" class="btn small danger"
                                data-testid="finalizer-picker-remove-@name"
                                @onclick="() => Remove(idx)">×</button>
                    </div>
                </div>
            }
            @if (Selected.Count == 0)
            {
                <p class="picker-empty-state">Kein Finalizer ausgewählt.</p>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<FinalizerProfile> AllProfiles { get; set; } = [];
    [Parameter, EditorRequired] public List<string> Selected { get; set; } = [];
    [Parameter] public EventCallback<List<string>> SelectedChanged { get; set; }

    private IEnumerable<FinalizerProfile> AvailableNotSelected =>
        AllProfiles.Where(p => !Selected.Contains(p.Name));

    private FinalizerProfile? FindProfile(string name) =>
        AllProfiles.FirstOrDefault(p => p.Name == name);

    private async Task Add(string name)
    {
        if (!Selected.Contains(name))
        {
            Selected = [.. Selected, name];
            await SelectedChanged.InvokeAsync(Selected);
        }
    }

    private async Task Remove(int idx)
    {
        var newList = Selected.ToList();
        newList.RemoveAt(idx);
        Selected = newList;
        await SelectedChanged.InvokeAsync(Selected);
    }

    private async Task MoveUp(int idx)
    {
        if (idx <= 0) return;
        var newList = Selected.ToList();
        (newList[idx - 1], newList[idx]) = (newList[idx], newList[idx - 1]);
        Selected = newList;
        await SelectedChanged.InvokeAsync(Selected);
    }

    private async Task MoveDown(int idx)
    {
        if (idx >= Selected.Count - 1) return;
        var newList = Selected.ToList();
        (newList[idx + 1], newList[idx]) = (newList[idx], newList[idx + 1]);
        Selected = newList;
        await SelectedChanged.InvokeAsync(Selected);
    }

    private static string GetTypeLabel(FinalizerType t) => t switch
    {
        FinalizerType.FileExport     => "Datei-Export",
        FinalizerType.MetadataEnrich => "Metadaten-Anreicherung",
        FinalizerType.ExternalSink   => "Externer Empfänger",
        FinalizerType.Transform      => "KI-Transformation",
        _                            => t.ToString(),
    };
}
