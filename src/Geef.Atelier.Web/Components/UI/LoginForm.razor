<div class="login-stage">
    <div class="login-left">
        <div class="ink-pool" aria-hidden="true">
            <span></span><span></span><span></span>
        </div>
        <div class="brand-row">
            <Brand />
        </div>
        <div class="quote">
            A text manufactory. <em>Briefings handed to a crew of writers and editors</em>, returned as manuscripts.
        </div>
        <div class="colophon">
            <span>EST. 2026 · ZÜRICH</span>
            <span>VOL. III</span>
            <span>NO. 047</span>
        </div>
    </div>
    <div class="login-right">
        @if (Error is not null)
        {
            <div class="login-error" role="alert">@Error</div>
        }
        <form method="post" class="login-card" @formname="login-form">
            <AntiforgeryToken />
            @if (ReturnUrl is not null)
            {
                <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
            }
            <h1>Enter the atelier</h1>
            <p class="sub">Single workshop, single hand.</p>

            <div class="field">
                <label for="username">Handle</label>
                <input id="username" type="text" name="Model.Username" autocomplete="username" required />
            </div>
            <div class="field">
                <label for="password">Passphrase</label>
                <input id="password" type="password" name="Model.Password" autocomplete="current-password"
                       required placeholder="•••••••••" />
            </div>

            <button type="submit" class="btn primary btn-login" style="width:100%;justify-content:center;padding:12px 16px;margin-top:6px">
                Open the door
            </button>
        </form>
    </div>
</div>

@code {
    [Parameter] public string? Error     { get; set; }
    [Parameter] public string? ReturnUrl { get; set; }
}
