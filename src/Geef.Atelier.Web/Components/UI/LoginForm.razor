@if (Error is not null)
{
    <div class="login-error" role="alert">@Error</div>
}

<form method="post" class="login-form" @formname="login-form">
    <AntiforgeryToken />
    @if (ReturnUrl is not null)
    {
        <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
    }
    <h1 class="login-title">Geef.Atelier</h1>
    <div class="form-group">
        <label for="username">Benutzername</label>
        <input id="username" type="text" name="Model.Username" autocomplete="username"
               required class="form-control" />
    </div>
    <div class="form-group">
        <label for="password">Passwort</label>
        <input id="password" type="password" name="Model.Password" autocomplete="current-password"
               required class="form-control" />
    </div>
    <button type="submit" class="btn-login">Anmelden</button>
</form>

@code {
    [Parameter] public string? Error      { get; set; }
    [Parameter] public string? ReturnUrl  { get; set; }
}
