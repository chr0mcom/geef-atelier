@using Geef.Atelier.Application.Crew
@using Geef.Atelier.Core.Domain.Crew
@inject IModelCatalog ModelCatalog

<div class="model-selector" data-testid="@DataTestId">
    @if (_loading)
    {
        <div class="model-selector-loading">Loading models…</div>
    }
    else
    {
        @if (_usingFallback)
        {
            <div class="model-selector-fallback-banner">
                Showing fallback list — provider unreachable.
                <button type="button" class="model-selector-refresh-inline" @onclick="HandleRefresh">Refresh</button>
            </div>
        }

        @if (_showCustomInput)
        {
            <div class="model-selector-custom-row">
                <input type="text"
                       class="model-selector-custom-input"
                       value="@Value"
                       @oninput="OnCustomInput"
                       placeholder="Enter custom model ID…"
                       data-testid="model-selector-custom-input" />
                <button type="button" class="model-selector-back" @onclick="SwitchToDropdown"
                        title="Back to list">↩</button>
            </div>
        }
        else
        {
            <div class="model-selector-combo-row">
                <div class="model-selector-trigger-wrap">
                    <button type="button" class="model-selector-trigger"
                            @onclick="Toggle"
                            disabled="@Disabled"
                            data-testid="model-selector-trigger">
                        <span class="trigger-label @(string.IsNullOrEmpty(Value) ? "placeholder" : "")">@GetTriggerLabel()</span>
                        <span class="trigger-chevron">▾</span>
                    </button>

                    @if (_isOpen)
                    {
                        <div class="model-selector-backdrop" @onclick="Close"></div>
                        <div class="model-selector-panel" data-testid="model-selector-panel">
                            <input type="text"
                                   class="model-selector-search"
                                   placeholder="Search models…"
                                   value="@_searchQuery"
                                   @oninput="OnSearchInput"
                                   @onkeydown="HandleKeyDown"
                                   data-testid="model-selector-search"
                                   @ref="_searchInputRef" />
                            <div class="model-selector-list">
                                @{
                                    var filteredRecommended = GetFiltered(_recommended).ToList();
                                    var filteredOthers = GetFiltered(_others).ToList();
                                }
                                @if (filteredRecommended.Count > 0)
                                {
                                    <div class="model-group-label">Recommended</div>
                                    @foreach (var m in filteredRecommended)
                                    {
                                        <div class="model-list-item @(string.Equals(m.Id, Value, StringComparison.OrdinalIgnoreCase) ? "selected" : "")"
                                             @onclick="() => SelectModel(m.Id)">@m.Label</div>
                                    }
                                }
                                @if (filteredOthers.Count > 0)
                                {
                                    <div class="model-group-label">Other available</div>
                                    @foreach (var m in filteredOthers)
                                    {
                                        <div class="model-list-item @(string.Equals(m.Id, Value, StringComparison.OrdinalIgnoreCase) ? "selected" : "")"
                                             @onclick="() => SelectModel(m.Id)">@m.Label</div>
                                    }
                                }
                                @if (filteredRecommended.Count == 0 && filteredOthers.Count == 0)
                                {
                                    <div class="model-list-empty">No models match "@_searchQuery"</div>
                                }
                                <div class="model-list-item custom" @onclick="SwitchToCustomInput">Custom model name…</div>
                            </div>
                        </div>
                    }
                </div>
                <button type="button" class="model-selector-refresh" @onclick="HandleRefresh"
                        title="Refresh model list" disabled="@_refreshing">⟳</button>
            </div>
        }
    }
</div>

@code {
    [Parameter] public string Provider { get; set; } = "";
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string DataTestId { get; set; } = "model-selector";

    private string _loadedForProvider = "";
    private List<ModelInfo> _recommended = [];
    private List<ModelInfo> _others      = [];
    private bool _loading       = false;
    private bool _refreshing    = false;
    private bool _usingFallback = false;
    private bool _showCustomInput = false;
    private bool _isOpen = false;
    private bool _prevIsOpen = false;
    private string _searchQuery = "";
    private ElementReference _searchInputRef;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(Provider) && Provider != _loadedForProvider)
        {
            _isOpen = false;
            _searchQuery = "";
            _showCustomInput = false;
            // When switching providers (not the initial load), clear the stale model ID
            // so LoadModelsAsync selects the first recommended model of the new provider
            // instead of treating the previous provider's ID as a custom entry.
            if (!string.IsNullOrEmpty(_loadedForProvider))
                await SetValue("");
            await LoadModelsAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isOpen && !_prevIsOpen)
        {
            try { await _searchInputRef.FocusAsync(); } catch { }
        }
        _prevIsOpen = _isOpen;
    }

    private async Task LoadModelsAsync(bool forceRefresh = false)
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var models = forceRefresh
                ? await ModelCatalog.RefreshAsync(Provider)
                : await ModelCatalog.ListModelsAsync(Provider);

            _recommended = models.Where(m => m.IsRecommended).ToList();
            _others      = models.Where(m => !m.IsRecommended).ToList();
            _usingFallback = ModelCatalog.IsUsingFallback(Provider);
            _loadedForProvider = Provider;

            var allIds = models.Select(m => m.Id).ToHashSet(StringComparer.OrdinalIgnoreCase);
            if (!string.IsNullOrEmpty(Value) && !allIds.Contains(Value))
            {
                _showCustomInput = true;
            }
            else
            {
                _showCustomInput = false;
                if (string.IsNullOrEmpty(Value) && _recommended.Count > 0)
                    await SetValue(_recommended[0].Id);
            }
        }
        finally
        {
            _loading = false;
            _refreshing = false;
        }
    }

    private void Toggle()
    {
        if (!Disabled)
            _isOpen = !_isOpen;
    }

    private void Close()
    {
        _isOpen = false;
        _searchQuery = "";
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchQuery = e.Value?.ToString() ?? "";
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            Close();
        }
        else if (e.Key == "Enter")
        {
            var filteredAll = GetFiltered(_recommended).Concat(GetFiltered(_others)).ToList();
            if (filteredAll.Count == 1)
                await SelectModel(filteredAll[0].Id);
        }
    }

    private async Task SelectModel(string id)
    {
        _isOpen = false;
        _searchQuery = "";
        await SetValue(id);
    }

    private void SwitchToCustomInput()
    {
        _isOpen = false;
        _searchQuery = "";
        _showCustomInput = true;
        _ = SetValue("");
    }

    private async Task OnCustomInput(ChangeEventArgs e)
    {
        await SetValue(e.Value?.ToString() ?? "");
    }

    private void SwitchToDropdown()
    {
        _showCustomInput = false;
        var firstModel = _recommended.Count > 0 ? _recommended[0].Id : (_others.Count > 0 ? _others[0].Id : "");
        _ = SetValue(firstModel);
    }

    private async Task HandleRefresh()
    {
        _refreshing = true;
        await LoadModelsAsync(forceRefresh: true);
    }

    private async Task SetValue(string value)
    {
        Value = value;
        await ValueChanged.InvokeAsync(value);
    }

    private string GetTriggerLabel()
    {
        if (string.IsNullOrEmpty(Value)) return "Select a model…";
        var found = _recommended.Concat(_others).FirstOrDefault(m =>
            string.Equals(m.Id, Value, StringComparison.OrdinalIgnoreCase));
        return found?.Label ?? Value;
    }

    private IEnumerable<ModelInfo> GetFiltered(IEnumerable<ModelInfo> models) =>
        string.IsNullOrWhiteSpace(_searchQuery)
            ? models
            : models.Where(m =>
                m.Id.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                m.Label.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));

    /// <summary>Returns true when the current <see cref="Value"/> is not in the fetched model list.</summary>
    public bool IsCustomModel()
    {
        var allIds = _recommended.Concat(_others).Select(m => m.Id).ToHashSet(StringComparer.OrdinalIgnoreCase);
        return !string.IsNullOrEmpty(Value) && !allIds.Contains(Value);
    }
}
