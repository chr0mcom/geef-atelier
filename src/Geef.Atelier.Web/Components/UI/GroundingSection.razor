@using Geef.Atelier.Core.Domain.Crew.Advisors
@using Geef.Atelier.Core.Domain.Crew.Grounding
@using Geef.Atelier.Web.Display

<div class="grounding-section" data-testid="grounding-section">
    <h2 class="grounding-header">Grounding</h2>

    <div class="sub-section">
        <div class="sub-section-label">Briefing</div>
        <pre class="briefing-text">@Briefing</pre>
    </div>

    @if (GroundingConsultations?.Count > 0)
    {
        <div class="sub-section" data-testid="grounding-web-research">
            <button class="sub-section-toggle collapsible-header" type="button"
                    @onclick="() => _webResearchExpanded = !_webResearchExpanded"
                    aria-expanded="@_webResearchExpanded">
                <span class="chevron @(_webResearchExpanded ? "up" : "down")">▾</span>
                <span>Web Research (@GroundingConsultations.Count @(GroundingConsultations.Count == 1 ? "search" : "searches"))</span>
            </button>
            @if (_webResearchExpanded)
            {
                <div class="collapsible-body">
                    @foreach (var consultation in GroundingConsultations)
                    {
                        <div class="grounding-consultation" data-testid="grounding-consultation-@consultation.Id">
                            <div class="grounding-consultation-meta">
                                <span class="grounding-provider-label">@ReviewerDisplay.GetGroundingProviderDisplay(consultation.GroundingProviderName, consultation.GroundingProviderName)</span>
                                @if (consultation.CostEur.HasValue)
                                {
                                    <span class="grounding-cost">~€@consultation.CostEur.Value.ToString("F4")</span>
                                }
                            </div>
                            <div class="grounding-query">
                                <strong>Query:</strong> <em>@Truncate(consultation.Query, 200)</em>
                            </div>
                            @if (consultation.Citations.Count > 0)
                            {
                                <ol class="grounding-citations">
                                    @foreach (var citation in consultation.Citations)
                                    {
                                        var isRunLocal = false;
                                        if (citation.DocumentReference is { } docRef
                                            && docRef.Contains('/')
                                            && Guid.TryParse(docRef.Split('/')[0], out var docGuid))
                                        {
                                            isRunLocal = RunAttachmentDocumentIds.Contains(docGuid);
                                        }
                                        <li class="grounding-citation">
                                            @if (!string.IsNullOrEmpty(citation.Url))
                                            {
                                                <a href="@citation.Url" target="_blank" rel="noopener noreferrer" class="citation-title">@citation.Title</a>
                                            }
                                            else if (!string.IsNullOrEmpty(citation.DocumentReference))
                                            {
                                                var docId = ParseDocId(citation.DocumentReference);
                                                @if (isRunLocal)
                                                {
                                                    <span class="citation-title">@citation.Title</span>
                                                    <span class="badge badge-attachment">From this run's attachments</span>
                                                }
                                                else
                                                {
                                                    <a href="/crew/knowledge/@docId" class="citation-title">@citation.Title</a>
                                                    <span class="badge badge-knowledge-base">From your knowledge base</span>
                                                }
                                                @if (citation.RelevanceScore.HasValue)
                                                {
                                                    <span class="citation-score">(relevance: @citation.RelevanceScore.Value.ToString("F2"))</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="citation-title">@citation.Title</span>
                                            }
                                            @if (citation.Url != null && citation.RelevanceScore.HasValue)
                                            {
                                                <span class="citation-score">@citation.RelevanceScore.Value.ToString("F2")</span>
                                            }
                                            @if (!string.IsNullOrEmpty(citation.Snippet))
                                            {
                                                <div class="citation-snippet">@Truncate(citation.Snippet, 300)</div>
                                            }
                                        </li>
                                    }
                                </ol>
                            }
                            @if (consultation.RefinementOutcome is { WasSkipped: true } skipped)
                            {
                                <div class="refinement-skip-banner">
                                    <span class="icon">⚠</span>
                                    Refinement skipped — raw results are used.
                                    @if (!string.IsNullOrWhiteSpace(skipped.SkipReason))
                                    {
                                        <span class="reason"> (@skipped.SkipReason)</span>
                                    }
                                </div>
                            }
                            else if (consultation.RefinementOutcome is { WasSkipped: false } outcome)
                            {
                                <div class="refinement-outcome">
                                    <span class="badge badge-refinement">@consultation.Citations.Count sources → @outcome.RefinedCitations.Count kept</span>
                                    @if (outcome.SynthesizedText is not null)
                                    {
                                        <div class="refinement-synthesis">
                                            <h4>Synthesized context</h4>
                                            <p>@outcome.SynthesizedText</p>
                                        </div>
                                    }
                                    @if (outcome.DroppedCitations.Count > 0)
                                    {
                                        <details class="refinement-dropped">
                                            <summary>@outcome.DroppedCitations.Count dropped source(s)</summary>
                                            <ul>
                                                @foreach (var dropped in outcome.DroppedCitations)
                                                {
                                                    <li>
                                                        <strong>@dropped.Original.Title</strong>
                                                        @if (!string.IsNullOrWhiteSpace(dropped.Original.Url))
                                                        {
                                                            <span> — <a href="@dropped.Original.Url" target="_blank">Link</a></span>
                                                        }
                                                        else if (!string.IsNullOrWhiteSpace(dropped.Original.DocumentReference))
                                                        {
                                                            <span> — @dropped.Original.DocumentReference</span>
                                                        }
                                                        <br /><em>Reason: @dropped.Reason</em>
                                                    </li>
                                                }
                                            </ul>
                                        </details>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }

    @if (BeforeFirstAdvisors.Count > 0)
    {
        <div class="sub-section" data-testid="grounding-advisors">
            <button class="sub-section-toggle collapsible-header" type="button"
                    @onclick="() => _advisorsExpanded = !_advisorsExpanded"
                    aria-expanded="@_advisorsExpanded">
                <span class="chevron @(_advisorsExpanded ? "up" : "down")">▾</span>
                <span>Advisor consultations (@BeforeFirstAdvisors.Count)</span>
            </button>
            @if (_advisorsExpanded)
            {
                <div class="collapsible-body">
                    <AdvisorConsultationsBlock Consultations="BeforeFirstAdvisors" />
                </div>
            }
        </div>
    }

    <div class="sub-section" data-testid="grounding-brief">
        <button class="sub-section-toggle collapsible-header" type="button"
                @onclick="() => _groundedExpanded = !_groundedExpanded"
                aria-expanded="@_groundedExpanded">
            <span class="chevron @(_groundedExpanded ? "up" : "down")">▾</span>
            <span>Grounded Brief</span>
        </button>
        @if (_groundedExpanded)
        {
            <div class="collapsible-body">
                <pre class="briefing-text">@GroundedBrief</pre>
                @if (GroundingConsultations == null || GroundingConsultations.Count == 0)
                {
                    <p class="grounded-brief-hint"><em>Currently identical to the original briefing — RAG will enrich this in a future step.</em></p>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Briefing { get; set; } = "";
    [Parameter, EditorRequired] public string GroundedBrief { get; set; } = "";
    [Parameter] public IReadOnlyList<AdvisorConsultation> BeforeFirstAdvisors { get; set; } = [];
    [Parameter] public IReadOnlyList<GroundingConsultation>? GroundingConsultations { get; set; }
    [Parameter] public IReadOnlyList<Guid> RunAttachmentDocumentIds { get; set; } = [];

    private bool _webResearchExpanded = true;
    private bool _advisorsExpanded = false;
    private bool _groundedExpanded = false;

    private static string Truncate(string s, int max) =>
        s.Length > max ? s[..max] + "…" : s;

    /// <summary>
    /// Parses the document ID from a vector-store document reference in the format "{docId}/chunk-{N}".
    /// </summary>
    private static string ParseDocId(string documentReference)
    {
        var slashIndex = documentReference.IndexOf('/');
        return slashIndex > 0 ? documentReference[..slashIndex] : documentReference;
    }
}
