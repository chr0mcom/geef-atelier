<div class="coming-soon">
    <h1>@Title</h1>
    <p>Coming soon.</p>
    <a href="/" class="lp-cta ghost">← Back</a>
</div>

<style>
    .coming-soon {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        gap: 18px;
        font-family: var(--font-display);
        text-align: center;
        padding: 48px 24px;
    }
    .coming-soon h1 {
        font-weight: 300;
        font-size: clamp(28px, 4vw, 48px);
        letter-spacing: -0.018em;
        color: var(--ink);
        margin: 0;
    }
    .coming-soon p {
        font-family: var(--font-ui);
        color: var(--ink-3);
        font-size: 15px;
        margin: 0;
    }
</style>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "";
}
