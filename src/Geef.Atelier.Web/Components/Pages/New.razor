@page "/new"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IRunService RunService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider

<PageTitle>New Run — Geef.Atelier</PageTitle>

<div class="new-run-container">
    <h2>New Run</h2>

    @if (_error is not null)
    {
        <div class="new-run-error">@_error</div>
    }

    <SubmitForm OnSubmitted="HandleSubmittedAsync" />
</div>

@code {
    private string? _error;

    private async Task HandleSubmittedAsync(SubmitFormResult result)
    {
        _error = null;
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            var createdByUser = auth.User.Identity?.Name;
            var runId = await RunService.SubmitRunAsync(result.Briefing, result.ConfigJson, createdByUser: createdByUser);
            Nav.NavigateTo($"/runs/{runId}");
        }
        catch (ArgumentException ex)
        {
            _error = ex.Message;
        }
        catch (Exception)
        {
            _error = "Failed to submit run. Please try again.";
        }
    }
}
