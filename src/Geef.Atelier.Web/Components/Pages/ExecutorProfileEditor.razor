@page "/crew/profiles/executors/new"
@page "/crew/profiles/executors/{name}"
@attribute [Authorize]
@rendermode InteractiveServer
@using Geef.Atelier.Application.Crew
@using Geef.Atelier.Core.Domain.Crew
@using Geef.Atelier.Core.Domain.Crew.Profiles
@inject ICrewService CrewService
@inject NavigationManager Nav

<PageTitle>@(IsNew ? "Executor-Profil erstellen" : "Executor-Profil bearbeiten") — Atelier</PageTitle>

<div class="crew-editor" data-testid="executor-profile-editor">
    <div class="page-header">
        <h1>@(IsNew ? "Neues Executor-Profil" : _isSystem ? _displayName : $"Bearbeiten: {_displayName}")</h1>
        <a href="/crew/profiles/executors" class="btn ghost">← Zurück</a>
    </div>

    @if (_loading)
    {
        <p>Wird geladen…</p>
    }
    else
    {
        <ProfileEditorForm ProfileName="@(IsNew ? null : Name)"
                           DisplayName="@_profileDisplayName"
                           Description="@_profileDescription"
                           SystemPrompt="@_profileSystemPrompt"
                           Provider="@_profileProvider"
                           Model="@_profileModel"
                           MaxTokens="@_profile?.MaxTokens"
                           IsSystem="@_isSystem"
                           IsSaving="@_saving"
                           Error="@_error"
                           ShowToolPicker="true"
                           InitialToolNames="@_profile?.ToolNames"
                           OnSave="SaveAsync"
                           OnCancel="NavigateBack"
                           OnDuplicate="DuplicateAsCustom"
                           OnDeleteRequested="() => _showDeleteModal = true" />
    }
</div>

<DeleteConfirmationModal
    Show="_showDeleteModal"
    ItemName="@(Name ?? "")"
    ItemKind="Profile"
    OnConfirm="ExecuteDeleteAsync"
    OnCancel="() => _showDeleteModal = false" />

@code {
    [Parameter] public string? Name { get; set; }

    private bool IsNew => Name == null;
    private bool _isSystem;
    private bool _loading = true;
    private bool _saving;
    private bool _showDeleteModal;
    private string? _error;
    private string _displayName = "";
    private ExecutorProfile? _profile;

    // Computed properties to avoid null-coalescing in Razor component attributes
    private string _profileDisplayName => _profile?.DisplayName ?? "";
    private string _profileDescription => _profile?.Description ?? "";
    private string _profileSystemPrompt => _profile?.SystemPrompt ?? "";
    private string _profileProvider => _profile?.Provider ?? "";
    private string _profileModel => _profile?.Model ?? "";

    protected override async Task OnInitializedAsync()
    {
        if (!IsNew)
        {
            _profile = await CrewService.GetExecutorProfileAsync(Name!);
            if (_profile == null) { Nav.NavigateTo("/crew/profiles/executors"); return; }
            _isSystem = _profile.IsSystem;
            _displayName = _profile.DisplayName;
        }

        _loading = false;
    }

    private void NavigateBack() => Nav.NavigateTo("/crew/profiles/executors");

    private async Task SaveAsync(ProfileEditorForm.ProfileFormValues values)
    {
        _saving = true;
        _error = null;
        try
        {
            var profile = new ExecutorProfile(
                Name: SystemCrew.EnsureCustomPrefix(values.Name),
                DisplayName: values.DisplayName,
                Description: values.Description,
                SystemPrompt: values.SystemPrompt,
                Provider: values.Provider,
                Model: values.Model,
                MaxTokens: values.MaxTokens,
                IsSystem: false,
                ToolNames: values.ToolNames);

            if (IsNew)
            {
                await CrewService.CreateCustomExecutorProfileAsync(profile);
            }
            else
            {
                if (profile.Name != Name)
                    await CrewService.RenameCustomExecutorProfileAsync(Name!, profile.Name);
                await CrewService.UpdateCustomExecutorProfileAsync(profile);
            }

            Nav.NavigateTo("/crew/profiles/executors");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DuplicateAsCustom()
    {
        _error = null;
        try
        {
            var original = await CrewService.GetExecutorProfileAsync(Name!);
            if (original == null) return;
            var copy = original with
            {
                Name = original.Name + "-copy",
                DisplayName = original.DisplayName + " (Copy)",
                IsSystem = false
            };
            await CrewService.CreateCustomExecutorProfileAsync(copy);
            Nav.NavigateTo("/crew/profiles/executors");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task ExecuteDeleteAsync()
    {
        _showDeleteModal = false;
        _error = null;
        try
        {
            await CrewService.DeleteCustomExecutorProfileAsync(Name!);
            Nav.NavigateTo("/crew/profiles/executors");
        }
        catch (Exception ex) { _error = ex.Message; }
    }
}
