@page "/admin/site-settings"
@attribute [Authorize(Policy = "AdminPolicy")]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Geef.Atelier.Application.SiteSettings
@inject ISiteSettingsService SiteSettingsService

<PageTitle>Site Settings — Geef.Atelier</PageTitle>

<div class="crew-editor settings-page-wrap" data-testid="site-settings-page">
    <div class="page-header">
        <h1>Site Settings</h1>
        <a href="/workshop" class="btn ghost">← Back</a>
    </div>

    <div class="settings-notice">
        ⚠️ <strong>Note:</strong> The details saved here appear on the public legal pages
        (imprint, privacy, terms). The prefilled legal texts are <strong>templates — not legal advice</strong>.
        Please have the texts reviewed by a lawyer before going live and adapt them to your actual
        data processing.
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger" data-testid="error-banner">@_error</div>
    }
    @if (!string.IsNullOrEmpty(_success))
    {
        <div class="alert alert-success" data-testid="success-banner">@_success</div>
    }

    @if (_loading)
    {
        <p>Loading…</p>
    }
    else
    {
        <form class="settings-form" @onsubmit="SaveAsync" data-testid="settings-form">

            <fieldset>
                <legend>Operator</legend>

                <div class="form-group">
                    <label for="operator-name">Operator name <span class="required">*</span></label>
                    <input id="operator-name" type="text" @bind="_operatorName" required maxlength="200"
                           data-testid="input-operator-name"
                           placeholder="Jane Doe or Doe Ltd." />
                    <span class="field-help">Full name or company (imprint, § 5 DDG).</span>
                </div>

                <div class="form-group">
                    <label for="address-street">Street and number <span class="required">*</span></label>
                    <input id="address-street" type="text" @bind="_addressStreet" required maxlength="300"
                           data-testid="input-address-street" placeholder="1 Example Street" />
                </div>

                <div class="form-row">
                    <div class="form-group" style="max-width:140px;">
                        <label for="address-zip">Postal code <span class="required">*</span></label>
                        <input id="address-zip" type="text" @bind="_addressZip" required maxlength="20"
                               data-testid="input-address-zip" placeholder="12345" />
                    </div>
                    <div class="form-group">
                        <label for="address-city">City <span class="required">*</span></label>
                        <input id="address-city" type="text" @bind="_addressCity" required maxlength="100"
                               data-testid="input-address-city" placeholder="Anytown" />
                    </div>
                </div>

                <div class="form-group">
                    <label for="address-country">Country <span class="required">*</span></label>
                    <input id="address-country" type="text" @bind="_addressCountry" required maxlength="100"
                           data-testid="input-address-country" placeholder="Germany" />
                </div>
            </fieldset>

            <fieldset>
                <legend>Contact</legend>

                <div class="form-group">
                    <label for="contact-email">Email <span class="required">*</span></label>
                    <input id="contact-email" type="email" @bind="_contactEmail" required maxlength="300"
                           data-testid="input-contact-email" placeholder="contact@example.com" />
                    <span class="field-help">Shown obfuscated on the imprint and privacy pages (no plaintext in the HTML).</span>
                </div>

                <div class="form-group">
                    <label for="contact-phone">Phone (optional)</label>
                    <input id="contact-phone" type="tel" @bind="_contactPhone" maxlength="100"
                           data-testid="input-contact-phone" placeholder="+49 123 456789" />
                </div>
            </fieldset>

            <fieldset>
                <legend>Additional details (optional)</legend>

                <div class="form-group">
                    <label for="responsible-person">Person responsible (V.i.S.d.P.)</label>
                    <input id="responsible-person" type="text" @bind="_responsiblePerson" maxlength="300"
                           data-testid="input-responsible-person"
                           placeholder="Name of the editorially responsible person" />
                    <span class="field-help">Person responsible for journalistic/editorial content (V.i.S.d.P.).</span>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="vat-id">VAT ID</label>
                        <input id="vat-id" type="text" @bind="_vatId" maxlength="50"
                               data-testid="input-vat-id" placeholder="DE123456789" />
                    </div>
                    <div class="form-group">
                        <label for="jurisdiction">Jurisdiction</label>
                        <input id="jurisdiction" type="text" @bind="_jurisdiction" maxlength="100"
                               data-testid="input-jurisdiction" placeholder="Anytown" />
                    </div>
                </div>

                <div class="form-group">
                    <label for="register-info">Register entry</label>
                    <input id="register-info" type="text" @bind="_registerInfo" maxlength="300"
                           data-testid="input-register-info" placeholder="HRB 12345, Anytown district court" />
                </div>

                <div class="form-group">
                    <label for="supervisory-authority">Supervisory authority</label>
                    <input id="supervisory-authority" type="text" @bind="_supervisoryAuthority" maxlength="300"
                           data-testid="input-supervisory-authority"
                           placeholder="State data protection commissioner, Anytown" />
                </div>
            </fieldset>

            <fieldset>
                <legend>Custom additions (Markdown)</legend>

                <div class="form-group">
                    <label for="privacy-append">Privacy appendix (optional)</label>
                    <textarea id="privacy-append" @bind="_privacyAppendMarkdown" rows="5"
                              data-testid="input-privacy-append"
                              placeholder="Additional operator-specific sections for the privacy policy (Markdown)."></textarea>
                    <span class="field-help">Appended after the boilerplate text of the privacy policy.</span>
                </div>

                <div class="form-group">
                    <label for="terms-append">Terms appendix (optional)</label>
                    <textarea id="terms-append" @bind="_termsAppendMarkdown" rows="5"
                              data-testid="input-terms-append"
                              placeholder="Additional operator-specific sections for the terms of use (Markdown)."></textarea>
                    <span class="field-help">Appended after the boilerplate text of the terms.</span>
                </div>
            </fieldset>

            <label class="settings-legal-accept" data-testid="legal-accept-label">
                <input type="checkbox" @bind="_legalBoilerplateAccepted" data-testid="input-legal-accepted" />
                <span class="settings-legal-accept-label">
                    <strong>I confirm</strong> that I have had the template legal texts (privacy policy, terms, imprint)
                    reviewed legally, or that I consciously choose to use them in this form.
                    This hides the notice banner on the public legal pages.
                </span>
            </label>

            @if (!string.IsNullOrEmpty(_validationError))
            {
                <div class="alert alert-danger" data-testid="validation-error">@_validationError</div>
            }

            <div class="form-actions">
                <button type="submit" class="btn primary" disabled="@_saving" data-testid="btn-save">
                    @(_saving ? "Saving…" : "Save")
                </button>
            </div>
        </form>
    }
</div>

@code {
    private bool _loading = true;
    private bool _saving;
    private string _error = "";
    private string _success = "";
    private string _validationError = "";

    private string _operatorName = "";
    private string _addressStreet = "";
    private string _addressZip = "";
    private string _addressCity = "";
    private string _addressCountry = "Germany";
    private string _contactEmail = "";
    private string? _contactPhone;
    private string? _responsiblePerson;
    private string? _vatId;
    private string? _registerInfo;
    private string? _supervisoryAuthority;
    private string? _jurisdiction;
    private string? _privacyAppendMarkdown;
    private string? _termsAppendMarkdown;
    private bool _legalBoilerplateAccepted;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var settings = await SiteSettingsService.GetAsync();
            _operatorName           = settings.OperatorName;
            _addressStreet          = settings.AddressStreet;
            _addressZip             = settings.AddressZip;
            _addressCity            = settings.AddressCity;
            _addressCountry         = settings.AddressCountry;
            _contactEmail           = settings.ContactEmail;
            _contactPhone           = settings.ContactPhone;
            _responsiblePerson      = settings.ResponsiblePerson;
            _vatId                  = settings.VatId;
            _registerInfo           = settings.RegisterInfo;
            _supervisoryAuthority   = settings.SupervisoryAuthority;
            _jurisdiction           = settings.Jurisdiction;
            _privacyAppendMarkdown  = settings.PrivacyAppendMarkdown;
            _termsAppendMarkdown    = settings.TermsAppendMarkdown;
            _legalBoilerplateAccepted = settings.LegalBoilerplateAccepted;
        }
        catch (Exception ex)
        {
            _error = $"Error loading settings: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveAsync()
    {
        _validationError = "";
        _success = "";

        if (string.IsNullOrWhiteSpace(_operatorName))
        {
            _validationError = "Operator name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_contactEmail) || !_contactEmail.Contains('@'))
        {
            _validationError = "A valid email address is required.";
            return;
        }

        _saving = true;
        try
        {
            var settings = new Core.Domain.SiteSettings
            {
                OperatorName            = _operatorName.Trim(),
                AddressStreet           = _addressStreet.Trim(),
                AddressZip              = _addressZip.Trim(),
                AddressCity             = _addressCity.Trim(),
                AddressCountry          = _addressCountry.Trim(),
                ContactEmail            = _contactEmail.Trim(),
                ContactPhone            = NullIfEmpty(_contactPhone),
                ResponsiblePerson       = NullIfEmpty(_responsiblePerson),
                VatId                   = NullIfEmpty(_vatId),
                RegisterInfo            = NullIfEmpty(_registerInfo),
                SupervisoryAuthority    = NullIfEmpty(_supervisoryAuthority),
                Jurisdiction            = NullIfEmpty(_jurisdiction),
                PrivacyAppendMarkdown   = NullIfEmpty(_privacyAppendMarkdown),
                TermsAppendMarkdown     = NullIfEmpty(_termsAppendMarkdown),
                LegalBoilerplateAccepted = _legalBoilerplateAccepted,
                UpdatedAt               = DateTimeOffset.UtcNow,
            };

            await SiteSettingsService.UpdateAsync(settings);
            _success = "Settings saved successfully.";
        }
        catch (Exception ex)
        {
            _error = $"Error saving: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private static string? NullIfEmpty(string? value)
        => string.IsNullOrWhiteSpace(value) ? null : value.Trim();
}
