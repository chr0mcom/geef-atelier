@page "/crew/profiles/executors"
@attribute [Authorize]
@rendermode InteractiveServer
@using Geef.Atelier.Application.Crew
@using Geef.Atelier.Core.Domain.Crew.Profiles
@inject ICrewService CrewService
@inject NavigationManager Nav

<PageTitle>Executor Profiles — Atelier</PageTitle>

<div class="crew-profiles-index">
    <div class="page-header">
        <h1>Executor Profiles</h1>
        <a href="/crew/profiles/executors/new" class="btn primary">+ New Profile</a>
    </div>

    @if (_profiles.Count == 0)
    {
        <p class="text-muted">No executor profiles yet.</p>
    }
    else
    {
        <table class="crew-table" data-testid="profile-list">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Provider</th>
                    <th>Model</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in _profiles)
                {
                    <tr data-testid="profile-row-@p.Name">
                        <td>
                            @p.DisplayName
                            @if (p.IsSystem) { <span class="crew-badge">System</span> }
                        </td>
                        <td>@p.Provider</td>
                        <td>@p.Model</td>
                        <td class="crew-table-actions">
                            @if (p.IsSystem)
                            {
                                <a href="/crew/profiles/executors/view/@Uri.EscapeDataString(p.Name)" class="btn small">View</a>
                                <button class="btn small primary" @onclick="() => DuplicateProfile(p)">Duplicate as custom</button>
                            }
                            else
                            {
                                <a href="/crew/profiles/executors/@p.Name" class="btn small">Edit</a>
                                <button class="btn small danger" @onclick="() => _profileToDelete = p">Delete</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="error-banner">@_error</div>
    }
</div>

<DeleteConfirmationModal
    Show="_profileToDelete != null"
    ItemName="@(_profileToDelete?.Name ?? "")"
    ItemKind="Profile"
    OnConfirm="ExecuteIndexDeleteAsync"
    OnCancel="() => _profileToDelete = null" />

@code {
    private IReadOnlyList<ExecutorProfile> _profiles = [];
    private ExecutorProfile? _profileToDelete;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _profiles = await CrewService.ListExecutorProfilesAsync(includeSystem: true);
    }

    private async Task DuplicateProfile(ExecutorProfile original)
    {
        _error = null;
        try
        {
            var copy = original with
            {
                Name = original.Name + "-copy",
                DisplayName = original.DisplayName + " (Copy)",
                IsSystem = false
            };
            var created = await CrewService.CreateCustomExecutorProfileAsync(copy);
            Nav.NavigateTo($"/crew/profiles/executors/{Uri.EscapeDataString(created.Name)}");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task ExecuteIndexDeleteAsync()
    {
        if (_profileToDelete == null) return;
        var name = _profileToDelete.Name;
        _profileToDelete = null;
        try { await CrewService.DeleteCustomExecutorProfileAsync(name); await LoadAsync(); }
        catch (Exception ex) { _error = ex.Message; }
    }
}
