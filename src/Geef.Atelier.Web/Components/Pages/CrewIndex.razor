@page "/crew"
@attribute [Authorize]
@rendermode InteractiveServer
@using Geef.Atelier.Application.Crew
@using Geef.Atelier.Core.Domain.Crew
@using Geef.Atelier.Core.Domain.Crew.Advisors
@using Geef.Atelier.Core.Domain.Crew.Grounding
@using Geef.Atelier.Core.Domain.Crew.Profiles
@inject ICrewService CrewService

<PageTitle>Crew — Atelier</PageTitle>

<div class="crew-index">
    <h1>Crew</h1>

    <section class="crew-section">
        <div class="crew-section-header">
            <h2>Templates</h2>
            <a href="/crew/templates/new" class="btn small">+ New</a>
        </div>
        @if (_templates.Count == 0)
        {
            <p class="text-muted">No templates yet.</p>
        }
        else
        {
            <ul class="crew-item-list">
                @foreach (var t in _templates.Take(5))
                {
                    <li>
                        <a href="/crew/templates/@t.Name">@t.DisplayName</a>
                        @if (t.IsSystem) { <span class="crew-badge">System</span> }
                    </li>
                }
            </ul>
        }
        <a href="/crew/templates" class="view-all-link">View all templates →</a>
    </section>

    <section class="crew-section">
        <div class="crew-section-header">
            <h2>Reviewer Profiles</h2>
            <a href="/crew/profiles/reviewers/new" class="btn small">+ New</a>
        </div>
        @if (_reviewers.Count == 0)
        {
            <p class="text-muted">No reviewer profiles yet.</p>
        }
        else
        {
            <ul class="crew-item-list">
                @foreach (var r in _reviewers.Take(5))
                {
                    <li>
                        <a href="/crew/profiles/reviewers/@r.Name">@r.DisplayName</a>
                        @if (r.IsSystem) { <span class="crew-badge">System</span> }
                    </li>
                }
            </ul>
        }
        <a href="/crew/profiles/reviewers" class="view-all-link">View all reviewer profiles →</a>
    </section>

    <section class="crew-section">
        <div class="crew-section-header">
            <h2>Executor Profiles</h2>
            <a href="/crew/profiles/executors/new" class="btn small">+ New</a>
        </div>
        @if (_executors.Count == 0)
        {
            <p class="text-muted">No executor profiles yet.</p>
        }
        else
        {
            <ul class="crew-item-list">
                @foreach (var e in _executors.Take(5))
                {
                    <li>
                        <a href="/crew/profiles/executors/@e.Name">@e.DisplayName</a>
                        @if (e.IsSystem) { <span class="crew-badge">System</span> }
                    </li>
                }
            </ul>
        }
        <a href="/crew/profiles/executors" class="view-all-link">View all executor profiles →</a>
    </section>

    <section class="crew-section">
        <div class="crew-section-header">
            <h2>Advisor Profiles</h2>
            <a href="/crew/profiles/advisors/new" class="btn small">+ New</a>
        </div>
        @if (_advisors.Count == 0)
        {
            <p class="text-muted">No advisor profiles yet.</p>
        }
        else
        {
            <ul class="crew-item-list">
                @foreach (var a in _advisors.Take(5))
                {
                    <li>
                        <a href="/crew/profiles/advisors/@a.Name">@a.DisplayName</a>
                        @if (a.IsSystem) { <span class="crew-badge">System</span> }
                    </li>
                }
            </ul>
        }
        <a href="/crew/profiles/advisors" class="view-all-link">View all advisor profiles →</a>
    </section>

    <section class="crew-section" data-testid="grounding-providers-section">
        <div class="crew-section-header">
            <h2>Grounding Providers</h2>
            <a href="/crew/profiles/grounding-providers/create" class="btn small">+ New</a>
        </div>
        @if (_groundingProviders.Count == 0)
        {
            <p class="text-muted">No grounding provider profiles yet.</p>
        }
        else
        {
            <ul class="crew-item-list">
                @foreach (var g in _groundingProviders.Take(5))
                {
                    <li>
                        <a href="/crew/profiles/grounding-providers/view/@g.Name">@g.DisplayName</a>
                        @if (g.IsSystem) { <span class="crew-badge">System</span> }
                    </li>
                }
            </ul>
        }
        <a href="/crew/profiles/grounding-providers" class="view-all-link">View all grounding providers →</a>
    </section>

    <section class="crew-section" data-testid="knowledge-base-section">
        <div class="crew-section-header">
            <h2>Knowledge Base</h2>
            <a href="/crew/knowledge" class="btn small">Manage</a>
        </div>
        <p class="text-muted">Manage documents for semantic search grounding.</p>
        <a href="/crew/knowledge" class="view-all-link">Go to Knowledge Base →</a>
    </section>
</div>

@code {
    private IReadOnlyList<CrewTemplate> _templates = [];
    private IReadOnlyList<ReviewerProfile> _reviewers = [];
    private IReadOnlyList<ExecutorProfile> _executors = [];
    private IReadOnlyList<AdvisorProfile> _advisors = [];
    private IReadOnlyList<GroundingProviderProfile> _groundingProviders = [];

    protected override async Task OnInitializedAsync()
    {
        _templates = await CrewService.ListCrewTemplatesAsync(includeSystem: true);
        _reviewers = await CrewService.ListReviewerProfilesAsync(includeSystem: true);
        _executors = await CrewService.ListExecutorProfilesAsync(includeSystem: true);
        _advisors = await CrewService.ListAdvisorProfilesAsync(includeSystem: true);
        _groundingProviders = await CrewService.ListGroundingProviderProfilesAsync(includeSystem: true);
    }
}
