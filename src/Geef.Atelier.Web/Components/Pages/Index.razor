@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IRunService RunService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider
@using Geef.Atelier.Core.Domain

<PageTitle>Atelier — Geef.Atelier</PageTitle>

<div class="welcome">
    <div class="welcome-hero">
        <h1>
            A briefing well-given<br />
            is half the <em>manuscript</em>.
        </h1>
        <div class="meta">
            <div class="greeting">@_greeting · Atelier open</div>
        </div>
    </div>

    <div class="welcome-cta">
        <a class="cta-card" href="/new">
            <div class="glyph-stamp" aria-hidden="true">¶</div>
            <div class="t-eyebrow eyebrow">Begin</div>
            <h2>Hand the crew a new briefing</h2>
            <p>
                Describe what should be written and to whom. The crew will draft, review,
                revise — and return when it converges or after three iterations.
            </p>
            <div class="arrow">⟶ Open the form</div>
        </a>
        <div class="welcome-side">
            @if (_isAdmin)
            {
                <label class="admin-toggle">
                    <input type="checkbox" @bind="_showAll" @bind:after="LoadAdminViewAsync" />
                    Alle Benutzer / system-weit anzeigen
                </label>
            }
            <div class="stat-tile" data-testid="stat-runs-this-month">
                <div class="label">This month</div>
                <div class="value">@(_stats?.RunsThisMonth.ToString() ?? "—")</div>
                <div class="delta">runs</div>
            </div>
            <div class="stat-tile" data-testid="stat-convergence-rate">
                <div class="label">Convergence rate</div>
                <div class="value">@FormatRate(_stats?.ConvergenceRate)</div>
                <div class="delta">completed runs</div>
            </div>
            <div class="stat-tile" data-testid="stat-cost-this-month">
                <div class="label">Cost this month</div>
                <div class="value">@FormatCost(_stats?.TotalCostThisMonth)</div>
                <div class="delta">LLM + research</div>
            </div>
            <div class="stat-tile" data-testid="stat-studio-analyses">
                <div class="label">Studio analyses</div>
                <div class="value">@(_stats?.StudioAnalysesThisMonth.ToString() ?? "—")</div>
                <div class="delta">this month</div>
            </div>
        </div>
    </div>

    <div>
        <div class="t-eyebrow eyebrow" style="margin-bottom:6px">The workbench</div>
        <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px">
            <h2 style="font-family:var(--font-display);font-weight:300;font-size:28px;letter-spacing:-0.012em;margin:0">
                Recent work
            </h2>
            <a href="/runs" style="font-family:var(--font-mono);font-size:11px;color:var(--ink-3);letter-spacing:.06em">
                ALL RUNS ⟶
            </a>
        </div>
        @if (_recentRuns is null)
        {
            <div class="recent-list">
                <EmptyState Message="Loading…" />
            </div>
        }
        else if (_recentRuns.Count == 0)
        {
            <div class="recent-list">
                <EmptyState Message="No runs yet — hand the crew your first briefing." />
            </div>
        }
        else
        {
            <div class="recent-list">
                @foreach (var run in _recentRuns)
                {
                    <div class="recent-row" @onclick="@(() => Nav.NavigateTo("/runs/" + run.Id))" role="button" tabindex="0">
                        <div class="when">@TimeAgo(run.CreatedAt)</div>
                        <div class="briefing-snip">@Truncate(run.BriefingText, 70)</div>
                        <div class="meta t-mono">@(run.TokensTotal > 0 ? run.TokensTotal.ToString("N0") + " tok" : "—")</div>
                        <StatusBadge Status="run.Status" />
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    IReadOnlyList<RunEntity>? _recentRuns;
    WelcomeStats? _stats;
    string _greeting = string.Empty;
    bool _isAdmin;
    string? _currentUsername;
    bool _showAll;

    protected override async Task OnInitializedAsync()
    {
        var auth     = await AuthProvider.GetAuthenticationStateAsync();
        _isAdmin         = auth.User.IsInRole("admin");
        _currentUsername = auth.User.Identity?.Name;

        await LoadAdminViewAsync();
        _greeting   = DateTime.Now.ToString("dddd · HH:mm");
    }

    // Admin defaults to their own view; the toggle opts into the system-wide /
    // all-users view for both the recent-runs list and the stats tiles at once.
    async Task LoadAdminViewAsync()
    {
        var username = (_showAll && _isAdmin) ? null : _currentUsername;
        _recentRuns = await RunService.ListRunsAsync(5, requestingUsername: username);
        _stats      = await RunService.GetWelcomeStatsAsync(requestingUsername: username, CancellationToken.None);
    }

    static string TimeAgo(DateTimeOffset dt)
    {
        var diff = DateTimeOffset.UtcNow - dt;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalHours < 1)   return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1)    return $"{(int)diff.TotalHours}h ago";
        return $"{(int)diff.TotalDays}d ago";
    }

    static string Truncate(string s, int max) =>
        s.Length > max ? s[..max] + "…" : s;

    static string FormatRate(double? rate) =>
        rate.HasValue ? $"{rate.Value:P0}" : "—";

    static string FormatCost(decimal? eur)
    {
        if (!eur.HasValue || eur.Value == 0m) return "—";
        if (eur.Value < 0.01m) return $"~€{eur.Value:F4}";
        return $"€{eur.Value:F2}";
    }
}
