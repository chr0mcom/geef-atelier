@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@implements IAsyncDisposable
@inject IDashboardService DashboardService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IHttpContextAccessor Http
@using Geef.Atelier.Application.Dashboard
@using Geef.Atelier.Core.Domain.Dashboard
@using Microsoft.AspNetCore.SignalR.Client

<PageTitle>Workshop — Geef.Atelier</PageTitle>

@if (_snapshot is null)
{
    <div class="dash-loading">Loading workshop…</div>
}
else
{
    <div class="dashboard">

        <WelcomeStrip Data="_snapshot.WelcomeStrip" />

        @if (_isAdmin)
        {
            <div class="dash-scope-bar">
                <button class="scope-btn @(_scope == DashboardScope.My  ? "active" : "")"
                        @onclick="@(() => SetScopeAsync(DashboardScope.My))">My Workshop</button>
                <button class="scope-btn @(_scope == DashboardScope.All ? "active" : "")"
                        @onclick="@(() => SetScopeAsync(DashboardScope.All))">All Workshops</button>
            </div>
        }

        <div class="dash-section dash-3col">
            <LivePressStatus Data="_snapshot.Press" />
            <LedgerStats Data="_snapshot.Ledger" />
            <ActivityCalendar Data="_snapshot.Heatmap" />
        </div>

        <div class="dash-section dash-3col">
            <CrewDnaWidget Data="_snapshot.CrewDna" />
            <CostForgeSankey Data="_snapshot.CostForge" />
            <IterationSweetSpot Data="_snapshot.SweetSpot" />
        </div>

        <div class="dash-section dash-2col-gallery">
            <ManuscriptsGallery Data="_snapshot.Manuscripts" />
        </div>

        <div class="dash-section dash-3col">
            <TokenStreamWidget Data="_snapshot.TokenStream" />
            <CriticsBenchMatrix Data="_snapshot.CriticsBench" />
            <ProviderBenchWidget Data="_snapshot.ProviderBench" />
        </div>

        <div class="dash-section dash-3col">
            <KnowledgeBaseWidget Data="_snapshot.KnowledgeBase" />
            <DayBookStream Data="_liveDayBook" />
        </div>

    </div>
}

@code {
    DashboardSnapshot?      _snapshot;
    List<DayBookEntry>      _liveDayBook = [];
    DashboardScope          _scope       = DashboardScope.My;
    bool                    _isAdmin;
    string                  _username    = string.Empty;
    HubConnection?          _hub;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        _isAdmin  = auth.User.IsInRole("admin");
        _username = auth.User.Identity?.Name ?? string.Empty;

        // Read scope from cookie (only available during SSR pass)
        var scopeCookie = Http.HttpContext?.Request.Cookies["Atelier.DashboardScope"];
        _scope = (scopeCookie == "all" && _isAdmin) ? DashboardScope.All : DashboardScope.My;

        await LoadSnapshotAsync();
        await InitHubAsync();
    }

    async Task LoadSnapshotAsync()
    {
        if (string.IsNullOrEmpty(_username)) return;
        _snapshot    = await DashboardService.GetSnapshotAsync(_username, _isAdmin, _scope);
        _liveDayBook = [.._snapshot.DayBook];
    }

    async Task SetScopeAsync(DashboardScope newScope)
    {
        if (_scope == newScope) return;
        await LeaveHubGroupsAsync();
        _scope = newScope;
        await JS.InvokeVoidAsync("window.atelier.setDashboardScope",
            newScope == DashboardScope.All ? "all" : "my");
        await LoadSnapshotAsync();
        await JoinHubGroupsAsync();
        StateHasChanged();
    }

    async Task InitHubAsync()
    {
        _hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/runs"))
            .WithAutomaticReconnect()
            .Build();

        _hub.On<DashboardEvent>("DashboardUpdated", async evt =>
        {
            if (evt.Kind == DashboardEventKind.PressUpdated)
            {
                // Cache already invalidated by notifier; fresh fetch
                if (!string.IsNullOrEmpty(_username))
                {
                    _snapshot    = await DashboardService.GetSnapshotAsync(_username, _isAdmin, _scope);
                    _liveDayBook = _liveDayBook.Count > 0 ? _liveDayBook : [.._snapshot.DayBook];
                }
            }
            else if (evt.Kind == DashboardEventKind.DayBookUpdated && evt.DayBookEntry is { } entry)
            {
                _liveDayBook.Insert(0, entry);
                if (_liveDayBook.Count > 12)
                    _liveDayBook.RemoveAt(_liveDayBook.Count - 1);
            }

            await InvokeAsync(StateHasChanged);
        });

        _hub.Reconnected += async _ =>
        {
            await JoinHubGroupsAsync();
            await LoadSnapshotAsync();
            await InvokeAsync(StateHasChanged);
        };

        await _hub.StartAsync();
        await JoinHubGroupsAsync();
    }

    async Task JoinHubGroupsAsync()
    {
        if (_hub?.State != HubConnectionState.Connected || string.IsNullOrEmpty(_username))
            return;
        await _hub.SendAsync("JoinDashboardGroupAsync", _username);
        if (_isAdmin && _scope == DashboardScope.All)
            await _hub.SendAsync("JoinDashboardAllGroupAsync");
    }

    async Task LeaveHubGroupsAsync()
    {
        if (_hub?.State != HubConnectionState.Connected || string.IsNullOrEmpty(_username))
            return;
        try { await _hub.SendAsync("LeaveDashboardGroupAsync", _username); } catch { }
        try { await _hub.SendAsync("LeaveDashboardAllGroupAsync"); } catch { }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null)
        {
            await LeaveHubGroupsAsync();
            await _hub.DisposeAsync();
        }
    }
}
