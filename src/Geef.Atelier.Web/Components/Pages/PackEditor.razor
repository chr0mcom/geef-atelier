@page "/packs/create"
@page "/packs/edit/{Name}"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Geef.Atelier.Core.Domain.Crew
@using Geef.Atelier.Core.Domain.Crew.Specialization
@using Geef.Atelier.Web.Services
@inject ISpecializationPackService PackService
@inject NavigationManager Nav

<PageTitle>@(IsNew ? "New pack" : $"Edit: {_form.DisplayName}") — Atelier</PageTitle>

<div class="crew-editor" data-testid="pack-editor">
    <div class="page-header">
        <h1>@(IsNew ? "New pack" : _readOnly ? _form.DisplayName : $"Edit: {_form.DisplayName}")</h1>
        <a href="/packs" class="btn ghost">← Back</a>
    </div>

    @if (_loading)
    {
        <p>Loading…</p>
    }
    else
    {
        @if (_readOnly)
        {
            <div class="info-banner">
                @(_isSystem
                    ? "This is a system pack and cannot be edited. Use \"Duplicate as custom\" in the list."
                    : "This pack is crew-bound (TaskBound) and is managed through its crew.")
            </div>
        }

        <EditForm Model="_form" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="error-banner" data-testid="editor-error">@_error</div>
            }

            <div class="template-meta-section">
                <h3>Basics</h3>

                <div class="field">
                    <label>Name (slug)</label>
                    <InputText @bind-Value="_form.Name" placeholder="my-pack"
                               disabled="@(!IsNew || _readOnly)" data-testid="input-name" />
                    @if (IsNew)
                    {
                        <small class="form-hint">Lowercase letters, digits and hyphens only. Saved as <code>custom-…</code>.</small>
                    }
                    <ValidationMessage For="() => _form.Name" />
                </div>

                <div class="field">
                    <label>Display name</label>
                    <InputText @bind-Value="_form.DisplayName" disabled="@_readOnly" data-testid="input-display-name" />
                    <ValidationMessage For="() => _form.DisplayName" />
                </div>

                <div class="field">
                    <label>Description</label>
                    <InputTextArea @bind-Value="_form.Description" rows="2" disabled="@_readOnly" data-testid="input-description" />
                </div>
            </div>

            <div class="template-meta-section">
                <h3>Specialization</h3>
                <p class="pipeline-stage-desc">The task-specific delta composed into the <code>{specialization}</code> slot of the generic actor prompt.</p>
                <div class="field">
                    <InputTextArea @bind-Value="_form.SpecializationText" rows="10"
                                   disabled="@_readOnly"
                                   style="font-family: var(--font-mono, monospace); font-size: 0.85rem;"
                                   data-testid="input-specialization-text" />
                    <ValidationMessage For="() => _form.SpecializationText" />
                </div>
            </div>

            <div class="template-meta-section">
                <h3>Scope &amp; binding</h3>

                <div class="field">
                    <label>Scope</label>
                    <InputSelect @bind-Value="_form.Scope" disabled="@_readOnly" data-testid="input-scope">
                        <option value="@PackScope.General">General — usable in any crew</option>
                        <option value="@PackScope.DomainScoped">Domain — only in crews of the same domain</option>
                    </InputSelect>
                </div>

                @if (_form.Scope == PackScope.DomainScoped)
                {
                    <div class="field">
                        <label>Domain</label>
                        <InputText @bind-Value="_form.Domain" placeholder="e.g. legal, academic, marketing"
                                   disabled="@_readOnly" data-testid="input-domain" />
                        <ValidationMessage For="() => _form.Domain" />
                    </div>
                }

                <div class="field">
                    <label>Applicable actor types</label>
                    <div class="checkbox-group" data-testid="actor-types-group">
                        @foreach (var t in _selectableActorTypes)
                        {
                            var type = t;
                            <label class="form-checkbox-label">
                                <input type="checkbox"
                                       checked="@_form.ActorTypes.Contains(type)"
                                       disabled="@_readOnly"
                                       @onchange="e => ToggleActorType(type, (bool)e.Value!)" />
                                @GetActorLabel(type)
                            </label>
                        }
                    </div>
                    <small class="form-hint">Empty or "All" = applies to every actor type.</small>
                </div>
            </div>

            @if (!_readOnly)
            {
                <div class="form-actions">
                    <button type="submit" class="btn primary" disabled="@_saving" data-testid="btn-save">
                        @(_saving ? "Saving…" : IsNew ? "Create" : "Save")
                    </button>
                    <button type="button" class="btn ghost" @onclick="NavigateBack">Cancel</button>
                    @if (!IsNew)
                    {
                        <button type="button" class="btn danger" @onclick="() => _showDeleteModal = true" data-testid="btn-delete">Delete</button>
                    }
                </div>
            }
            else
            {
                <div class="form-actions">
                    <button type="button" class="btn ghost" @onclick="NavigateBack">Back</button>
                </div>
            }
        </EditForm>

        @if (!IsNew && !_isSystem)
        {
            <div class="template-meta-section" data-testid="pack-lifecycle">
                <h3>Lifecycle</h3>

                @if (_referencingTemplates.Count > 0)
                {
                    <p class="form-hint">Referenced by: @string.Join(", ", _referencingTemplates)</p>
                }

                @if (_lifecycleConcerns is { Count: > 0 })
                {
                    <div class="alert alert-danger" data-testid="generality-concerns">
                        <strong>Generality review failed:</strong>
                        <ul>@foreach (var c in _lifecycleConcerns) { <li>@c</li> }</ul>
                    </div>
                }
                @if (_lifecycleInfo is not null)
                {
                    <div class="info-banner" data-testid="lifecycle-info">@_lifecycleInfo</div>
                }

                <div class="field">
                    <label>Target scope for promote/clone</label>
                    <InputSelect @bind-Value="_targetScope">
                        <option value="@PackScope.General">General</option>
                        <option value="@PackScope.DomainScoped">Domain</option>
                    </InputSelect>
                    @if (_targetScope == PackScope.DomainScoped)
                    {
                        <InputText @bind-Value="_targetDomain" placeholder="Target domain" />
                    }
                </div>

                <div class="form-actions">
                    <button type="button" class="btn" disabled="@_lifecycleBusy"
                            data-testid="btn-promote" @onclick="PromoteAsync">Promote (with generality review)</button>
                    <button type="button" class="btn" disabled="@_lifecycleBusy"
                            data-testid="btn-demote" @onclick="DemoteAsync">Demote to domain</button>
                </div>

                <div class="field" style="margin-top:0.75rem;">
                    <label>Clone-to-generalize — new name</label>
                    <InputText @bind-Value="_cloneName" placeholder="generalized-pack" />
                    <button type="button" class="btn" style="margin-top:0.4rem;" disabled="@_lifecycleBusy"
                            data-testid="btn-clone-generalize" @onclick="CloneToGeneralizeAsync">Clone &amp; generalize</button>
                </div>
            </div>
        }
    }
</div>

<DeleteConfirmationModal
    Show="_showDeleteModal"
    ItemName="@(Name ?? "")"
    ItemKind="Pack"
    OnConfirm="ExecuteDeleteAsync"
    OnCancel="() => _showDeleteModal = false" />

@code {
    [Parameter] public string? Name { get; set; }

    private bool IsNew => Name == null;
    private bool _isSystem;
    private bool _readOnly;
    private bool _loading = true;
    private bool _saving;
    private bool _showDeleteModal;
    private string? _error;

    private readonly PackActorType[] _selectableActorTypes =
    [
        PackActorType.Any, PackActorType.Executor, PackActorType.Reviewer,
        PackActorType.Advisor, PackActorType.Grounding, PackActorType.Finalizer
    ];

    private PackFormModel _form = new();

    // Lifecycle (promote/demote/clone)
    private IReadOnlyList<string> _referencingTemplates = [];
    private IReadOnlyList<string>? _lifecycleConcerns;
    private string? _lifecycleInfo;
    private bool _lifecycleBusy;
    private PackScope _targetScope = PackScope.General;
    private string? _targetDomain;
    private string _cloneName = "";

    protected override async Task OnInitializedAsync()
    {
        if (!IsNew)
        {
            var pack = await PackService.GetByNameAsync(Name!);
            if (pack == null) { Nav.NavigateTo("/packs"); return; }
            _isSystem = pack.IsSystem;
            _readOnly = pack.IsSystem || pack.Scope == PackScope.TaskBound;
            _form = PackFormModel.From(pack);
            if (!_isSystem)
                _referencingTemplates = await PackService.FindReferencingTemplatesAsync(pack.Name);
        }
        _loading = false;
    }

    private async Task PromoteAsync()
    {
        _lifecycleBusy = true; _lifecycleConcerns = null; _lifecycleInfo = null; _error = null;
        try
        {
            var review = await PackService.PromoteAsync(Name!, _targetScope, _targetDomain);
            if (review.Approved) Nav.NavigateTo("/packs");
            else _lifecycleConcerns = review.Concerns;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _lifecycleBusy = false; }
    }

    private async Task DemoteAsync()
    {
        _lifecycleBusy = true; _lifecycleConcerns = null; _lifecycleInfo = null; _error = null;
        try
        {
            await PackService.DemoteAsync(Name!, _targetDomain ?? "");
            Nav.NavigateTo("/packs");
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _lifecycleBusy = false; }
    }

    private async Task CloneToGeneralizeAsync()
    {
        _lifecycleBusy = true; _lifecycleConcerns = null; _lifecycleInfo = null; _error = null;
        try
        {
            var review = await PackService.CloneToGeneralizeAsync(Name!, _cloneName, _targetScope, _targetDomain);
            if (review.Approved) Nav.NavigateTo("/packs");
            else _lifecycleConcerns = review.Concerns;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _lifecycleBusy = false; }
    }

    private void ToggleActorType(PackActorType type, bool on)
    {
        if (on) { if (!_form.ActorTypes.Contains(type)) _form.ActorTypes.Add(type); }
        else _form.ActorTypes.Remove(type);
    }

    private void NavigateBack() => Nav.NavigateTo("/packs");

    private async Task SaveAsync()
    {
        _saving = true;
        _error = null;
        try
        {
            await PackService.SaveAsync(_form.ToPack());
            Nav.NavigateTo("/packs");
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private async Task ExecuteDeleteAsync()
    {
        _showDeleteModal = false;
        _error = null;
        try
        {
            await PackService.DeleteAsync(Name!);
            Nav.NavigateTo("/packs");
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private static string GetActorLabel(PackActorType t) => t switch
    {
        PackActorType.Any        => "All",
        PackActorType.Executor   => "Executor",
        PackActorType.Reviewer   => "Reviewer",
        PackActorType.Advisor    => "Advisor",
        PackActorType.Grounding  => "Grounding",
        PackActorType.Finalizer  => "Finalizer",
        _                        => t.ToString()
    };

    private sealed class PackFormModel
    {
        [Required(ErrorMessage = "Name is required.")]
        [RegularExpression(@"^[a-z0-9]([a-z0-9\-]*[a-z0-9])?$",
            ErrorMessage = "Lowercase letters, digits and hyphens only.")]
        [MaxLength(64)]
        public string Name { get; set; } = "";

        [Required(ErrorMessage = "Display name is required.")]
        [MaxLength(200)]
        public string DisplayName { get; set; } = "";

        [MaxLength(1000)]
        public string Description { get; set; } = "";

        [Required(ErrorMessage = "Specialization text is required.")]
        public string SpecializationText { get; set; } = "";

        public PackScope Scope { get; set; } = PackScope.General;

        [MaxLength(100)]
        public string? Domain { get; set; }

        public List<PackActorType> ActorTypes { get; set; } = [PackActorType.Any];

        // For round-tripping TaskBound metadata that the form does not edit.
        private string? _owningCrewId;
        private bool _archived;
        private DateTimeOffset? _createdAt;
        private DateTimeOffset? _lastUsedAt;

        public static PackFormModel From(SpecializationPack p) => new()
        {
            Name = p.Name,
            DisplayName = p.DisplayName,
            Description = p.Description,
            SpecializationText = p.SpecializationText,
            Scope = p.Scope,
            Domain = p.Domain,
            ActorTypes = p.ApplicableActorTypes.Count > 0 ? p.ApplicableActorTypes.ToList() : [PackActorType.Any],
            _owningCrewId = p.OwningCrewId,
            _archived = p.Archived,
            _createdAt = p.CreatedAt,
            _lastUsedAt = p.LastUsedAt,
        };

        public SpecializationPack ToPack()
        {
            var now = DateTimeOffset.UtcNow;
            var actorTypes = ActorTypes.Count > 0 ? ActorTypes : [PackActorType.Any];
            return new SpecializationPack(
                Name: SystemCrew.EnsureCustomPrefix(Name),
                DisplayName: DisplayName,
                Description: Description,
                SpecializationText: SpecializationText,
                Scope: Scope,
                Domain: Scope == PackScope.DomainScoped ? Domain : null,
                ApplicableActorTypes: actorTypes,
                OwningCrewId: Scope == PackScope.TaskBound ? _owningCrewId : null,
                IsSystem: false,
                Archived: _archived,
                CreatedAt: _createdAt ?? now,
                UpdatedAt: now,
                LastUsedAt: _lastUsedAt);
        }
    }
}
