@page "/crew/profiles/finalizers/create"
@page "/crew/profiles/finalizers/edit/{name}"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Geef.Atelier.Application.Crew
@using Geef.Atelier.Application.Providers
@using Geef.Atelier.Core.Domain.Crew.Finalizers
@using Geef.Atelier.Core.Domain.Providers
@using Geef.Atelier.Web.Resources
@inject ICrewService CrewService
@inject IProviderService ProviderService
@inject NavigationManager Nav

<PageTitle>@(IsNew ? "New Finalizer" : "Edit Finalizer") — Atelier</PageTitle>

<div class="crew-editor" data-testid="finalizer-editor">
    <div class="page-header">
        <h1>@(IsNew ? "New Finalizer" : $"Edit: {_displayName}")</h1>
        <a href="/crew/profiles/finalizers" class="btn ghost">← Back</a>
    </div>

    @if (_loading)
    {
        <p>Loading…</p>
    }
    else
    {
        <EditForm Model="_form" OnValidSubmit="SaveAsync" class="crew-form">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="error-banner" data-testid="editor-error">@_error</div>
            }

            <div class="form-row">
                <label>Name (Slug)</label>
                <InputText @bind-Value="_form.Name" class="form-input" placeholder="export-pdf" data-testid="input-name" />
                <ValidationMessage For="() => _form.Name" />
                <small class="form-hint">Saved as <code>custom-…</code>. Lowercase letters, digits and hyphens only.</small>
            </div>

            <div class="form-row">
                <label>Display Name</label>
                <InputText @bind-Value="_form.DisplayName" class="form-input" placeholder="PDF Export" data-testid="input-display-name" />
                <ValidationMessage For="() => _form.DisplayName" />
            </div>

            <div class="form-row">
                <label>Description</label>
                <InputTextArea @bind-Value="_form.Description" class="form-input" rows="2" data-testid="input-description" />
            </div>

            <div class="form-row">
                <label>Finalizer Type</label>
                <InputSelect @bind-Value="_form.FinalizerType" disabled="@(!IsNew)" class="form-input" data-testid="input-finalizer-type">
                    <option value="@FinalizerType.FileExport">File Export</option>
                    <option value="@FinalizerType.MetadataEnrich">Metadata Enrichment</option>
                    <option value="@FinalizerType.ExternalSink">External Sink</option>
                    <option value="@FinalizerType.Transform">AI Transform</option>
                </InputSelect>
                @if (!IsNew)
                {
                    <small class="form-hint">The type cannot be changed after creation.</small>
                }
            </div>

            @switch (_form.FinalizerType)
            {
                case FinalizerType.FileExport:
                    <div class="form-section-header">Export Settings</div>
                    <div class="form-row">
                        <label>Format</label>
                        <InputSelect @bind-Value="_form.ExportFormat" class="form-input" data-testid="input-export-format">
                            <option value="markdown">Markdown (.md)</option>
                            <option value="html">HTML (.html)</option>
                            <option value="pdf">PDF (.pdf)</option>
                            <option value="docx">Word Document (.docx)</option>
                            <option value="txt">Plain Text (.txt)</option>
                            <option value="json">JSON (.json)</option>
                        </InputSelect>
                    </div>
                    break;

                case FinalizerType.MetadataEnrich:
                    <div class="form-section-header">Enrichment Settings</div>
                    <div class="form-row">
                        <label>Enrichment Type</label>
                        <InputSelect @bind-Value="_form.EnricherType" class="form-input" data-testid="input-enricher-type">
                            <option value="front-matter">Front Matter (YAML header)</option>
                            <option value="word-count-footer">Word Count Footer</option>
                            <option value="reading-level">Reading Level Estimate</option>
                        </InputSelect>
                    </div>
                    break;

                case FinalizerType.ExternalSink:
                    <div class="form-section-header">Sink Settings</div>
                    <div class="form-row">
                        <label>Sink Type</label>
                        <InputSelect @bind-Value="_form.SinkKind" class="form-input" data-testid="input-sink-kind">
                            <option value="webhook">Webhook (HTTP POST)</option>
                            <option value="email">Email (SMTP)</option>
                        </InputSelect>
                    </div>
                    @if (_form.SinkKind == "webhook")
                    {
                        <div class="form-row">
                            <label>Webhook URL</label>
                            <InputText @bind-Value="_form.WebhookUrl" class="form-input" placeholder="https://example.com/hook" data-testid="input-webhook-url" />
                        </div>
                        <div class="form-row">
                            <label>Auth Header (optional)</label>
                            <InputText @bind-Value="_form.WebhookAuthHeader" class="form-input" placeholder="Bearer <token>" data-testid="input-webhook-auth" />
                            <small class="form-hint">Stored in plain text in the database, never written to logs.</small>
                        </div>
                        <div class="form-row">
                            <label>Content-Type</label>
                            <InputText @bind-Value="_form.WebhookContentType" class="form-input" placeholder="application/json" data-testid="input-webhook-content-type" />
                        </div>
                        <div class="form-row">
                            <label>Timeout (seconds)</label>
                            <InputNumber @bind-Value="_form.WebhookTimeout" class="form-input" min="5" max="300" data-testid="input-webhook-timeout" />
                        </div>
                    }
                    else
                    {
                        <div class="form-row">
                            <label>Recipient Email</label>
                            <InputText @bind-Value="_form.EmailTo" class="form-input" placeholder="recipient@example.com" data-testid="input-email-to" />
                        </div>
                        <div class="form-row">
                            <label>Subject</label>
                            <InputText @bind-Value="_form.EmailSubject" class="form-input" placeholder="Geef.Atelier — Result" data-testid="input-email-subject" />
                        </div>
                        <div class="form-row">
                            <label class="form-checkbox-label">
                                <InputCheckbox @bind-Value="_form.EmailAttachAsFile" data-testid="input-email-attach" />
                                Send as attachment
                            </label>
                        </div>
                        @if (_form.EmailAttachAsFile)
                        {
                            <div class="form-row">
                                <label>Attachment Format</label>
                                <InputSelect @bind-Value="_form.EmailAttachmentFormat" class="form-input" data-testid="input-email-format">
                                    <option value="markdown">Markdown (.md)</option>
                                    <option value="html">HTML (.html)</option>
                                    <option value="pdf">PDF (.pdf)</option>
                                    <option value="docx">Word Document (.docx)</option>
                                    <option value="txt">Plain Text (.txt)</option>
                                </InputSelect>
                            </div>
                        }
                    }
                    break;

                case FinalizerType.Transform:
                    <div class="form-section-header">Transform Settings</div>
                    <div class="form-row">
                        <label>System Prompt</label>
                        <InputTextArea @bind-Value="_form.SystemPrompt" class="form-input" rows="6"
                            placeholder="Instructions for the AI transform…" data-testid="input-system-prompt" />
                        <small class="form-hint">Tip: end with "Respond in the language of the input text."</small>
                        <FieldHelp Text="@StudioFieldHelps.FinalizerTransformSystemPrompt" DataTestId="field-help-transform-system-prompt" />
                    </div>
                    <div class="field">
                        <label>Provider</label>
                        <select class="form-input"
                                value="@_form.TransformProvider"
                                @onchange="OnTransformProviderChanged"
                                disabled="@(!CanEdit)"
                                data-testid="input-transform-provider">
                            <optgroup label="HTTP">
                                @foreach (var p in _providers.Where(x => x.IsActive && x.Type == ProviderType.Http))
                                {
                                    <option value="@p.Name" selected="@(_form.TransformProvider == p.Name)">@p.DisplayName</option>
                                }
                            </optgroup>
                            <optgroup label="CLI">
                                @foreach (var p in _providers.Where(x => x.IsActive && x.Type == ProviderType.Cli))
                                {
                                    <option value="@p.Name" selected="@(_form.TransformProvider == p.Name)">@p.DisplayName</option>
                                }
                            </optgroup>
                        </select>
                        <FieldHelp Text="@FinalizerFieldHelps.TransformProvider" DataTestId="field-help-transform-provider" />
                    </div>
                    <div class="field">
                        <label>Model</label>
                        <ModelSelector Provider="@_form.TransformProvider"
                                       @bind-Value="_form.TransformModel"
                                       Disabled="@(!CanEdit)"
                                       DataTestId="input-transform-model" />
                        <FieldHelp Text="@FinalizerFieldHelps.TransformModel" DataTestId="field-help-transform-model" />
                    </div>
                    <div class="field">
                        <label>Max Tokens</label>
                        <InputNumber @bind-Value="_form.TransformMaxTokens" class="form-input" min="1024" max="64000" data-testid="input-transform-max-tokens" />
                        <FieldHelp Text="@FinalizerFieldHelps.TransformMaxTokens" DataTestId="field-help-transform-max-tokens" />
                    </div>
                    <div class="field">
                        <label>Temperature <span class="text-muted">(optional)</span></label>
                        <input type="number" class="form-input"
                               step="0.1" min="0" max="2"
                               value="@(_form.TransformTemperature?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                               @onchange="OnTemperatureChanged"
                               disabled="@(!CanEdit)"
                               data-testid="input-transform-temperature"
                               placeholder="empty = provider default" />
                        <FieldHelp Text="@FinalizerFieldHelps.TransformTemperature" DataTestId="field-help-transform-temperature" />
                    </div>
                    break;
            }

            <div class="form-actions">
                <button type="submit" class="btn primary" data-testid="btn-save">
                    @(IsNew ? "Create" : "Save")
                </button>
                <a href="/crew/profiles/finalizers" class="btn ghost">Cancel</a>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter] public string? Name { get; set; }

    private bool IsNew => string.IsNullOrEmpty(Name);
    private bool CanEdit => IsNew || !_form.IsSystem;
    private bool _loading = true;
    private string _displayName = string.Empty;
    private string? _error;
    private FinalizerFormModel _form = new();
    private IReadOnlyList<Provider> _providers = [];

    protected override async Task OnInitializedAsync()
    {
        _providers = await ProviderService.ListAsync(includeInactive: false);

        if (!IsNew && Name is not null)
        {
            var existing = await CrewService.GetFinalizerProfileAsync(Name);
            if (existing is null)
            {
                Nav.NavigateTo("/crew/profiles/finalizers");
                return;
            }
            _displayName = existing.DisplayName;
            _form = FinalizerFormModel.From(existing);
        }
        _loading = false;
    }

    private void OnTransformProviderChanged(ChangeEventArgs e)
    {
        _form.TransformProvider = e.Value?.ToString() ?? "";
        _form.TransformModel = "";
    }

    private void OnTemperatureChanged(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(raw))
            _form.TransformTemperature = null;
        else if (double.TryParse(raw, System.Globalization.NumberStyles.Any,
                 System.Globalization.CultureInfo.InvariantCulture, out var t))
            _form.TransformTemperature = t;
    }

    private async Task SaveAsync()
    {
        _error = null;
        try
        {
            var profile = _form.ToProfile();
            if (IsNew)
                await CrewService.CreateCustomFinalizerProfileAsync(profile);
            else
                await CrewService.UpdateCustomFinalizerProfileAsync(profile);

            Nav.NavigateTo("/crew/profiles/finalizers");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private sealed class FinalizerFormModel
    {
        [Required(ErrorMessage = "Name is required.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Display name is required.")]
        public string DisplayName { get; set; } = string.Empty;

        public string Description { get; set; } = string.Empty;
        public FinalizerType FinalizerType { get; set; } = FinalizerType.FileExport;

        // FileExport
        public string ExportFormat { get; set; } = "markdown";

        // MetadataEnrich
        public string EnricherType { get; set; } = MetadataEnrichSettings.FrontMatter;

        // ExternalSink
        public string SinkKind { get; set; } = WebhookSinkSettings.SinkKindValue;

        [Url(ErrorMessage = "Please enter a valid URL.")]
        public string WebhookUrl { get; set; } = string.Empty;

        public string WebhookAuthHeader { get; set; } = string.Empty;
        public string WebhookContentType { get; set; } = "application/json";
        public int WebhookTimeout { get; set; } = 30;

        [EmailAddress(ErrorMessage = "Please enter a valid email address.")]
        public string EmailTo { get; set; } = string.Empty;

        public string EmailSubject { get; set; } = "Geef.Atelier — Result";
        public bool EmailAttachAsFile { get; set; } = false;
        public string EmailAttachmentFormat { get; set; } = "markdown";

        public bool IsSystem { get; set; } = false;

        // Transform
        [Required(ErrorMessage = "System prompt is required.")]
        public string SystemPrompt { get; set; } = string.Empty;

        public string TransformProvider { get; set; } = "codex-cli";
        public string TransformModel { get; set; } = "gpt-5.5";
        public int TransformMaxTokens { get; set; } = 4096;
        public double? TransformTemperature { get; set; } = null;

        public static FinalizerFormModel From(FinalizerProfile p)
        {
            var m = new FinalizerFormModel
            {
                Name = p.Name,
                DisplayName = p.DisplayName,
                Description = p.Description,
                FinalizerType = p.FinalizerType,
                IsSystem = p.IsSystem,
            };
            switch (p.FinalizerType)
            {
                case FinalizerType.FileExport:
                    var fe = FileExportSettings.From(p.Settings);
                    m.ExportFormat = fe.Format;
                    break;
                case FinalizerType.MetadataEnrich:
                    var me = MetadataEnrichSettings.From(p.Settings);
                    m.EnricherType = me.EnricherType;
                    break;
                case FinalizerType.ExternalSink:
                    var sk = p.Settings.GetValueOrDefault(WebhookSinkSettings.KeySinkKind, WebhookSinkSettings.SinkKindValue);
                    m.SinkKind = sk;
                    if (sk == EmailSinkSettings.SinkKindValue)
                    {
                        var es = EmailSinkSettings.From(p.Settings);
                        m.EmailTo = es.ToAddress;
                        m.EmailSubject = es.Subject;
                        m.EmailAttachAsFile = es.AttachAsFile;
                        m.EmailAttachmentFormat = es.AttachmentFormat;
                    }
                    else
                    {
                        var ws = WebhookSinkSettings.From(p.Settings);
                        m.WebhookUrl = ws.Url;
                        m.WebhookAuthHeader = ws.AuthHeader ?? string.Empty;
                        m.WebhookContentType = ws.ContentType;
                        m.WebhookTimeout = ws.TimeoutSeconds;
                    }
                    break;
                case FinalizerType.Transform:
                    var ts = TransformSettings.From(p.Settings);
                    m.SystemPrompt = ts.SystemPrompt;
                    m.TransformProvider = ts.Provider;
                    m.TransformModel = ts.Model;
                    m.TransformMaxTokens = ts.MaxTokens;
                    m.TransformTemperature = ts.Temperature;
                    break;
            }
            return m;
        }

        public FinalizerProfile ToProfile()
        {
            var settings = FinalizerType switch
            {
                FinalizerType.FileExport =>
                    new FileExportSettings(ExportFormat).ToDict(),
                FinalizerType.MetadataEnrich =>
                    new MetadataEnrichSettings(EnricherType).ToDict(),
                FinalizerType.ExternalSink when SinkKind == EmailSinkSettings.SinkKindValue =>
                    new EmailSinkSettings(EmailTo, EmailSubject, EmailAttachAsFile, EmailAttachmentFormat).ToDict(),
                FinalizerType.ExternalSink =>
                    new WebhookSinkSettings(
                        WebhookUrl,
                        string.IsNullOrWhiteSpace(WebhookAuthHeader) ? null : WebhookAuthHeader,
                        WebhookContentType,
                        WebhookTimeout).ToDict(),
                FinalizerType.Transform =>
                    new TransformSettings(SystemPrompt, TransformProvider, TransformModel, TransformMaxTokens, TransformTemperature).ToDict(),
                _ => [],
            };
            return new FinalizerProfile(
                Name: Name,
                DisplayName: DisplayName,
                Description: Description,
                FinalizerType: FinalizerType,
                Settings: settings,
                IsSystem: false);
        }
    }
}
