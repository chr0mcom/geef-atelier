@page "/crew/templates/new"
@page "/crew/templates/{name}"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Geef.Atelier.Application.Crew
@using Geef.Atelier.Core.Domain.Crew
@using Geef.Atelier.Core.Domain.Crew.Advisors
@using Geef.Atelier.Core.Domain.Crew.Finalizers
@using Geef.Atelier.Core.Domain.Crew.Grounding
@using Geef.Atelier.Core.Domain.Crew.Profiles
@using Geef.Atelier.Infrastructure.Configuration
@using Microsoft.Extensions.Options
@inject ICrewService CrewService
@inject IOptions<ConvergenceOptions> ConvergenceOpts
@inject NavigationManager Nav

<PageTitle>@(IsNew ? "New Template" : "Edit Template") — Atelier</PageTitle>

<div class="crew-editor" data-testid="template-editor">
    <div class="page-header">
        <h1>@(IsNew ? "New Template" : _isSystem ? _displayName : $"Edit: {_displayName}")</h1>
        <a href="/crew/templates" class="btn ghost">← Back</a>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="error-banner">@_error</div>
    }

    @if (_loading)
    {
        <p>Loading…</p>
    }
    else
    {
        <EditForm Model="_form" OnValidSubmit="SaveAsync" data-testid="template-editor-form">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="edit-section">
            <h3>Grunddaten</h3>

            <div class="field">
                <label>Name</label>
                <InputText @bind-Value="_form.Name" disabled="@_isSystem" placeholder="my-template" />
                @if (!_isSystem && !string.IsNullOrEmpty(_form.Name))
                {
                    <small>Will be saved as: custom-@_form.Name.TrimStart("custom-".ToCharArray())</small>
                }
            </div>

            <div class="field">
                <label>Display Name</label>
                <InputText @bind-Value="_form.DisplayName" />
            </div>

            <div class="field">
                <label>Description</label>
                <InputTextArea @bind-Value="_form.Description" rows="3" />
            </div>
            </div>

            <div class="edit-section">
            <h3>Crew-Zusammenstellung</h3>

            <div class="field">
                <label>Executor Profile</label>
                <InputSelect @bind-Value="_form.ExecutorProfileName" disabled="@_isSystem">
                    @foreach (var e in _executors)
                    {
                        <option value="@e.Name">@e.DisplayName @(e.IsSystem ? "(System)" : "")</option>
                    }
                </InputSelect>
            </div>

            <div class="field">
                <label>Grounding Providers</label>
                <GroundingProviderPicker AllProfiles="_groundingProviderProfiles"
                                        Selected="_form.GroundingProviderNames"
                                        SelectedChanged="names => _form.GroundingProviderNames = names" />
            </div>

            <div class="field">
                <label>Finalizer (optionale Pipeline nach dem Run)</label>
                <FinalizerPicker AllProfiles="_finalizerProfiles"
                                 Selected="_form.FinalizerProfileNames"
                                 SelectedChanged="names => _form.FinalizerProfileNames = names" />
            </div>

            @if (_form.FinalizerProfileNames.Count > 0)
            {
                <div class="field">
                    <label class="form-checkbox-label">
                        <InputCheckbox @bind-Value="_form.RunFinalizersOnMaxAttempts" data-testid="run-finalizers-on-max-attempts" />
                        Finalizer auch bei MaxIterations ausführen
                    </label>
                    <small class="form-hint">Wenn aktiviert, werden Finalizer auch dann ausgeführt, wenn die Pipeline nicht konvergiert. Der Run wird als abgeschlossen markiert, nicht als fehlgeschlagen.</small>
                </div>
            }

            <div class="field">
                <label>Advisors</label>
                <AdvisorPicker AllProfiles="_advisorProfiles"
                               Selected="_form.AdvisorProfileNames"
                               SelectedChanged="names => _form.AdvisorProfileNames = names" />
            </div>

            <div class="field">
                <label>Reviewers</label>
                <ReviewerPicker AllProfiles="_reviewers"
                                Selected="_form.ReviewerProfileNames"
                                SelectedChanged="names => _form.ReviewerProfileNames = names" />
            </div>
            </div>

            <div class="edit-section">
            <h3>Auswertung</h3>

            <div class="field">
                <label>Evaluation Strategy</label>
                <div class="radio-group">
                    @foreach (var strategy in Enum.GetValues<EvaluationStrategy>())
                    {
                        <label class="radio-option">
                            <input type="radio" name="strategy"
                                   value="@strategy"
                                   checked="@(_form.EvaluationStrategy == strategy)"
                                   @onchange="() => _form.EvaluationStrategy = strategy"
                                   disabled="@_isSystem" />
                            @strategy.ToString()
                        </label>
                    }
                </div>
            </div>
            </div>

            <details class="collapsible-section">
                <summary class="collapsible-header">Advanced (Convergence Override)</summary>
                <div class="collapsible-body">
                    <p class="field-hint">Pre-filled with the global defaults. A value is only stored as a per-template override when you change it away from the default.</p>
                    <div class="field">
                        <label>Max Iterations</label>
                        <InputNumber @bind-Value="_form.MaxIterations" data-testid="advanced-max-iterations" />
                    </div>
                    <div class="field">
                        <label>Abort on Critical</label>
                        <InputCheckbox @bind-Value="_form.AbortOnCritical" data-testid="advanced-abort-on-critical" />
                    </div>
                    <div class="field">
                        <label>Detect Regression</label>
                        <InputCheckbox @bind-Value="_form.DetectRegression" data-testid="advanced-detect-regression" />
                    </div>
                    <div class="field">
                        <label>Stagnation Threshold</label>
                        <InputNumber @bind-Value="_form.StagnationThreshold" data-testid="advanced-stagnation-threshold" />
                    </div>
                    <div class="field">
                        <label>Max Elapsed Minutes (Zeitbudget)</label>
                        <InputNumber @bind-Value="_form.MaxElapsedMinutes" data-testid="advanced-max-elapsed-minutes" />
                        <p class="field-hint">Wall-Clock-Limit des gesamten Runs. Wird es überschritten, stoppt der Run (auch wenn die Iterationszahl noch nicht erreicht ist). Für sehr lange Runs erhöhen.</p>
                    </div>
                </div>
            </details>

            @if (!_isSystem)
            {
                <div class="editor-actions">
                    <button type="submit" class="btn primary" data-testid="save-template" disabled="@_saving">
                        @(_saving ? "Saving…" : "Save")
                    </button>
                    <a href="/crew/templates" class="btn ghost">Cancel</a>
                    @if (!IsNew)
                    {
                        <button type="button" class="btn danger" @onclick="() => _showDeleteModal = true">Delete</button>
                    }
                </div>
            }
            else
            {
                <div class="editor-actions">
                    <button type="button" class="btn primary" @onclick="DuplicateAsCustom">Duplicate as custom</button>
                    <a href="/crew/templates" class="btn ghost">Cancel</a>
                </div>
            }
        </EditForm>
    }
</div>

<DeleteConfirmationModal
    Show="_showDeleteModal"
    ItemName="@(Name ?? "")"
    ItemKind="Template"
    ExtraWarning="Templates are preserved in historical runs as a snapshot — this delete only affects future submits."
    OnConfirm="ExecuteDeleteAsync"
    OnCancel="() => _showDeleteModal = false" />

@code {
    [Parameter] public string? Name { get; set; }

    private bool IsNew => Name == null;
    private bool _isSystem;
    private bool _loading = true;
    private bool _saving;
    private bool _showDeleteModal;
    private string? _error;
    private string _displayName = "";

    private IReadOnlyList<ReviewerProfile> _reviewers = [];
    private IReadOnlyList<ExecutorProfile> _executors = [];
    private IReadOnlyList<AdvisorProfile> _advisorProfiles = [];
    private IReadOnlyList<GroundingProviderProfile> _groundingProviderProfiles = [];
    private IReadOnlyList<FinalizerProfile> _finalizerProfiles = [];

    private TemplateFormModel _form = new();

    protected override async Task OnInitializedAsync()
    {
        _reviewers = await CrewService.ListReviewerProfilesAsync(includeSystem: true);
        _executors = await CrewService.ListExecutorProfilesAsync(includeSystem: true);
        _advisorProfiles = await CrewService.ListAdvisorProfilesAsync(includeSystem: true);
        _groundingProviderProfiles = await CrewService.ListGroundingProviderProfilesAsync(includeSystem: true);
        _finalizerProfiles = await CrewService.ListFinalizerProfilesAsync(includeSystem: true);

        var defaults = ConvergenceOpts.Value;
        if (!IsNew)
        {
            var template = await CrewService.GetCrewTemplateAsync(Name!);
            if (template == null) { Nav.NavigateTo("/crew/templates"); return; }
            _isSystem = template.IsSystem;
            _displayName = template.DisplayName;
            _form = TemplateFormModel.FromTemplate(template, defaults);
        }
        else
        {
            _form.ExecutorProfileName = _executors.FirstOrDefault()?.Name ?? "";
            _form.ApplyConvergenceDefaults(defaults);
        }

        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _error = null;
        try
        {
            var template = _form.ToTemplate(ConvergenceOpts.Value);
            if (IsNew)
            {
                await CrewService.CreateCustomCrewTemplateAsync(template);
            }
            else
            {
                if (template.Name != Name)
                    await CrewService.RenameCustomCrewTemplateAsync(Name!, template.Name);
                await CrewService.UpdateCustomCrewTemplateAsync(template);
            }
            Nav.NavigateTo("/crew/templates");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DuplicateAsCustom()
    {
        _error = null;
        try
        {
            var original = await CrewService.GetCrewTemplateAsync(Name!);
            if (original == null) return;
            var copy = original with
            {
                Name = original.Name + "-copy",
                DisplayName = original.DisplayName + " (Copy)",
                IsSystem = false
            };
            await CrewService.CreateCustomCrewTemplateAsync(copy);
            Nav.NavigateTo("/crew/templates");
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task ExecuteDeleteAsync()
    {
        _showDeleteModal = false;
        _error = null;
        try
        {
            await CrewService.DeleteCustomCrewTemplateAsync(Name!);
            Nav.NavigateTo("/crew/templates");
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private sealed class TemplateFormModel
    {
        [Required, RegularExpression(@"^[a-z0-9\-]+$", ErrorMessage = "Only lowercase letters, numbers, and hyphens")]
        [MaxLength(64)]
        public string Name { get; set; } = "";

        [Required, MaxLength(200)]
        public string DisplayName { get; set; } = "";

        [MaxLength(1000)]
        public string Description { get; set; } = "";

        [Required]
        public string ExecutorProfileName { get; set; } = "";

        public List<string> AdvisorProfileNames { get; set; } = [];

        public List<string> ReviewerProfileNames { get; set; } = [];

        public List<string> GroundingProviderNames { get; set; } = [];

        public List<string> FinalizerProfileNames { get; set; } = [];
        public bool RunFinalizersOnMaxAttempts { get; set; } = false;

        public EvaluationStrategy EvaluationStrategy { get; set; } = EvaluationStrategy.Parallel;

        public int? MaxIterations { get; set; }
        public bool AbortOnCritical { get; set; }
        public bool DetectRegression { get; set; }
        public int? StagnationThreshold { get; set; }
        public int? MaxElapsedMinutes { get; set; }

        public static TemplateFormModel FromTemplate(CrewTemplate t, ConvergenceOptions d) => new()
        {
            Name = t.Name,
            DisplayName = t.DisplayName,
            Description = t.Description,
            ExecutorProfileName = t.ExecutorProfileName,
            AdvisorProfileNames = t.AdvisorProfileNames.ToList(),
            ReviewerProfileNames = t.ReviewerProfileNames.ToList(),
            GroundingProviderNames = t.GroundingProviderNames.ToList(),
            FinalizerProfileNames = (t.FinalizerProfileNames ?? []).ToList(),
            RunFinalizersOnMaxAttempts = t.RunFinalizersOnMaxAttempts,
            EvaluationStrategy = t.EvaluationStrategy,
            MaxIterations = t.ConvergenceOverride?.MaxIterations ?? d.MaxIterations,
            AbortOnCritical = t.ConvergenceOverride?.AbortOnCritical ?? d.AbortOnCritical,
            DetectRegression = t.ConvergenceOverride?.DetectRegression ?? d.DetectRegression,
            StagnationThreshold = t.ConvergenceOverride?.StagnationThreshold ?? d.StagnationThreshold,
            MaxElapsedMinutes = t.ConvergenceOverride?.MaxElapsedMinutes ?? d.MaxElapsedMinutes,
        };

        public void ApplyConvergenceDefaults(ConvergenceOptions d)
        {
            MaxIterations = d.MaxIterations;
            AbortOnCritical = d.AbortOnCritical;
            DetectRegression = d.DetectRegression;
            StagnationThreshold = d.StagnationThreshold;
            MaxElapsedMinutes = d.MaxElapsedMinutes;
        }

        public CrewTemplate ToTemplate(ConvergenceOptions d)
        {
            // Persist a per-field override only when it differs from the global default,
            // so untouched templates keep ConvergenceOverride = null and continue to
            // inherit future changes to the global convergence policy.
            int? mi = MaxIterations == d.MaxIterations ? null : MaxIterations;
            bool? ac = AbortOnCritical == d.AbortOnCritical ? null : AbortOnCritical;
            bool? dr = DetectRegression == d.DetectRegression ? null : DetectRegression;
            int? st = StagnationThreshold == d.StagnationThreshold ? null : StagnationThreshold;
            int? me = MaxElapsedMinutes == d.MaxElapsedMinutes ? null : MaxElapsedMinutes;

            ConvergencePolicyOverride? overr =
                mi is null && ac is null && dr is null && st is null && me is null
                    ? null
                    : new ConvergencePolicyOverride(mi, ac, dr, st, me);

            return new CrewTemplate(
                Name: SystemCrew.EnsureCustomPrefix(Name),
                DisplayName: DisplayName,
                Description: Description,
                ExecutorProfileName: ExecutorProfileName,
                ReviewerProfileNames: ReviewerProfileNames,
                EvaluationStrategy: EvaluationStrategy,
                ConvergenceOverride: overr,
                AdvisorProfileNames: AdvisorProfileNames,
                GroundingProviderNames: GroundingProviderNames,
                IsSystem: false,
                FinalizerProfileNames: FinalizerProfileNames,
                RunFinalizersOnMaxAttempts: RunFinalizersOnMaxAttempts);
        }
    }
}
