@page "/runs"
@rendermode InteractiveServer
@attribute [Authorize]
@implements IAsyncDisposable
@inject IRunService RunService
@inject NavigationManager Nav

<PageTitle>Runs — Geef.Atelier</PageTitle>

<div class="runs-container">
    <div class="runs-header">
        <h2>Runs</h2>
        <a href="/new" class="btn-new-run">+ New Run</a>
    </div>

    <div class="runs-filter">
        @foreach (var status in _filterOptions)
        {
            <button class="filter-btn @(StatusFilter == status ? "active" : "")"
                    @onclick="() => ApplyFilterAsync(status)">
                @(status?.ToString() ?? "All")
            </button>
        }
    </div>

    @if (_runs is null)
    {
        <EmptyState Message="Loading…" />
    }
    else if (_runs.Count == 0)
    {
        <EmptyState Message="No runs yet. Submit your first run!" />
    }
    else
    {
        @foreach (var run in _runs)
        {
            <RunCard Run="run" />
        }
    }
</div>

@code {
    [SupplyParameterFromQuery] public string? Status { get; set; }

    private RunStatus? StatusFilter => Enum.TryParse<RunStatus>(Status, out var s) ? s : null;

    private static readonly RunStatus?[] _filterOptions = [null, RunStatus.Pending, RunStatus.Running, RunStatus.Completed, RunStatus.Failed, RunStatus.Aborted];

    private IReadOnlyList<RunEntity>? _runs;
    private HubConnection? _hub;

    protected override async Task OnInitializedAsync()
    {
        _runs = await RunService.ListRunsAsync(20, StatusFilter);
        await InitHubAsync();
    }

    private async Task InitHubAsync()
    {
        _hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/runs"))
            .WithAutomaticReconnect()
            .Build();

        _hub.On<Guid>("AnyRunUpdated", async _ =>
        {
            _runs = await RunService.ListRunsAsync(20, StatusFilter);
            await InvokeAsync(StateHasChanged);
        });

        _hub.Reconnected += async _ =>
        {
            await _hub.SendAsync("JoinAllRunsGroupAsync");
            _runs = await RunService.ListRunsAsync(20, StatusFilter);
            await InvokeAsync(StateHasChanged);
        };

        await _hub.StartAsync();
        await _hub.SendAsync("JoinAllRunsGroupAsync");
    }

    private async Task ApplyFilterAsync(RunStatus? status)
    {
        var query = status.HasValue ? $"?Status={status.Value}" : string.Empty;
        Nav.NavigateTo("/runs" + query, forceLoad: false);
        _runs = await RunService.ListRunsAsync(20, status);
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null)
        {
            try { await _hub.SendAsync("LeaveAllRunsGroupAsync"); } catch { }
            await _hub.DisposeAsync();
        }
    }
}
