@page "/runs"
@rendermode InteractiveServer
@attribute [Authorize]
@implements IAsyncDisposable
@inject IRunService RunService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider
@using Microsoft.AspNetCore.SignalR.Client
@using Geef.Atelier.Core.Domain

<PageTitle>Runs — Geef.Atelier</PageTitle>

<div class="runs">
    <div class="runs-head">
        <div>
            <div class="t-eyebrow eyebrow">The workbench</div>
            <h1>All runs</h1>
            <div class="sub">Every commission, every revision — newest first.</div>
        </div>
        <div class="filters">
            @foreach (var f in _filters)
            {
                var count  = f.Status is null ? _runs?.Count : _runs?.Count(r => r.Status == f.Status);
                <FilterPill Label="@f.Label"
                            Count="@count"
                            Active="@(StatusFilter == f.Status)"
                            OnClick="@(() => ApplyFilterAsync(f.Status))" />
            }
        </div>
        @if (_isAdmin)
        {
            <label class="admin-toggle">
                <input type="checkbox" @bind="_showAllUsers" @bind:after="LoadRunsAsync" />
                Show all users
            </label>
        }
    </div>

    @if (_runs is null)
    {
        <EmptyState Message="Loading…" />
    }
    else if (_runs.Count == 0)
    {
        <div class="empty-state">
            <h3>An empty workbench</h3>
            <p>No runs match this filter — but the door is open. Begin your next briefing.</p>
            <a class="btn primary" href="/new">New briefing</a>
        </div>
    }
    else
    {
        <div class="runs-grid">
            @foreach (var run in _runs)
            {
                <div class="run-row-wrapper">
                    @if (_showAllUsers && _isAdmin && run.CreatedByUser is not null)
                    {
                        <div class="run-user-badge">@run.CreatedByUser</div>
                    }
                    <RunRow Run="run"
                            OnOpen="@(() => Nav.NavigateTo($"/runs/{run.Id}"))"
                            CanDelete="@(run.Status is RunStatus.Completed or RunStatus.Failed or RunStatus.Aborted)"
                            OnDelete="@(() => _toDelete = run)" />
                </div>
            }
        </div>
    }

    <a class="floating-new btn primary" href="/new" aria-label="New briefing">
        <IconAdd Size="14" />
        New briefing
    </a>
</div>

@if (!string.IsNullOrEmpty(_deleteError))
{
    <div class="error-banner" data-testid="delete-error">@_deleteError</div>
}

<DeleteConfirmationModal
    Show="_toDelete != null"
    ItemName="@(_toDelete?.Id.ToString("N")[..8].ToUpperInvariant() ?? "")"
    ItemKind="Run"
    OnConfirm="ExecuteDeleteAsync"
    OnCancel="() => _toDelete = null" />

@code {
    [SupplyParameterFromQuery] public string? Status { get; set; }

    RunStatus? StatusFilter => Enum.TryParse<RunStatus>(Status, out var s) ? s : null;

    static readonly (RunStatus? Status, string Label)[] _filters =
    [
        (null,                   "All"),
        (RunStatus.Pending,      "Pending"),
        (RunStatus.Running,      "Running"),
        (RunStatus.Completed,    "Completed"),
        (RunStatus.Failed,       "Failed"),
        (RunStatus.Aborted,      "Aborted"),
    ];

    IReadOnlyList<RunEntity>? _runs;
    HubConnection?            _hub;
    bool                      _isAdmin;
    string?                   _currentUsername;
    bool                      _showAllUsers;
    RunEntity?                _toDelete;
    string?                   _deleteError;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        _isAdmin         = auth.User.IsInRole("admin");
        _currentUsername = auth.User.Identity?.Name;

        await LoadRunsAsync();
        await InitHubAsync();
    }

    async Task LoadRunsAsync()
    {
        var username = (_showAllUsers && _isAdmin) ? null : _currentUsername;
        _runs = await RunService.ListRunsAsync(20, StatusFilter, requestingUsername: username);
    }

    async Task InitHubAsync()
    {
        _hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/runs"))
            .WithAutomaticReconnect()
            .Build();

        _hub.On<Guid>("AnyRunUpdated", async _ =>
        {
            await LoadRunsAsync();
            await InvokeAsync(StateHasChanged);
        });

        _hub.Reconnected += async _ =>
        {
            await _hub.SendAsync("JoinAllRunsGroupAsync");
            await LoadRunsAsync();
            await InvokeAsync(StateHasChanged);
        };

        await _hub.StartAsync();
        await _hub.SendAsync("JoinAllRunsGroupAsync");
    }

    async Task ExecuteDeleteAsync()
    {
        if (_toDelete is null) return;
        var id = _toDelete.Id;
        _toDelete = null;
        _deleteError = null;
        try
        {
            await RunService.DeleteRunAsync(id, _isAdmin ? null : _currentUsername);
            await LoadRunsAsync();
        }
        catch (Exception ex) { _deleteError = ex.Message; }
    }

    async Task ApplyFilterAsync(RunStatus? status)
    {
        var query = status.HasValue ? $"?Status={status.Value}" : string.Empty;
        Nav.NavigateTo("/runs" + query, forceLoad: false);
        var username = (_showAllUsers && _isAdmin) ? null : _currentUsername;
        _runs = await RunService.ListRunsAsync(20, status, requestingUsername: username);
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null)
        {
            try { await _hub.SendAsync("LeaveAllRunsGroupAsync"); } catch { }
            await _hub.DisposeAsync();
        }
    }
}
