@page "/runs/{runId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]
@implements IAsyncDisposable
@inject IRunService RunService
@inject IKnowledgeService KnowledgeService
@inject IRunArtifactRepository ArtifactRepository
@inject NavigationManager Nav
@inject ILogger<RunDetail> Logger
@inject AuthenticationStateProvider AuthProvider
@using Microsoft.AspNetCore.SignalR.Client
@using Geef.Atelier.Application.Runs
@using Geef.Atelier.Application.Crew.Knowledge
@using Geef.Atelier.Core.Domain
@using Geef.Atelier.Core.Domain.Crew
@using Geef.Atelier.Core.Domain.Crew.Advisors
@using Geef.Atelier.Core.Domain.Crew.Finalizers
@using Geef.Atelier.Core.Domain.Crew.Knowledge
@using Geef.Atelier.Core.Persistence
@using Geef.Atelier.Web.Display
@using Geef.Atelier.Web.Components.UI

<PageTitle>Run @_shortId — Geef.Atelier</PageTitle>

<div class="detail">
    @if (_details is null && !_notFound && !_forbidden)
    {
        <EmptyState Message="Loading…" />
    }
    else if (_forbidden)
    {
        <div class="forbidden-banner">
            <h2>No access</h2>
            <p>This run belongs to another user.</p>
            <a href="/runs" class="btn ghost">← Back to all runs</a>
        </div>
    }
    else if (_notFound)
    {
        <EmptyState Message="Run not found." />
    }
    else if (_details is not null)
    {
        <div class="crumb">
            <a href="/runs">All runs</a>
            <span class="sep" aria-hidden="true">/</span>
            <span class="id t-mono">@_shortId</span>
        </div>

        <div class="run-header">
            <div>
                <div class="status-line">
                    <StatusBadge Status="_details.Run.Status" Large="true" />
                    @if (_details.Run.Kind == RunKind.CrewComposition)
                    {
                        <span class="kind-badge kind-composition" title="Kompositions-Run">Kompositions-Run</span>
                    }
                    else if (_details.Run.Kind == RunKind.Learning)
                    {
                        <span class="kind-badge kind-learning" title="Lern-Run">Lern-Run</span>
                    }
                    <span class="t-eyebrow eyebrow">
                        Iteration @_details.Iterations.Count of 3
                    </span>
                </div>
                <h1>@Truncate(_details.Run.BriefingText, 100)</h1>
                <div class="briefing-block">@_details.Run.BriefingText</div>
                @if (_details.Run.ErrorMessage is not null)
                {
                    <div class="error-banner" style="margin-top:18px;max-width:600px" role="alert">
                        @_details.Run.ErrorMessage
                    </div>
                }
            </div>
            <div class="run-meta">
                <div class="row"><span class="label">Submitted</span><span class="val">@_details.Run.CreatedAt.LocalDateTime.ToString("HH:mm")</span></div>
                <div class="row"><span class="label">Tokens</span><span class="val">@(_details.Run.TokensTotal > 0 ? _details.Run.TokensTotal.ToString("N0") : "—")</span></div>
                <div class="row"><span class="label">Cost</span><span class="val" data-testid="run-cost">@FormatRunCost(_details.Run)</span></div>
                @if (_details.Run.ParentRunId.HasValue)
                {
                    <div class="row">
                        <span class="label">Resumed from</span>
                        <span class="val">
                            <a href="/runs/@_details.Run.ParentRunId.Value" class="t-mono">
                                @_details.Run.ParentRunId.Value.ToString("N")[..8].ToUpperInvariant()
                            </a>
                        </span>
                    </div>
                }
                @if (_details.Run.ParentCompositionRunId.HasValue)
                {
                    <div class="row">
                        <span class="label">Komponiert durch</span>
                        <span class="val">
                            <a href="/runs/@_details.Run.ParentCompositionRunId.Value" class="t-mono" data-testid="composition-run-link">
                                @_details.Run.ParentCompositionRunId.Value.ToString("N")[..8].ToUpperInvariant()
                            </a>
                        </span>
                    </div>
                }
                @if (_details.Run.Status is RunStatus.Pending or RunStatus.Running)
                {
                    <div class="actions">
                        <CancelButton RunId="_details.Run.Id" OnCancelled="HandleCancelledAsync" />
                    </div>
                }
                @if (_details.Run.Status is RunStatus.Aborted or RunStatus.Failed)
                {
                    <div class="actions">
                        <button class="btn secondary" data-testid="resume-run-button"
                                @onclick="OpenResumeDialog">
                            Resume
                        </button>
                        <button class="btn danger" data-testid="delete-run-button"
                                @onclick="() => _showDeleteModal = true">
                            Delete
                        </button>
                    </div>
                }
                @if (_details.Run.Status is RunStatus.Completed)
                {
                    <div class="actions">
                        <button class="btn danger" data-testid="delete-run-button"
                                @onclick="() => _showDeleteModal = true">
                            Delete
                        </button>
                    </div>
                }
            </div>
        </div>

        <CrewSummary Snapshot="_snapshot" FallbackTemplateName="@_details.Run.CrewTemplateName" />

        <Press Status="_details.Run.Status" />

        @if (_promoteError is not null)
        {
            <div class="error-banner" role="alert">@_promoteError</div>
        }

        @if (_runAttachments.Count > 0)
        {
            <RunAttachmentsList Attachments="_runAttachments"
                               OnPromoteClick="OpenPromoteModal" />
        }

        <PromoteAttachmentModal @bind-Show="_showPromoteModal"
                               Document="_promoteCandidate"
                               OnConfirm="HandlePromoteAsync" />

        <ResumeRunDialog
            Show="@_showResumeDialog"
            HasIterations="@(_details?.Iterations.Count > 0)"
            DefaultMaxIterations="@GetEffectiveMaxIterations()"
            ParentRunId="@RunId"
            OnConfirm="HandleResumeConfirmedAsync"
            OnCancel="() => _showResumeDialog = false" />

        <DeleteConfirmationModal
            Show="_showDeleteModal"
            ItemName="@_shortId"
            ItemKind="Run"
            OnConfirm="ExecuteDeleteAsync"
            OnCancel="() => _showDeleteModal = false" />

        @if (_details is not null && _viewModel is not null)
        {
            <GroundingSection
                Briefing="@_details.Run.BriefingText"
                GroundedBrief="@_viewModel.GroundedBrief"
                BeforeFirstAdvisors="@_viewModel.GroundingAdvisors"
                GroundingConsultations="@_viewModel.GroundingConsultations"
                RunAttachmentDocumentIds="_runAttachmentDocumentIds" />
        }

        <div class="iters">
            @{
                var resolvedMap = FindingResolutionInferrer.MarkResolved(_details!.Iterations);
            }
            @foreach (var (iwf, idx) in _details.Iterations.Select((x, i) => (x, i)))
            {
                var iterConsultations = _viewModel?.AdvisorsByIteration[iwf.Iteration.IterationNumber]?.ToList() ?? [];
                @if (iterConsultations.Count > 0)
                {
                    <AdvisorConsultationsBlock Consultations="iterConsultations" />
                }
                <IterationPanel
                    Iteration="iwf.Iteration"
                    Findings="iwf.Findings"
                    IsLast="@(idx == _details.Iterations.Count - 1)"
                    ResolvedMap="resolvedMap" />
                <IterationCostBlock Iteration="iwf.Iteration" />
            }
        </div>

        @if (_viewModel?.RecoveryAdvisors.Count > 0)
        {
            <div class="advisor-recovery-section">
                <h4>Convergence Failure Recovery</h4>
                <AdvisorConsultationsBlock Consultations="@_viewModel.RecoveryAdvisors" IsRecovery="true" />
            </div>
        }

        <FinalizersPipeline Snapshot="_snapshot"
                            Artifacts="_artifacts"
                            FinalText="@_details.Run.FinalText" />

        @if (_artifacts.Any(a => a.ArtifactType is ArtifactType.File or ArtifactType.Url))
        {
            <div class="run-artifacts-section" data-testid="artifacts-section">
                <h2>Downloads</h2>
                <table class="crew-table">
                    <thead>
                        <tr>
                            <th>Finalizer</th>
                            <th>File</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in _artifacts.Where(x => x.ArtifactType is ArtifactType.File or ArtifactType.Url))
                        {
                            <tr data-testid="artifact-row-@a.Id">
                                <td>@a.FinalizerProfileName</td>
                                <td>
                                    @if (a.ArtifactType == ArtifactType.File && a.Filename is not null)
                                    {
                                        <a href="/runs/@RunId/artifacts/@a.Id/download"
                                           class="btn small"
                                           data-testid="artifact-download-@a.Id">
                                            @a.Filename (@FormatBytes(a.SizeBytes ?? 0))
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="@a.StorageUri" target="_blank" rel="noopener noreferrer"
                                           data-testid="artifact-url-@a.Id">@a.StorageUri</a>
                                    }
                                </td>
                                <td>@a.CreatedAt.ToString("HH:mm:ss")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (_details.Run.Status == RunStatus.Completed && !string.IsNullOrEmpty(_details.Run.FinalText))
        {
            <Manuscript Run="_details.Run" IterationCount="@_details.Iterations.Count" />
        }
    }
</div>

@code {
    [Parameter] public Guid RunId { get; set; }

    RunWithGroundingViewModel? _viewModel;
    RunDetails?    _details;
    bool           _notFound;
    bool           _forbidden;
    HubConnection? _hub;
    CrewSnapshot?  _snapshot;
    List<KnowledgeDocument> _runAttachments = [];
    IReadOnlyList<Guid>     _runAttachmentDocumentIds = [];
    IReadOnlyList<RunArtifact> _artifacts = [];
    bool _showPromoteModal;
    KnowledgeDocument? _promoteCandidate;
    string? _promoteError;
    string? _requestingUser;
    bool _showResumeDialog;
    bool _showDeleteModal;

    string _shortId => RunId.ToString("N")[..8].ToUpperInvariant();

    protected override async Task OnInitializedAsync()
    {
        var auth     = await AuthProvider.GetAuthenticationStateAsync();
        var isAdmin  = auth.User.IsInRole("admin");
        var username = auth.User.Identity?.Name;
        _requestingUser = isAdmin ? null : username;

        await LoadAsync();
        await InitHubAsync();
    }

    async Task LoadAsync()
    {
        _viewModel = await RunService.GetRunWithGroundingAsync(RunId, requestingUsername: _requestingUser, CancellationToken.None);
        _details   = _viewModel?.Details;
        _snapshot  = _viewModel?.Snapshot;

        if (_viewModel is null)
        {
            // Distinguish 403 (run exists but belongs to another user) from 404
            if (_requestingUser is not null)
            {
                var adminView = await RunService.GetRunDetailsAsync(RunId, requestingUsername: null, CancellationToken.None);
                _forbidden = adminView is not null;
                _notFound  = !_forbidden;
            }
            else
            {
                _notFound = true;
            }
        }
        else
        {
            _forbidden = false;
            _notFound  = false;
        }
        try
        {
            _runAttachments = (await KnowledgeService.ListRunAttachmentsAsync(RunId, CancellationToken.None)).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load run attachments for run {RunId}", RunId);
            _runAttachments = [];
        }
        _runAttachmentDocumentIds = _runAttachments.Select(a => a.Id).ToArray();
        try
        {
            _artifacts = await ArtifactRepository.ListByRunAsync(RunId, CancellationToken.None);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load run artifacts for run {RunId}", RunId);
            _artifacts = [];
        }
    }

    static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }

    void OpenPromoteModal(KnowledgeDocument doc)
    {
        _promoteCandidate = doc;
        _showPromoteModal = true;
    }

    async Task HandlePromoteAsync(PromoteAttachmentModal.PromoteRequest req)
    {
        _promoteError = null;
        try
        {
            await KnowledgeService.PromoteToGlobalAsync(
                req.DocumentId, req.NewTitle, req.NewDescription, req.AdditionalTags, CancellationToken.None);
            _showPromoteModal = false;
            _runAttachments = (await KnowledgeService.ListRunAttachmentsAsync(RunId, CancellationToken.None)).ToList();
            _runAttachmentDocumentIds = _runAttachments.Select(a => a.Id).ToArray();
            _promoteCandidate = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to promote attachment {DocumentId}", req.DocumentId);
            _promoteError = "Failed to save to knowledge base. Please try again.";
        }
    }

    async Task InitHubAsync()
    {
        _hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/runs"))
            .WithAutomaticReconnect()
            .Build();

        _hub.On<Guid>("RunUpdated", async _ =>
        {
            await LoadAsync();
            await InvokeAsync(StateHasChanged);
        });

        _hub.Reconnected += async _ =>
        {
            await _hub.SendAsync("JoinRunGroupAsync", RunId);
            await LoadAsync();
            await InvokeAsync(StateHasChanged);
        };

        await _hub.StartAsync();
        await _hub.SendAsync("JoinRunGroupAsync", RunId);
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    async Task HandleCancelledAsync()
    {
        await LoadAsync();
        StateHasChanged();
    }

    void OpenResumeDialog() => _showResumeDialog = true;

    async Task ExecuteDeleteAsync()
    {
        _showDeleteModal = false;
        await RunService.DeleteRunAsync(RunId, _requestingUser);
        Nav.NavigateTo("/runs");
    }

    int GetEffectiveMaxIterations()
    {
        if (_details?.Run.CrewSnapshot is { } json)
        {
            var snapshot = CrewSnapshot.Deserialize(json);
            if (snapshot?.ConvergenceOverride?.MaxIterations is { } max)
                return max;
        }
        return 3;
    }

    async Task HandleResumeConfirmedAsync(ResumeOptions opts)
    {
        _showResumeDialog = false;
        try
        {
            var newRunId = await RunService.ResumeRunAsync(opts, _requestingUser);
            Nav.NavigateTo($"/runs/{newRunId}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Resume failed for run {RunId}", RunId);
        }
    }

    static string Truncate(string s, int max) =>
        s.Length > max ? s[..max] + "…" : s;

    static string FormatCost(decimal eur)
    {
        if (eur < 0.01m) return $"~€{eur:F4}";
        return $"€{eur:F2}";
    }

    static string FormatRunCost(RunEntity run)
    {
        if (!run.TotalCostEur.HasValue)
            return "—";

        var total = FormatCost(run.TotalCostEur.Value);
        if (run.LlmCostEur.HasValue && run.GroundingCostEur.HasValue)
            return $"{total} (LLM: {FormatCost(run.LlmCostEur.Value)}, Research: {FormatCost(run.GroundingCostEur.Value)})";
        if (run.LlmCostEur.HasValue)
            return $"{total} (LLM: {FormatCost(run.LlmCostEur.Value)})";
        return total;
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null)
        {
            try { await _hub.SendAsync("LeaveRunGroupAsync", RunId); } catch { }
            await _hub.DisposeAsync();
        }
    }
}
