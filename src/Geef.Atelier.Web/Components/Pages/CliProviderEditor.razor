@page "/crew/providers/create/cli"
@page "/crew/providers/edit/cli/{name}"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Text.Json
@using Geef.Atelier.Application.Providers
@using Geef.Atelier.Core.Domain.Providers
@using Geef.Atelier.Web.Resources
@inject IProviderService ProviderService
@inject NavigationManager Nav

<PageTitle>@(IsNew ? "CLI-Anbieter erstellen" : "CLI-Anbieter bearbeiten") — Atelier</PageTitle>

<div class="crew-editor" data-testid="cli-provider-editor">
    <div class="page-header">
        <h1>@(IsNew ? "Neuer CLI-Anbieter" : $"Bearbeiten: {_displayName}")</h1>
        <a href="/crew/providers" class="btn ghost">← Zurück</a>
    </div>

    @if (_loading)
    {
        <p>Wird geladen…</p>
    }
    else
    {
        <EditForm Model="_form" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="error-banner" data-testid="editor-error">@_error</div>
            }

            @* ── §0 Grunddaten ── *@
            <div class="template-meta-section">
                <h3>Grunddaten</h3>

                <div class="field">
                    <label>Name (Slug)</label>
                    <InputText @bind-Value="_form.Name" placeholder="my-cli-provider" data-testid="input-name" />
                    <ValidationMessage For="() => _form.Name" />
                    <FieldHelp Text="@ProviderFieldHelps.Name" DataTestId="help-name" />
                </div>

                <div class="field">
                    <label>Anzeigename</label>
                    <InputText @bind-Value="_form.DisplayName" placeholder="Mein CLI-Anbieter" data-testid="input-display-name" />
                    <ValidationMessage For="() => _form.DisplayName" />
                    <FieldHelp Text="@ProviderFieldHelps.DisplayName" DataTestId="help-display-name" />
                </div>

                <div class="field">
                    <label>Beschreibung</label>
                    <InputTextArea @bind-Value="_form.Description" rows="2" data-testid="input-description" />
                    <FieldHelp Text="@ProviderFieldHelps.Description" DataTestId="help-description" />
                </div>

                <div class="field">
                    <label class="form-checkbox-label">
                        <InputCheckbox @bind-Value="_form.IsActive" data-testid="input-is-active" />
                        Aktiv (in Profilen und Modell-Selektoren verfügbar)
                    </label>
                    <FieldHelp Text="@ProviderFieldHelps.IsActive" DataTestId="help-is-active" />
                </div>
            </div>

            @* ── §1 CLI-Typ ── *@
            <div class="template-meta-section">
                <h3>CLI-Typ</h3>

                @* Hidden select for form binding *@
                <div class="provider-type-hidden-select">
                    <InputSelect @bind-Value="_form.CliKind" data-testid="input-cli-kind">
                        <option value="claude">Claude Code CLI</option>
                        <option value="codex">Codex CLI</option>
                        <option value="gemini">Gemini CLI</option>
                        <option value="generic">Generic CLI</option>
                    </InputSelect>
                </div>

                <p class="pipeline-stage-desc" style="margin: 0 0 0.75rem;">
                    Wähle das CLI-Tool. Integrierte Typen sind voreingestellt — nur Parallelität und Modelle können angepasst werden.
                </p>
                <div class="provider-type-grid">
                    @foreach (var ct in _cliTypes)
                    {
                        var captured = ct.Kind;
                        <button type="button"
                                class="provider-type-card @(_form.CliKind == captured ? "active" : "")"
                                @onclick="() => _form.CliKind = captured">
                            <span class="ptc-label">@ct.Label</span>
                            <span class="ptc-desc">@ct.Desc</span>
                        </button>
                    }
                </div>

                @if (_form.CliKind != "generic")
                {
                    <div class="info-banner" style="margin-top: 0.75rem;" data-testid="builtin-info">
                        Integrierter CLI-Typ — Binary und Auth sind vorkonfiguriert. Nur <strong>Max. Gleichzeitig</strong> und <strong>Modelle</strong> können angepasst werden.
                    </div>
                }
            </div>

            @* ── §2 Allgemein ── *@
            <div class="pipeline-stage-section">
                <div class="pipeline-stage-header">
                    <div class="pipeline-stage-header-text">
                        <h3>Allgemein</h3>
                        <p class="pipeline-stage-desc">Parallelität und verfügbare Modelle für diesen Anbieter.</p>
                    </div>
                </div>

                <div class="field">
                    <label>Max. Gleichzeitig</label>
                    <InputNumber @bind-Value="_form.MaxConcurrent" min="1" max="10" data-testid="input-max-concurrent" />
                    <FieldHelp Text="@ProviderFieldHelps.CliMaxConcurrent" DataTestId="help-max-concurrent" />
                </div>

                <div class="field">
                    <label>Modelle (ein Modell pro Zeile)</label>
                    <InputTextArea @bind-Value="_form.Models" rows="4"
                                   placeholder="google/gemini-2.5-pro&#10;google/gemini-2.5-flash" data-testid="input-models" />
                    <FieldHelp Text="@ProviderFieldHelps.CliModels" DataTestId="help-models" />
                </div>
            </div>

            @* ── §3 Binary & Aufruf (nur Generic) ── *@
            @if (_form.CliKind == "generic")
            {
                <div class="pipeline-stage-section">
                    <div class="pipeline-stage-header">
                        <div class="pipeline-stage-header-text">
                            <h3>Binary &amp; Aufruf</h3>
                            <p class="pipeline-stage-desc">Pfad, Argumente und Ausgabeformat des generischen CLI-Tools.</p>
                        </div>
                    </div>

                    <div class="field">
                        <label>Binary</label>
                        <InputText @bind-Value="_form.Binary" placeholder="mycli" data-testid="input-binary" />
                        <ValidationMessage For="() => _form.Binary" />
                        <FieldHelp Text="@ProviderFieldHelps.CliBinary" DataTestId="help-binary" />
                    </div>

                    <div class="field">
                        <label class="form-checkbox-label">
                            <InputCheckbox @bind-Value="_form.StdinMode" data-testid="input-stdin-mode" />
                            Stdin-Modus (Prompt via stdin statt Argument übergeben)
                        </label>
                        <FieldHelp Text="@ProviderFieldHelps.CliStdinMode" DataTestId="help-stdin-mode" />
                    </div>

                    @if (!_form.StdinMode)
                    {
                        <div class="field">
                            <label>Prompt-Args-Template (ein Argument pro Zeile)</label>
                            <InputTextArea @bind-Value="_form.PromptArgsTemplate" rows="4"
                                           placeholder="-p&#10;{prompt}&#10;--model&#10;{model}" data-testid="input-prompt-args" />
                            <FieldHelp Text="@ProviderFieldHelps.CliPromptArgsTemplate" DataTestId="help-prompt-args" />
                        </div>
                    }

                    <div class="field">
                        <label>Ausgabe-Format</label>
                        <InputSelect @bind-Value="_form.OutputFormat" data-testid="input-output-format">
                            <option value="text">text (Klartext)</option>
                            <option value="openai-json">openai-json (OpenAI-kompatibles JSON)</option>
                            <option value="jsonl">jsonl (Streaming-JSON, letztes Event)</option>
                        </InputSelect>
                        <FieldHelp Text="@ProviderFieldHelps.CliOutputFormat" DataTestId="help-output-format" />
                    </div>

                    @if (_form.OutputFormat != "text")
                    {
                        <div class="field">
                            <label>Ausgabe-JSON-Pfad (optional)</label>
                            <InputText @bind-Value="_form.OutputJsonPath" placeholder="response" data-testid="input-output-json-path" />
                            <FieldHelp Text="@ProviderFieldHelps.CliOutputJsonPath" DataTestId="help-output-json-path" />
                        </div>
                    }
                </div>
            }

            @* ── Aktionsleiste ── *@
            <div class="form-actions">
                <button type="submit" class="btn primary" disabled="@_saving" data-testid="btn-save">
                    @(_saving ? "Speichern…" : IsNew ? "Erstellen" : "Speichern")
                </button>
                <a href="/crew/providers" class="btn ghost">Abbrechen</a>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter] public string? Name { get; set; }

    private bool IsNew => string.IsNullOrEmpty(Name);
    private bool _loading = true;
    private bool _saving;
    private string _displayName = string.Empty;
    private string? _error;
    private CliFormModel _form = new();

    private static readonly (string Kind, string Label, string Desc)[] _cliTypes =
    [
        ("claude",  "Claude Code",  "Anthropic Claude Code — lokal authentifiziert"),
        ("codex",   "Codex CLI",    "OpenAI Codex — lokal authentifiziert"),
        ("gemini",  "Gemini CLI",   "Google Gemini — lokal authentifiziert"),
        ("generic", "Generic CLI",  "Eigenes CLI-Tool mit individuellem Aufruf"),
    ];

    protected override async Task OnInitializedAsync()
    {
        if (!IsNew && Name is not null)
        {
            var existing = await ProviderService.GetByNameAsync(Name);
            if (existing is null || existing.IsSystem)
            {
                Nav.NavigateTo("/crew/providers");
                return;
            }
            _displayName = existing.DisplayName;
            _form = CliFormModel.From(existing);
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _error = null;
        try
        {
            var provider = _form.ToProvider();
            if (IsNew)
                await ProviderService.CreateCustomAsync(provider);
            else
                await ProviderService.UpdateCustomAsync(Name!, provider);

            Nav.NavigateTo("/crew/providers");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private sealed class CliFormModel
    {
        [Required(ErrorMessage = "Name ist erforderlich.")]
        [RegularExpression(@"^[a-z0-9\-]+$", ErrorMessage = "Nur Kleinbuchstaben, Ziffern und Bindestriche.")]
        [MaxLength(64)]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Anzeigename ist erforderlich.")]
        [MaxLength(200)]
        public string DisplayName { get; set; } = string.Empty;

        public string Description { get; set; } = string.Empty;
        public string CliKind { get; set; } = "claude";
        public int MaxConcurrent { get; set; } = 2;
        public string Models { get; set; } = string.Empty;

        [RequiredIf(nameof(CliKind), "generic", ErrorMessage = "Binary ist für Generic-CLI-Anbieter erforderlich.")]
        public string Binary { get; set; } = string.Empty;

        public bool StdinMode { get; set; } = false;
        public string PromptArgsTemplate { get; set; } = string.Empty;
        public string OutputFormat { get; set; } = "text";
        public string OutputJsonPath { get; set; } = string.Empty;
        public bool IsActive { get; set; } = true;

        public static CliFormModel From(Provider p)
        {
            var s = CliProviderSettings.FromSettings(p.Settings);
            var promptArgs = s.PromptArgsTemplate is { Count: > 0 }
                ? string.Join("\n", s.PromptArgsTemplate)
                : string.Empty;
            return new CliFormModel
            {
                Name = p.Name,
                DisplayName = p.DisplayName,
                Description = p.Description,
                CliKind = s.CliKind,
                MaxConcurrent = s.MaxConcurrent,
                Models = s.Models.Count > 0 ? string.Join("\n", s.Models) : string.Empty,
                Binary = s.Binary,
                StdinMode = s.StdinMode ?? false,
                PromptArgsTemplate = promptArgs,
                OutputFormat = s.OutputFormat ?? "text",
                OutputJsonPath = s.OutputJsonPath ?? string.Empty,
                IsActive = p.IsActive,
            };
        }

        public Provider ToProvider()
        {
            var models = Models
                .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(m => m.Length > 0)
                .ToList();

            var settings = new Dictionary<string, JsonElement>
            {
                ["cli_kind"] = JsonDocument.Parse(JsonSerializer.Serialize(CliKind)).RootElement.Clone(),
                ["max_concurrent"] = JsonDocument.Parse(MaxConcurrent.ToString()).RootElement.Clone(),
                ["models"] = JsonDocument.Parse(JsonSerializer.Serialize(models)).RootElement.Clone(),
            };

            void AddStr(string key, string? value)
            {
                if (!string.IsNullOrWhiteSpace(value))
                    settings[key] = JsonDocument.Parse(JsonSerializer.Serialize(value)).RootElement.Clone();
            }

            void AddBool(string key, bool value) =>
                settings[key] = JsonDocument.Parse(value ? "true" : "false").RootElement.Clone();

            if (CliKind == "generic")
            {
                AddStr("binary", Binary);
                AddBool("stdin_mode", StdinMode);
                AddStr("output_format", OutputFormat);
                AddStr("output_json_path", OutputJsonPath);

                if (!StdinMode && !string.IsNullOrWhiteSpace(PromptArgsTemplate))
                {
                    var args = PromptArgsTemplate
                        .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                        .ToList();
                    settings["prompt_args_template"] = JsonDocument.Parse(JsonSerializer.Serialize(args)).RootElement.Clone();
                }
            }
            else
            {
                AddStr("binary", CliKind);
            }

            var now = DateTimeOffset.UtcNow;
            return new Provider(
                Name: Name,
                DisplayName: DisplayName,
                Description: Description,
                Type: ProviderType.Cli,
                Settings: settings,
                IsSystem: false,
                IsActive: IsActive,
                CreatedAt: now,
                UpdatedAt: now
            );
        }
    }

    /// <summary>Validates that a field is required only when another field has a specific value.</summary>
    private sealed class RequiredIfAttribute : ValidationAttribute
    {
        private readonly string _dependentProperty;
        private readonly string _dependentValue;
        private readonly string? _customErrorMessage;

        public RequiredIfAttribute(string dependentProperty, string dependentValue, string? errorMessage = null)
        {
            _dependentProperty = dependentProperty;
            _dependentValue = dependentValue;
            _customErrorMessage = errorMessage;
        }

        protected override ValidationResult? IsValid(object? value, ValidationContext context)
        {
            var instance = context.ObjectInstance;
            var prop = instance.GetType().GetProperty(_dependentProperty);
            var actual = prop?.GetValue(instance)?.ToString();
            if (!string.Equals(actual, _dependentValue, StringComparison.Ordinal))
                return ValidationResult.Success;

            if (value is string s && !string.IsNullOrWhiteSpace(s))
                return ValidationResult.Success;
            if (value is not null and not string)
                return ValidationResult.Success;

            return new ValidationResult(_customErrorMessage ?? $"{context.DisplayName} ist erforderlich.", [context.MemberName!]);
        }
    }
}
