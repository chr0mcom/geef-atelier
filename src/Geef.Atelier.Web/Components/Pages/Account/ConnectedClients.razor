@page "/account/connected-clients"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.Security.Claims
@using Geef.Atelier.Application.OAuth
@inject IOAuthService OAuthService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Connected clients — Geef.Atelier</PageTitle>

<div class="connected-clients" data-testid="connected-clients-page">
    <div class="page-header">
        <h1>Connected clients</h1>
        <a href="/workshop" class="btn ghost" data-testid="btn-back">← Back</a>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger" data-testid="error-banner">@_error</div>
    }

    @if (_loading)
    {
        <p>Loading…</p>
    }
    else if (_clients.Count == 0)
    {
        <div class="empty-state" data-testid="empty-state">
            No connected clients.
        </div>
    }
    else
    {
        <div class="clients-list" data-testid="connected-clients-list">
            @foreach (var client in _clients)
            {
                <div class="client-row" data-testid="client-row-@client.ClientId">
                    <div class="client-info">
                        <span class="client-name">@client.ClientName</span>
                        <span class="client-meta">Connected since @client.IssuedAt.ToString("yyyy-MM-dd HH:mm") UTC</span>
                        <span class="client-scope">Permission: @client.Scope</span>
                    </div>
                    <div class="client-actions">
                        @if (_confirmRevokeClientId == client.ClientId)
                        {
                            <span class="revoke-confirm-text">Really revoke?</span>
                            <button class="btn danger small" @onclick="() => RevokeClientAsync(client.ClientId)"
                                    data-testid="btn-confirm-revoke-@client.ClientId">
                                Yes
                            </button>
                            <button class="btn ghost small" @onclick="CancelRevoke"
                                    data-testid="btn-cancel-revoke-@client.ClientId">
                                No
                            </button>
                        }
                        else
                        {
                            <button class="btn ghost small" @onclick="() => ConfirmRevoke(client.ClientId)"
                                    data-testid="btn-revoke-@client.ClientId">
                                Revoke
                            </button>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="clients-footer">
            @if (_confirmRevokeAll)
            {
                <span class="revoke-confirm-text">Really revoke all?</span>
                <button class="btn danger" @onclick="RevokeAllAsync" data-testid="btn-confirm-revoke-all">Yes</button>
                <button class="btn ghost" @onclick="() => _confirmRevokeAll = false" data-testid="btn-cancel-revoke-all">No</button>
            }
            else
            {
                <button class="btn danger" @onclick="() => _confirmRevokeAll = true" data-testid="btn-revoke-all">
                    Revoke all
                </button>
            }
        </div>
    }
</div>

@code {
    private IReadOnlyList<ConnectedClientInfo> _clients = [];
    private bool    _loading            = true;
    private string? _error;
    private string? _confirmRevokeClientId;
    private bool    _confirmRevokeAll;
    private string  _userId             = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userId = authState.User.FindFirst(ClaimTypes.Name)?.Value ?? "";
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error   = null;
        try
        {
            _clients = await OAuthService.GetConnectedClientsAsync(_userId, CancellationToken.None);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void ConfirmRevoke(string clientId)
    {
        _confirmRevokeClientId = clientId;
        _confirmRevokeAll      = false;
    }

    private void CancelRevoke() => _confirmRevokeClientId = null;

    private async Task RevokeClientAsync(string clientId)
    {
        _confirmRevokeClientId = null;
        try
        {
            await OAuthService.RevokeClientAsync(_userId, clientId, CancellationToken.None);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task RevokeAllAsync()
    {
        _confirmRevokeAll = false;
        try
        {
            await OAuthService.RevokeAllUserTokensAsync(_userId, CancellationToken.None);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
