@page "/tools/create"
@page "/tools/edit/{Name}"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Text.Json
@using Geef.Atelier.Core.Domain.Tools
@using Geef.Atelier.Web.Services
@inject IToolDefinitionService ToolService
@inject NavigationManager Nav

<PageTitle>@(IsNew ? "New tool" : $"Edit: {_form.DisplayName}") — Atelier</PageTitle>

<div class="crew-editor" data-testid="tool-editor">
    <div class="page-header">
        <h1>@(IsNew ? "New tool" : _isSystem ? _form.DisplayName : $"Edit: {_form.DisplayName}")</h1>
        <a href="/tools" class="btn ghost">← Back</a>
    </div>

    @if (_loading)
    {
        <p>Loading…</p>
    }
    else
    {
        @if (_isSystem)
        {
            <div class="info-banner">
                This is a system tool and cannot be edited. Use <strong>Duplicate as custom</strong> in the list.
            </div>
        }

        <EditForm Model="_form" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="error-banner" data-testid="editor-error">@_error</div>
            }

            @* ── §0 Basics ── *@
            <div class="template-meta-section">
                <h3>Basics</h3>

                <div class="field">
                    <label>Name (slug)</label>
                    <InputText @bind-Value="_form.Name" placeholder="my-tool"
                               disabled="@(!IsNew || _isSystem)"
                               data-testid="input-name" />
                    @if (IsNew)
                    {
                        <small class="form-hint">Lowercase letters, digits and hyphens only. No leading or trailing hyphen.</small>
                    }
                    <ValidationMessage For="() => _form.Name" />
                </div>

                <div class="field">
                    <label>Display name</label>
                    <InputText @bind-Value="_form.DisplayName" disabled="@_isSystem"
                               data-testid="input-display-name" />
                    <ValidationMessage For="() => _form.DisplayName" />
                </div>

                <div class="field">
                    <label>Description</label>
                    <InputTextArea @bind-Value="_form.Description" rows="3"
                                   disabled="@_isSystem"
                                   data-testid="input-description" />
                    <ValidationMessage For="() => _form.Description" />
                </div>
            </div>

            @* ── §1 Tool type ── *@
            <div class="template-meta-section">
                <h3>Tool type</h3>

                <div class="field">
                    <label>Type</label>
                    <InputSelect @bind-Value="_form.ToolType" disabled="@_isSystem"
                                 data-testid="input-tool-type">
                        <option value="web-search">Web search</option>
                        <option value="knowledge-base">Knowledge base</option>
                        <option value="url-fetch">URL fetch</option>
                        <option value="news-search">News search</option>
                        <option value="academic-search">Academic search</option>
                        <option value="rest-api">REST API</option>
                        <option value="static-context">Static context</option>
                        <option value="learning-retrieval">Learning retrieval</option>
                        <option value="mcp-tool">MCP tool</option>
                    </InputSelect>
                    <ValidationMessage For="() => _form.ToolType" />
                </div>
            </div>

            @* ── §2 Access & secret ── *@
            <div class="template-meta-section">
                <h3>Access &amp; authentication</h3>

                <div class="field">
                    <label>Access class</label>
                    <div class="radio-group" data-testid="access-class-group">
                        <label class="radio-option">
                            <input type="radio" name="access-class" value="ReadOnly"
                                   checked="@(_form.AccessClass == ToolAccessClass.ReadOnly)"
                                   disabled="@_isSystem"
                                   @onchange="() => _form.AccessClass = ToolAccessClass.ReadOnly" />
                            <span>
                                <strong>Read-only</strong>
                                <span class="radio-description">The tool only reads data and changes no external state.</span>
                            </span>
                        </label>
                        <label class="radio-option">
                            <input type="radio" name="access-class" value="Mutating"
                                   checked="@(_form.AccessClass == ToolAccessClass.Mutating)"
                                   disabled="@_isSystem"
                                   @onchange="() => _form.AccessClass = ToolAccessClass.Mutating" />
                            <span>
                                <strong>Mutating</strong>
                                <span class="radio-description">
                                    The tool writes or changes external state.
                                    <strong class="form-hint--warn"> Requires explicit opt-in per crew spec.</strong>
                                </span>
                            </span>
                        </label>
                    </div>
                </div>

                @if (_form.AccessClass == ToolAccessClass.Mutating)
                {
                    <div class="alert alert-danger d-flex align-items-center gap-2 mt-2" data-testid="mutating-warning">
                        <span>&#9888;</span>
                        <span><strong>Mutating tool:</strong> This tool can write or change data. It only runs when <code>allow_mutating_tools</code> is explicitly enabled in the crew spec.</span>
                    </div>
                }

                <div class="field">
                    <label>Secret reference (optional)</label>
                    <InputText @bind-Value="_form.SecretRef"
                               placeholder="e.g. MY_API_KEY"
                               disabled="@_isSystem"
                               data-testid="input-secret-ref" />
                    <small class="form-hint">Name of an ENV variable holding the API key. Never enter the plaintext key here.</small>
                </div>
            </div>

            @* ── §3 LLM schema ── *@
            <div class="template-meta-section">
                <h3>LLM schema</h3>
                <p class="pipeline-stage-desc">JSON Schema describing the input object the LLM must supply when calling this tool.</p>

                <div class="field">
                    <textarea rows="10"
                              style="font-family: var(--font-mono, monospace); font-size: 0.82rem; width: 100%;"
                              disabled="@_isSystem"
                              value="@_schemaText"
                              @onchange="OnSchemaChanged"
                              data-testid="input-llm-schema">@_schemaText</textarea>
                    @if (!string.IsNullOrEmpty(_schemaError))
                    {
                        <small class="form-hint form-hint--warn">@_schemaError</small>
                    }
                </div>
            </div>

            @* ── Actions ── *@
            @if (!_isSystem)
            {
                <div class="form-actions">
                    <button type="submit" class="btn primary" disabled="@_saving" data-testid="btn-save">
                        @(_saving ? "Saving…" : IsNew ? "Create" : "Save")
                    </button>
                    <button type="button" class="btn ghost" @onclick="NavigateBack">Cancel</button>
                    @if (!IsNew)
                    {
                        <button type="button" class="btn danger"
                                @onclick="() => _showDeleteModal = true"
                                data-testid="btn-delete">Delete</button>
                    }
                </div>
            }
            else
            {
                <div class="form-actions">
                    <button type="button" class="btn ghost" @onclick="NavigateBack">Back</button>
                </div>
            }
        </EditForm>
    }
</div>

<DeleteConfirmationModal
    Show="_showDeleteModal"
    ItemName="@(Name ?? "")"
    ItemKind="Tool"
    OnConfirm="ExecuteDeleteAsync"
    OnCancel="() => _showDeleteModal = false" />

@code {
    [Parameter] public string? Name { get; set; }

    private bool IsNew => Name == null;
    private bool _isSystem;
    private bool _loading = true;
    private bool _saving;
    private bool _showDeleteModal;
    private string? _error;
    private string _schemaText = "{}";
    private string? _schemaError;

    private ToolFormModel _form = new();

    protected override async Task OnInitializedAsync()
    {
        if (!IsNew)
        {
            var tool = await ToolService.GetByNameAsync(Name!);
            if (tool == null) { Nav.NavigateTo("/tools"); return; }
            _isSystem = tool.IsSystem;
            _form = ToolFormModel.From(tool);
            _schemaText = FormatSchema(tool.LlmSchema);
        }
        _loading = false;
    }

    private void OnSchemaChanged(ChangeEventArgs e)
    {
        _schemaText = e.Value?.ToString() ?? "{}";
        _schemaError = null;
        try
        {
            JsonDocument.Parse(_schemaText);
        }
        catch (JsonException ex)
        {
            _schemaError = $"Invalid JSON: {ex.Message}";
        }
    }

    private void NavigateBack() => Nav.NavigateTo("/tools");

    private async Task SaveAsync()
    {
        if (!string.IsNullOrEmpty(_schemaError)) return;

        _saving = true;
        _error = null;
        try
        {
            JsonElement schema;
            try
            {
                schema = JsonDocument.Parse(_schemaText).RootElement;
            }
            catch (JsonException ex)
            {
                _schemaError = $"Invalid JSON: {ex.Message}";
                return;
            }

            var tool = _form.ToToolDefinition(schema);
            await ToolService.SaveAsync(tool);
            Nav.NavigateTo("/tools");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ExecuteDeleteAsync()
    {
        _showDeleteModal = false;
        _error = null;
        try
        {
            await ToolService.DeleteAsync(Name!);
            Nav.NavigateTo("/tools");
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private static string FormatSchema(JsonElement schema)
    {
        try
        {
            return JsonSerializer.Serialize(schema, new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return "{}";
        }
    }

    private sealed class ToolFormModel
    {
        [Required(ErrorMessage = "Name is required.")]
        [RegularExpression(@"^[a-z0-9]([a-z0-9\-]*[a-z0-9])?$",
            ErrorMessage = "Lowercase letters, digits and hyphens only. No leading or trailing hyphen.")]
        [MaxLength(64)]
        public string Name { get; set; } = "";

        [Required(ErrorMessage = "Display name is required.")]
        [MaxLength(200)]
        public string DisplayName { get; set; } = "";

        [MaxLength(1000)]
        public string Description { get; set; } = "";

        [Required(ErrorMessage = "Type is required.")]
        public string ToolType { get; set; } = "web-search";

        public ToolAccessClass AccessClass { get; set; } = ToolAccessClass.ReadOnly;

        [MaxLength(200)]
        public string SecretRef { get; set; } = "";

        public static ToolFormModel From(ToolDefinition t) => new()
        {
            Name        = t.Name,
            DisplayName = t.DisplayName,
            Description = t.Description,
            ToolType    = t.ToolType,
            AccessClass = t.AccessClass,
            SecretRef   = t.SecretRef ?? "",
        };

        public ToolDefinition ToToolDefinition(JsonElement schema) => new(
            Name:        Name,
            DisplayName: DisplayName,
            Description: Description,
            ToolType:    ToolType,
            Settings:    new Dictionary<string, string>(),
            SecretRef:   string.IsNullOrWhiteSpace(SecretRef) ? null : SecretRef.Trim(),
            LlmSchema:   schema,
            AccessClass: AccessClass,
            IsSystem:    false);
    }
}
