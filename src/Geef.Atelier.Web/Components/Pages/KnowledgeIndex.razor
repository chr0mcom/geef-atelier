@page "/crew/knowledge"
@attribute [Authorize]
@rendermode InteractiveServer
@using Geef.Atelier.Application.Crew.Knowledge
@using Geef.Atelier.Core.Domain.Crew.Knowledge
@inject IKnowledgeService KnowledgeService
@inject NavigationManager Nav

<PageTitle>Knowledge Base — Atelier</PageTitle>

<div class="crew-profiles-index" data-testid="knowledge-index">
    <div class="page-header">
        <div>
            <div class="t-eyebrow eyebrow">Crew</div>
            <h1>Knowledge Base</h1>
        </div>
        <a href="/crew/knowledge/upload" class="btn primary" data-testid="btn-upload">+ Upload Document</a>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger" data-testid="error-banner">@_error</div>
    }

    @if (_loading)
    {
        <p class="text-muted">Loading…</p>
    }
    else if (_documents.Count == 0)
    {
        <div class="empty-state" data-testid="empty-state">
            <h3>No documents yet</h3>
            <p>Upload a document to make it available to your crew as a knowledge source.</p>
            <a class="btn primary" href="/crew/knowledge/upload">Upload Document</a>
        </div>
    }
    else
    {
        <div class="knowledge-doc-list" data-testid="knowledge-doc-list">
            @foreach (var doc in _documents)
            {
                <KnowledgeDocumentCard Document="doc" OnDelete="@(() => _toDelete = doc)" />
            }
        </div>
    }

    <div class="knowledge-actions">
        <button class="btn ghost" @onclick="ReindexAllAsync" disabled="@_reindexing" data-testid="btn-reindex-all">
            @(_reindexing ? "Re-indexing…" : "Re-Index All")
        </button>
        @if (_reindexSuccess)
        {
            <span class="text-muted" data-testid="reindex-success">All documents re-indexed.</span>
        }
    </div>
</div>

<DeleteConfirmationModal
    Show="_toDelete != null"
    ItemName="@(_toDelete?.Title ?? "")"
    ItemKind="Document"
    OnConfirm="ExecuteDeleteAsync"
    OnCancel="@(() => _toDelete = null)" />

@code {
    private IReadOnlyList<KnowledgeDocument> _documents = [];
    private bool   _loading = true;
    private bool   _reindexing;
    private bool   _reindexSuccess;
    private string? _error;
    private KnowledgeDocument? _toDelete;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error   = null;
        try
        {
            _documents = await KnowledgeService.ListAsync(null, CancellationToken.None, KnowledgeScope.Global);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally  { _loading = false; }
    }

    private async Task ExecuteDeleteAsync()
    {
        if (_toDelete is null) return;
        var id = _toDelete.Id;
        _toDelete = null;
        _error    = null;
        try
        {
            await KnowledgeService.DeleteAsync(id, CancellationToken.None);
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task ReindexAllAsync()
    {
        _reindexing    = true;
        _reindexSuccess = false;
        _error          = null;
        try
        {
            await KnowledgeService.ReindexAllAsync(CancellationToken.None);
            _reindexSuccess = true;
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _reindexing = false; }
    }
}
