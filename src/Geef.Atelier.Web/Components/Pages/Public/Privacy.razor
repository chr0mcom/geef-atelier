@page "/privacy"
@layout Layout.LandingLayout
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@using Geef.Atelier.Application.SiteSettings
@using Geef.Atelier.Web.Services
@inject ISiteSettingsService SiteSettingsService

<PageTitle>Privacy policy — Geef.Atelier</PageTitle>

@if (_settings is not null)
{
    <div class="lp-legal-page">
        <LandingNav />
        <div class="lp-container">
            <div class="legal-content">
                <h1>Privacy policy</h1>
                @if (!_settings.LegalBoilerplateAccepted)
                {
                    <p class="legal-disclaimer">
                        ⚠️ <em>Template scaffold — not legal advice. The operator must adapt this privacy policy to the actual data processing (auth cookies, LLM providers, Tavily/grounding services, hosting) and have it reviewed legally before going live.</em>
                    </p>
                }

                <section>
                    <h2>1. Controller</h2>
                    <address>
                        <strong>@_settings.OperatorName</strong><br />
                        @_settings.AddressStreet<br />
                        @_settings.AddressZip @_settings.AddressCity<br />
                        @_settings.AddressCountry
                    </address>
                    <p>Email: <EmailObfuscated Email="@_settings.ContactEmail" /></p>
                </section>

                <section>
                    <h2>2. Collection and processing of personal data</h2>
                    <p>
                        When you visit this website, data that your browser transmits to our server is collected automatically
                        (so-called server log files). These include, among other things, the IP address, the date and time of the
                        request, the amount of data transferred and the requesting provider. This data is processed for the
                        purposes of security, error analysis and statistical evaluation, and is deleted after a short time.
                    </p>
                </section>

                <section>
                    <h2>3. Cookies and authentication</h2>
                    <p>
                        This application sets cookies for authentication (cookie-based session management). The authentication
                        cookie is technically necessary for the operation of the application and cannot be disabled. Additional
                        cookies may be set for display preferences (e.g. colour theme).
                    </p>
                    <p>Legal basis: Art. 6 (1) (f) GDPR (legitimate interest in secure operation).</p>
                </section>

                <section>
                    <h2>4. External service providers / third parties</h2>
                    <p>
                        <strong>[Please adapt:]</strong> This application uses external AI providers (e.g. OpenRouter, OpenAI, Anthropic,
                        Google, Groq, DeepSeek) as well as search and grounding services (e.g. Tavily). With every request,
                        text content is transmitted to these providers. The respective privacy policies of these providers apply.
                        The operator must list the services actually used in full and conclude the corresponding data processing
                        agreements (DPAs).
                    </p>
                </section>

                <section>
                    <h2>5. Your rights</h2>
                    <p>
                        You have the right to access (Art. 15 GDPR), rectification (Art. 16), erasure (Art. 17), restriction of
                        processing (Art. 18), data portability (Art. 20) and objection (Art. 21). To exercise these rights,
                        please contact: <EmailObfuscated Email="@_settings.ContactEmail" />
                    </p>
                    <p>
                        You also have the right to lodge a complaint with the competent data protection supervisory authority
                        @if (!string.IsNullOrWhiteSpace(_settings.SupervisoryAuthority))
                        {
                            <span>(@_settings.SupervisoryAuthority)</span>
                        }.
                    </p>
                </section>

                <section>
                    <h2>6. Transfer of data to third countries</h2>
                    <p>
                        <strong>[Please adapt:]</strong> When using AI providers outside the EU/EEA, personal data is transferred to
                        third countries. The operator ensures that appropriate safeguards pursuant to Art. 46 GDPR are in place
                        for these transfers (e.g. standard contractual clauses).
                    </p>
                </section>

                @if (!string.IsNullOrWhiteSpace(_settings.PrivacyAppendMarkdown))
                {
                    <div class="legal-append">
                        @MarkdownRenderer.ToMarkupString(_settings.PrivacyAppendMarkdown)
                    </div>
                }
            </div>
        </div>
        <LandingFooter />
    </div>
}

@code {
    private Core.Domain.SiteSettings? _settings;

    protected override async Task OnInitializedAsync()
        => _settings = await SiteSettingsService.GetAsync();
}
