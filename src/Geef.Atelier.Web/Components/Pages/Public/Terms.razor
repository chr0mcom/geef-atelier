@page "/terms"
@layout Layout.LandingLayout
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@using Geef.Atelier.Application.SiteSettings
@using Geef.Atelier.Web.Services
@inject ISiteSettingsService SiteSettingsService

<PageTitle>Terms of use — Geef.Atelier</PageTitle>

@if (_settings is not null)
{
    <div class="lp-legal-page">
        <LandingNav />
        <div class="lp-container">
            <div class="legal-content">
                <h1>Terms of use</h1>
                @if (!_settings.LegalBoilerplateAccepted)
                {
                    <p class="legal-disclaimer">
                        ⚠️ <em>Template scaffold — not legal advice. The operator must have these terms reviewed by a lawyer and adapted to the specific terms of use before going live.</em>
                    </p>
                }

                <section>
                    <h2>§ 1 Scope</h2>
                    <p>
                        These terms of use apply to the use of the Geef.Atelier platform, operated by
                        @_settings.OperatorName, @_settings.AddressStreet, @_settings.AddressZip @_settings.AddressCity
                        (hereinafter the "operator"). By using the platform, the user accepts these terms.
                    </p>
                </section>

                <section>
                    <h2>§ 2 Scope of services</h2>
                    <p>
                        Geef.Atelier is an experimental writing-tool platform (beta phase) that provides AI-assisted text
                        iteration. The operator reserves the right to change, restrict or discontinue the service at any time.
                    </p>
                </section>

                <section>
                    <h2>§ 3 Terms of use and obligations</h2>
                    <p>
                        The user undertakes not to use the platform for unlawful purposes, not to transmit malware, not to
                        process content that infringes the rights of third parties, and not to carry out automated access
                        without express authorisation.
                    </p>
                </section>

                <section>
                    <h2>§ 4 Limitation of liability</h2>
                    <p>
                        The platform is in the beta phase. The operator is not liable for damages arising from AI-generated
                        content, outages of external providers or the beta nature of the service, unless such damages are based
                        on gross negligence or intent on the part of the operator.
                    </p>
                </section>

                <section>
                    <h2>§ 5 AI-generated content</h2>
                    <p>
                        The platform uses third-party AI services. The operator gives no warranty as to the correctness,
                        completeness or legal admissibility of the generated texts. Users are themselves responsible for
                        reviewing and using the results.
                    </p>
                </section>

                <section>
                    <h2>§ 6 Place of jurisdiction and applicable law</h2>
                    <p>
                        German law applies.
                        @if (!string.IsNullOrWhiteSpace(_settings.Jurisdiction))
                        {
                            <span>The place of jurisdiction is @_settings.Jurisdiction.</span>
                        }
                    </p>
                </section>

                @if (!string.IsNullOrWhiteSpace(_settings.TermsAppendMarkdown))
                {
                    <div class="legal-append">
                        @MarkdownRenderer.ToMarkupString(_settings.TermsAppendMarkdown)
                    </div>
                }
            </div>
        </div>
        <LandingFooter />
    </div>
}

@code {
    private Core.Domain.SiteSettings? _settings;

    protected override async Task OnInitializedAsync()
        => _settings = await SiteSettingsService.GetAsync();
}
