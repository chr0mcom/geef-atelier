@page "/contact"
@layout Layout.LandingLayout
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@using Geef.Atelier.Application.SiteSettings
@inject ISiteSettingsService SiteSettingsService

<PageTitle>Contact — Geef.Atelier</PageTitle>

@if (_settings is not null)
{
    <div class="lp-legal-page">
        <LandingNav />
        <div class="lp-container">
            <div class="legal-content contact-page">
                <h1>Contact</h1>

                <section class="contact-card">
                    <h2>@_settings.OperatorName</h2>
                    <address>
                        @_settings.AddressStreet<br />
                        @_settings.AddressZip @_settings.AddressCity<br />
                        @_settings.AddressCountry
                    </address>
                    <p class="contact-email-row">
                        <span class="contact-label">Email</span>
                        <EmailObfuscated Email="@_settings.ContactEmail" />
                    </p>
                    @if (!string.IsNullOrWhiteSpace(_settings.ContactPhone))
                    {
                        <p class="contact-email-row">
                            <span class="contact-label">Phone</span>
                            <span>@_settings.ContactPhone</span>
                        </p>
                    }
                </section>

                <p class="contact-note">
                    No contact form — email is the most direct way.
                </p>
            </div>
        </div>
        <LandingFooter />
    </div>
}

@code {
    private Core.Domain.SiteSettings? _settings;

    protected override async Task OnInitializedAsync()
        => _settings = await SiteSettingsService.GetAsync();
}
