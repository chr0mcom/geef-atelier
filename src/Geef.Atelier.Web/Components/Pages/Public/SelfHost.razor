@page "/self-host"
@layout Layout.LandingLayout
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization

<PageTitle>Self-host — Geef.Atelier</PageTitle>
<HeadContent>
    <meta name="description" content="Geef.Atelier is open source under the MIT license. Self-host the full pipeline on your own infrastructure — bring your own models, keep your own data." />
</HeadContent>

<div class="landing">
    <LandingNav />

    <section class="lp-section sh">
        <div class="lp-container">
            <p class="lp-eyebrow">Open source · MIT licensed</p>
            <h1 class="lp-h2">Run the atelier on <em>your own iron</em>.</h1>
            <p class="lp-lede">
                Geef.Atelier is free and open source under the MIT license — like the
                <a class="sh-link" href="https://github.com/chr0mcom/geef" target="_blank" rel="noopener">open Geef SDK</a>
                it is built on. Clone the repository, bring your own model keys, and run the
                whole workshop on your own infrastructure. Your briefings, your drafts,
                your data — they never leave your servers.
            </p>

            <div class="sh-actions">
                <a class="lp-cta lg" href="https://github.com/chr0mcom/geef-atelier" target="_blank" rel="noopener">
                    View on GitHub
                    <span class="arrow">↗</span>
                </a>
                <a class="lp-cta lg ghost" href="https://github.com/chr0mcom/geef" target="_blank" rel="noopener">
                    Read the SDK
                    <span class="arrow">↗</span>
                </a>
            </div>

            <div class="sh-grid">
                <div class="sh-item">
                    <h3>The full pipeline</h3>
                    <p>Grounding · Execution · Evaluation · Finalize — the same GEEF loop that powers every run here, running on your machine.</p>
                </div>
                <div class="sh-item">
                    <h3>Bring your own models</h3>
                    <p>Plug in your own keys via OpenRouter — OpenAI, Anthropic, or local models. No vendor lock-in, no per-seat tax.</p>
                </div>
                <div class="sh-item">
                    <h3>Multi-user &amp; admin</h3>
                    <p>DB-backed accounts with BCrypt, an admin panel, and per-user run isolation. Seed the first admin from env vars.</p>
                </div>
                <div class="sh-item">
                    <h3>MCP server built in</h3>
                    <p>Connect Claude Desktop or the CLI over a self-hosted OAuth 2.1 server, or a static bearer token. Fifteen tools out of the box.</p>
                </div>
                <div class="sh-item">
                    <h3>Knowledge base &amp; RAG</h3>
                    <p>Postgres + pgvector for vector search over your own documents, with global and run-local knowledge scopes.</p>
                </div>
                <div class="sh-item">
                    <h3>Docker &amp; Traefik</h3>
                    <p>One <code>docker compose</code> stack. Migrations run on startup, daily Postgres backups, health checks for your reverse proxy.</p>
                </div>
            </div>

            <div class="sh-quickstart">
                <span class="lp-mono-caption">Quick start</span>
                <pre><code>git clone https://github.com/chr0mcom/geef-atelier
cd geef-atelier
cp .env.example .env        # add your model + Postgres keys
docker compose up -d --build</code></pre>
                <p class="sh-note">
                    Migrations run automatically on startup. Health check at
                    <code>https://&lt;your-domain&gt;/health</code>.
                    Full deployment guide in the repository README.
                </p>
            </div>

            <p class="sh-foot">
                MIT licensed · Built on .NET 10, Blazor Server &amp; the open Geef SDK
                <span class="sh-sep">·</span>
                <a href="/">← Back to the atelier</a>
            </p>
        </div>
    </section>

    <LandingFooter />
</div>

<style>
    .sh { padding-top: 72px; }
    .sh .lp-h2 { max-width: 22ch; }
    .sh .sh-link { color: var(--hero); text-decoration: none; border-bottom: 1px solid color-mix(in oklch, var(--hero) 40%, transparent); }
    .sh .sh-link:hover { border-bottom-color: var(--hero); }

    .sh-actions {
        display: flex; flex-wrap: wrap; gap: 14px;
        margin: 36px 0 8px;
    }

    .sh-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        margin-top: 56px;
        background: var(--hairline-soft);
        border: 1px solid var(--hairline-soft);
    }
    @@media (max-width: 900px) { .sh-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 600px) { .sh-grid { grid-template-columns: 1fr; } }
    .sh-item {
        background: var(--surface);
        padding: 28px 26px;
    }
    .sh-item h3 {
        font-family: var(--font-display);
        font-weight: 400;
        font-size: 19px;
        letter-spacing: -0.01em;
        color: var(--ink);
        margin: 0 0 10px;
    }
    .sh-item p {
        font-family: var(--font-ui);
        font-size: 14px;
        line-height: 1.55;
        color: var(--ink-2);
        margin: 0;
    }
    .sh-item code {
        font-family: var(--font-mono);
        font-size: 12.5px;
        color: var(--ink);
        background: var(--surface-2);
        padding: 1px 5px;
        border-radius: 4px;
    }

    .sh-quickstart { margin-top: 48px; }
    .sh-quickstart pre {
        margin: 14px 0 0;
        background: var(--surface-2);
        border: 1px solid var(--hairline-soft);
        border-radius: 8px;
        padding: 22px 24px;
        overflow-x: auto;
    }
    .sh-quickstart code {
        font-family: var(--font-mono);
        font-size: 13px;
        line-height: 1.7;
        color: var(--ink);
        white-space: pre;
    }
    .sh-note {
        font-family: var(--font-ui);
        font-size: 14px;
        color: var(--ink-3);
        margin: 16px 0 0;
        line-height: 1.55;
    }
    .sh-note code {
        font-family: var(--font-mono);
        font-size: 12.5px;
        color: var(--ink-2);
    }

    .sh-foot {
        margin-top: 48px;
        padding-top: 24px;
        border-top: 1px solid var(--hairline-soft);
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--ink-3);
    }
    .sh-foot .sh-sep { margin: 0 10px; color: var(--ink-4); }
    .sh-foot a { color: var(--ink-2); text-decoration: none; }
    .sh-foot a:hover { color: var(--hero); }
</style>
