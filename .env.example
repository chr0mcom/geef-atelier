# Geef.Atelier — Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.

# PostgreSQL
POSTGRES_DB=geef_atelier
POSTGRES_USER=geef_atelier
POSTGRES_PASSWORD=<generate: openssl rand -base64 24>

# Web UI auth (single-user)
ATELIER_USER=admin
ATELIER_PASSWORD_HASH=<generate: dotnet run --project tools/HashPassword -- "YourPassword">

# MCP Bearer Token
ATELIER_MCP_TOKEN=<generate: openssl rand -hex 32>

# Traefik domain (used in docker-compose.yml labels)
ATELIER_DOMAIN=<your-domain>

# LLM providers
LLM_OPENROUTER_API_KEY=<your-openrouter-api-key>

# Tavily Web Search — optional, only needed for Tavily grounding profiles
TAVILY_API_KEY=
